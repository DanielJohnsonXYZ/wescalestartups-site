---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema, buildFaqSchema } from "../../lib/schema";
import { siteConfig } from "../../site";

const experimentationFaqs = [
  {
    question: "How is this different from random A/B tests?",
    answer:
      "Experiments sit under a constraint map. The job is to learn what moves qualified pipeline, not to ship volume for its own sake."
  },
  {
    question: "Do I need a sprint or diagnosis first?",
    answer:
      "If the bottleneck is unclear, Growth Diagnosis or the scorecard comes first. If the constraint is visible, a 90-day sprint or acquisition build may be the right container."
  },
  {
    question: "What does a good experiment brief include?",
    answer:
      "Hypothesis, primary metric, guardrails, owner, timeline, and the decision rule before you start — scale, stop, refine, or transfer."
  }
];

const experimentationSchema = [
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Experimentation", path: "/experimentation" }
  ]),
  buildFaqSchema(experimentationFaqs)
];
---

<BaseLayout
  title="Experimentation | We Scale Startups"
  description="Run focused growth experiments with clear hypotheses, owners, metrics, and decision rules — after the bottleneck is named."
  keywords="growth experiments, startup testing cadence, ICE backlog, post-PMF marketing tests"
  path="/experimentation"
  schema={experimentationSchema}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Experimentation</p>
      <h1>Run fewer experiments, learn more from each one.</h1>
      <p>We turn scattered marketing activity into tests with hypotheses, owners, commercial metrics, and decisions the team can act on.</p>
      <div class="hero-actions">
        <a
          class="button button-dark button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="experimentation-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="experimentation-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
        <a class="button button-light" href="/proof" data-cta="experimentation-proof">See proof</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell grid-3">
      <article class="feature-card">
        <h3>Choose</h3>
        <p>Select experiments by likely learning value, pipeline potential, effort, and risk.</p>
      </article>
      <article class="feature-card">
        <h3>Measure</h3>
        <p>Use clear leading and lagging metrics so tests do not become activity reports.</p>
      </article>
      <article class="feature-card">
        <h3>Decide</h3>
        <p>Scale, stop, refine, or transfer the work based on evidence.</p>
      </article>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">FAQ</p>
      <h2>Experiment discipline.</h2>
      <div class="grid-3">
        {experimentationFaqs.map((item) => (
          <article class="feature-card">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Experiments without a constraint map</p>
        <h2>Name the bottleneck before you scale tests.</h2>
        <p>
          In {siteConfig.bookingCallDurationPhrase}, we can usually tell whether the learning problem is positioning, acquisition, conversion, reporting, or ownership — so experiments compound instead of stacking.
        </p>
      </div>
      <div class="hero-actions">
        <a
          class="button button-brand button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="experimentation-final-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="experimentation-final-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
