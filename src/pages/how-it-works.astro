---
import BaseLayout from "../layouts/BaseLayout.astro";
import WssOperatingSystemDiagram from "../components/WssOperatingSystemDiagram.astro";
import { buildBreadcrumbSchema, buildFaqSchema } from "../lib/schema";
import { first30Days, siteConfig, strategicPageRelatedInsights } from "../site";

const cadence = [
  { day: "Mon", body: "Weekly priorities locked. Owners and decision rules attached to every test in the backlog." },
  { day: "Tue–Thu", body: "Execution. Briefs ship, copy ships, pages ship. Async on Slack. Daniel is in the build, not just review." },
  { day: "Fri", body: "Numbers review against the scorecard. What's working, what to scale, what to kill. Decisions logged." }
];

const phases = [
  {
    title: "Phase 1 — Diagnose",
    weeks: "Weeks 1–2",
    body: "Find the real constraint across ICP, positioning, funnel, channels, reporting, and team cadence. Ends in a plain-English bottleneck statement everyone agrees on."
  },
  {
    title: "Phase 2 — Build",
    weeks: "Weeks 3–6",
    body: "Turn the decision into pages, campaigns, workflows, dashboards, and a weekly rhythm. Existing assets get rewired before new ones are built."
  },
  {
    title: "Phase 3 — Test",
    weeks: "Weeks 7–10",
    body: "Run focused experiments with clear hypotheses, owners, and decision rules. ICE-scored, sequenced, and cut fast if they don't move the metric."
  },
  {
    title: "Phase 4 — Transfer",
    weeks: "Weeks 11–12",
    body: "Document the system so the founder, team, and vendors can keep running it. Handover doc, dashboard read-me, vendor SLAs, decision rules — all written."
  }
];

const youGet = [
  "Direct Slack and email — Daniel responds to commercial questions same-day",
  "A working backlog you can see and edit in Notion",
  "A weekly numbers dashboard tied to the metric we agreed in week one",
  "Monthly business review pack for the board or leadership team",
  "Every brief, page, and campaign written and shipped — not just specced",
  "On the way out: a 10–15 page handover doc so the system survives the engagement"
];

const howItWorksFaqs = [
  {
    question: "Is every engagement exactly 12 weeks?",
    answer:
      "Diagnosis and sprint windows vary by scope. The four-phase shape is consistent: diagnose, build, test, transfer — but timelines flex with team capacity and channel complexity."
  },
  {
    question: "What if we already have an agency?",
    answer:
      "Common. The weekly rhythm includes directing agency work inside one system: priorities, briefs, and stop/scale decisions — not competing channel plans."
  },
  {
    question: "What does transfer mean in practice?",
    answer:
      "Written decision rules, dashboard ownership, meeting format, and vendor SLAs so the team can run the rhythm without daily operator dependency."
  }
];

const howItWorksRelated = strategicPageRelatedInsights["/how-we-work"] ?? [];

const artefactGallery = [
  {
    src: "/images/deliverables/artefacts/growth-dashboard.webp",
    alt: "Anonymized weekly growth dashboard showing pipeline, conversion, CAC, and funnel trend charts.",
    caption: "The weekly growth dashboard every engagement ends with"
  },
  {
    src: "/images/deliverables/artefacts/experiment-backlog.webp",
    alt: "Anonymized experiment backlog table with hypotheses, ICE scores, owners, and status for Series A SaaS Co.",
    caption: "An active experiment backlog from a 90-day growth sprint"
  },
  {
    src: "/images/deliverables/artefacts/icp-map.webp",
    alt: "Anonymized ICP map grid with segment, core pain, and channel fit columns from a Growth Diagnosis.",
    caption: "ICP map built during Growth Diagnosis — segment, pain, channel fit"
  },
  {
    src: "/images/deliverables/artefacts/landing-brief.webp",
    alt: "Anonymized landing page brief document with placeholder brand name and structured sections.",
    caption: "A landing page brief from the Acquisition System Build phase"
  },
  {
    src: "/images/deliverables/artefacts/weekly-decision.webp",
    alt: "Anonymized weekly decision document with tested, moved, and next columns; figures obscured.",
    caption: "The weekly decision doc — what was tested, what moved, what is next"
  },
  {
    src: "/images/deliverables/artefacts/handover-pack.webp",
    alt: "Handover pack cover slide with title and systems tagline, no client details.",
    caption: "The handover pack delivered at the end of every engagement"
  }
];

const howItWorksSchema = [
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "How it works", path: "/how-it-works" }
  ]),
  buildFaqSchema(howItWorksFaqs)
];
---

<BaseLayout
  path="/how-it-works"
  title="How it works | We Scale Startups"
  description="How a WSS engagement runs week by week: diagnosis, acquisition system build, experiment cadence, and transfer to your team."
  keywords="fractional CMO process, growth engagement phases, weekly growth cadence, startup acquisition system, handover playbook"
  schema={howItWorksSchema}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">How it works</p>
      <h1>Diagnose. Build. Test. Transfer.</h1>
      <p class="lede">
        Most consultancy engagements are a black box. This one isn't. Here's exactly what happens week by week,
        what the cadence looks like, and what you walk away with.
      </p>
      <div class="hero-actions">
        <a
          class="button button-brand button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="how-it-works-hero-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="how-it-works-hero-scorecard">
          {siteConfig.scorecardLabel} →
        </a>
        <a class="button button-light" href="/diagnose" data-cta="how-it-works-hero-diagnose">
          5-layer framework (deep dive) →
        </a>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">First 30 days</p>
      <h2>What happens in month one.</h2>
      <p class="lede">Same sequence on most engagements — emphasis shifts with your bottleneck.</p>
      <div class="timeline">
        {first30Days.map((item) => (
          <article class="timeline-row">
            <span class="timeline-week">{item.week}</span>
            <div>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </div>
          </article>
        ))}
      </div>
      <p>
        <a class="card-link" href="/first-30-days">Full first 30 days detail →</a>
      </p>
    </div>
  </section>

  <WssOperatingSystemDiagram tone="alt" />

  <section class="section">
    <div class="shell">
      <p class="eyebrow">The engagement rhythm</p>
      <h2 style="font-family:'Geist','Inter',ui-sans-serif,system-ui,sans-serif;font-size:clamp(2.4rem,4vw,3.6rem);line-height:1.05;font-weight:700;margin:0.4rem 0 2.2rem;">Diagnose. Build. Test. Transfer.</h2>
      <div class="timeline">
        {phases.map((p) => (
          <article class="timeline-row">
            <span class="timeline-week">{p.weeks}</span>
            <div>
              <h3>{p.title}</h3>
              <p>{p.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section how-artefacts-section">
    <div class="shell">
      <p class="eyebrow">Deliverables</p>
      <h2
        style="font-family:'Geist','Inter',ui-sans-serif,system-ui,sans-serif;font-size:clamp(2.2rem,3.8vw,3.2rem);line-height:1.08;font-weight:700;margin:0.4rem 0 1rem;"
      >
        The work is in the artefacts, not the deck.
      </h2>
      <p class="lede how-artefacts-lede">
        Representative, anonymized snapshots of what ships inside an engagement — not client-specific screenshots.
        Exported at 2× for sharp displays; WebP for load time.
      </p>
      <div class="how-artefact-strip" role="list">
        {artefactGallery.map((item) => (
          <figure class="how-artefact-card" role="listitem">
            <img
              src={item.src}
              alt={item.alt}
              width="800"
              height="500"
              loading="lazy"
              decoding="async"
              class="how-artefact-img"
            />
            <figcaption class="how-artefact-caption">{item.caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell two-column">
      <div>
        <p class="eyebrow">Weekly cadence</p>
        <h2 style="font-family:'Geist','Inter',ui-sans-serif,system-ui,sans-serif;font-size:clamp(2.4rem,4vw,3.4rem);line-height:1.05;font-weight:700;margin:0.4rem 0 1.4rem;">One rhythm, every week.</h2>
        <p class="lead-copy">No mystery, no Friday-afternoon "what's been happening?" calls. The week is the same shape, every week.</p>
      </div>
      <div class="grid">
        {cadence.map((c) => (
          <article class="feature-card">
            <p class="card-kicker">{c.day}</p>
            <p>{c.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell two-column">
      <div>
        <p class="eyebrow">What you get</p>
        <h2 style="font-family:'Geist','Inter',ui-sans-serif,system-ui,sans-serif;font-size:clamp(2.4rem,4vw,3.4rem);line-height:1.05;font-weight:700;margin:0.4rem 0 1.4rem;">Practical working assets your team can use.</h2>
        <p class="lead-copy">Everything below is something the team can edit, run, or hand to a vendor on day 91 without us in the room.</p>
      </div>
      <ul class="daniel-credentials">
        {youGet.map((d) => <li>{d}</li>)}
      </ul>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">FAQ</p>
      <h2>How engagements run in practice.</h2>
      <div class="grid-3">
        {howItWorksFaqs.map((item) => (
          <article class="feature-card">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {
    howItWorksRelated.length > 0 && (
      <section class="section">
        <div class="shell">
          <p class="eyebrow">Related reading</p>
          <h2>Notes that pair with this page.</h2>
          <ul class="related-insights-list">
            {howItWorksRelated.map((item) => (
              <li>
                <a class="card-link" href={item.href}>
                  {item.label} →
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Next step</p>
        <h2>See if this rhythm fits your team.</h2>
        <p class="max-w-2xl mx-auto">Bring the current growth picture. {siteConfig.bookingCallDurationPhrase}. Plain English.</p>
      </div>
      <div class="hero-actions">
        <a class="button button-brand button-with-subcopy" href={siteConfig.bookingUrl} data-cta="how-it-works-cta">
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="how-it-works-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
      </div>
    </div>
  </section>

  <style>
    .how-artefacts-lede {
      max-width: 62ch;
      margin-bottom: 1.5rem;
    }
    .how-artefact-strip {
      display: flex;
      gap: 1rem;
      overflow-x: auto;
      padding-bottom: 0.5rem;
      scroll-snap-type: x proximity;
      margin-inline: -0.5rem;
      padding-inline: 0.5rem;
    }
    .how-artefact-card {
      flex: 0 0 min(340px, 85vw);
      scroll-snap-align: start;
      margin: 0;
      display: grid;
      gap: 0.65rem;
    }
    .how-artefact-img {
      width: 100%;
      height: auto;
      border-radius: 0.75rem;
      border: 1px solid var(--line);
      background: var(--surface);
      box-shadow: var(--shadow);
    }
    .how-artefact-caption {
      font-size: 0.88rem;
      line-height: 1.45;
      color: var(--muted);
      margin: 0;
      padding-right: 0.25rem;
    }
  </style>
</BaseLayout>
