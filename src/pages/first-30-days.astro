---
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema, buildFaqSchema } from "../lib/schema";
import { first30Days, siteConfig, strategicPageRelatedInsights } from "../site";

const deliverables = [
  "North Star and KPIs agreed + baseline dashboard",
  "ICP and messaging notes (voice of customer → value props → angle bank)",
  "90-day plan with owners, effort/impact scoring, and timelines",
  "Experiment backlog (prioritised) + 3–5 tests already shipped",
  "Channel plan (paid/SEO/content/partnerships/email) with first assets live",
  "Analytics and attribution hygiene: events, UTM discipline, reporting cadence",
  "Monthly business review pack so leadership sees progress at a glance"
];

const first30Faqs = [
  {
    question: "Is month one the same for every company?",
    answer:
      "The sequence is consistent — lock metrics, validate ICP, ship tests — but the emphasis shifts based on whether the constraint is positioning, acquisition, conversion, or reporting."
  },
  {
    question: "What do you need from us in week one?",
    answer:
      "Read access to analytics and CRM, a founder or operator for a kickoff, and honesty about what has already been tried. No perfect data required."
  },
  {
    question: "What if we need longer than 30 days before major spend?",
    answer:
      "That is common. Month one is about evidence and sequencing. Bigger bets follow once the bottleneck is named and the baseline is trustworthy."
  }
];

const first30Related = strategicPageRelatedInsights["/engagement-models"] ?? [];

const first30Schema = [
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "First 30 days", path: "/first-30-days" }
  ]),
  buildFaqSchema(first30Faqs)
];
---

<BaseLayout
  path="/first-30-days"
  title="First 30 days · We Scale Startups"
  description="Exactly what happens in the first month of an engagement. Week-by-week, with concrete deliverables you'll have by day 30."
  schema={first30Schema}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">First 30 days</p>
      <h1>Exactly what happens in month one.</h1>
      <p class="lede">
        Week-by-week. Real deliverables, not slides. By day 30 you have a documented plan,
        a working dashboard, and 3–5 experiments shipped against the constraint we found in week one.
      </p>
      <div class="hero-actions">
        <a class="button button-brand" href="/quiz" data-cta="first-30-hero-quiz">
          3-minute bottleneck quiz →
        </a>
        <a class="button button-light" href="/diagnose" data-cta="first-30-hero-diagnose">
          5-layer diagnostic →
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="first-30-hero-scorecard">
          {siteConfig.scorecardLabel} →
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="timeline">
        {first30Days.map((item) => (
          <article class="timeline-row">
            <span class="timeline-week">{item.week}</span>
            <div>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell two-column">
      <div>
        <p class="eyebrow">By day 30</p>
        <h2>What you'll have in your hands.</h2>
        <p class="lead-copy">
          Every deliverable below is a working artefact — not a deck. The team can use it, edit it, and run with it after we leave.
        </p>
      </div>
      <ul class="daniel-credentials">
        {deliverables.map((d) => <li>{d}</li>)}
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">FAQ</p>
      <h2>Month one in practice.</h2>
      <div class="grid-3">
        {first30Faqs.map((item) => (
          <article class="feature-card">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {
    first30Related.length > 0 && (
      <section class="section section-alt">
        <div class="shell">
          <p class="eyebrow">Related reading</p>
          <h2>How this fits the wider engagement map.</h2>
          <ul class="related-insights-list">
            {first30Related.map((item) => (
              <li>
                <a class="card-link" href={item.href}>
                  {item.label} →
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Sound right?</p>
        <h2>Book the call. Bring your numbers.</h2>
        <p>We'll spend {siteConfig.bookingCallDurationPhrase} on whether month one would actually move the needle for you, or whether something else would.</p>
      </div>
      <div class="hero-actions">
        <a class="button button-brand button-with-subcopy" href={siteConfig.bookingUrl} data-cta="first-30-days-cta">
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="first-30-days-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
