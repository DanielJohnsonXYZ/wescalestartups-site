---
// ServiceComparisonTable.astro
// Side-by-side comparison of the four engagements with Fractional CMO
// elevated as the premium offer.

const services = [
  {
    name: "Growth Diagnosis",
    href: "/services/growth-diagnosis",
    bestFor: "You're not sure what's blocking pipeline.",
    duration: "1 week",
    price: "from £4k",
    builds: "Constraint map, evidence review, 90-day plan.",
    solves: "Decision paralysis. Conflicting opinions on what to fix first.",
    next: "Read the Diagnosis page",
    primary: false
  },
  {
    name: "90-Day Growth Sprint",
    href: "/services/90-day-growth-sprint",
    bestFor: "You need focused tests this quarter.",
    duration: "12 weeks",
    price: "from £15k",
    builds: "Experiment backlog, weekly decisions, tested landing/copy/offer.",
    solves: "Activity without learning. Strategy without execution.",
    next: "Run a sprint",
    primary: false
  },
  {
    name: "Acquisition System Build",
    href: "/services/acquisition-system-build",
    bestFor: "Channels work in isolation; you need them as one system.",
    duration: "8–12 weeks",
    price: "from £30k",
    builds: "Channel architecture, offer map, reporting, handoff pack.",
    solves: "Disconnected paid + organic + outbound. No single decision view.",
    next: "Build the system",
    primary: false
  },
  {
    name: "Fractional CMO",
    href: "/services/fractional-cmo",
    bestFor: "You need senior growth leadership without a full-time hire.",
    duration: "3 months min, then rolling",
    price: "from £8k / month",
    builds: "Operating cadence, agency direction, board reporting, hiring calls.",
    solves: "Founder running marketing themselves. No senior owner inside the team.",
    next: "Add senior leadership",
    primary: true,
    note: "Premium offer · most teams stay 6–9 months"
  }
];
---

<section class="section service-compare-section" id="services-compare" aria-labelledby="compare-heading">
  <div class="shell">
    <div class="compare-head">
      <p class="eyebrow">Compare the four offers</p>
      <h2 id="compare-heading">Pick by constraint, not by menu.</h2>
      <p class="lede">All four engagements solve a different problem. Pick the smallest commitment that answers your biggest question.</p>
    </div>

    <div class="compare-cards">
      {services.map((s) => (
        <article class:list={["compare-card", { "compare-card-primary": s.primary }]}>
          {s.primary && <span class="compare-badge">Most popular</span>}
          <header class="compare-card-head">
            <h3>{s.name}</h3>
            <div class="compare-price">
              <strong>{s.price}</strong>
              <span>{s.duration}</span>
            </div>
          </header>
          {s.note && <p class="compare-note">{s.note}</p>}
          <dl class="compare-rows">
            <div><dt>Best for</dt><dd>{s.bestFor}</dd></div>
            <div><dt>What gets built</dt><dd>{s.builds}</dd></div>
            <div><dt>What it solves</dt><dd>{s.solves}</dd></div>
          </dl>
          <a class:list={["compare-cta", s.primary ? "button button-brand" : "button button-light"]} href={s.href}>
            {s.next} →
          </a>
        </article>
      ))}
    </div>

    <p class="compare-foot">Hands-on, not just advisory: we build the system with your team, then transfer it.</p>
  </div>
</section>

<style>
  .compare-head { max-width: 60ch; margin-bottom: 2.25rem; }
  .compare-head h2 { font-size: clamp(1.75rem, 4vw, 2.5rem); letter-spacing: -0.03em; line-height: 1.15; margin-top: 0.5rem; }
  .compare-head .lede { color: var(--muted); margin-top: 0.75rem; line-height: 1.6; }

  .compare-cards {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) { .compare-cards { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1180px) { .compare-cards { grid-template-columns: repeat(4, 1fr); } }

  .compare-card {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 1.25rem;
    padding: 1.5rem 1.25rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 180ms ease, transform 180ms ease;
  }
  .compare-card:hover { transform: translateY(-2px); }
  .compare-card-primary {
    border-color: var(--accent);
    box-shadow: 0 14px 32px -18px color-mix(in srgb, var(--accent) 40%, transparent);
  }
  .compare-badge {
    position: absolute;
    top: -10px; left: 1.25rem;
    background: var(--accent);
    color: #fff;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
  }
  .compare-card-head h3 {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 0.4rem;
  }
  .compare-price strong {
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--ink);
    display: block;
  }
  .compare-price span {
    color: var(--muted);
    font-size: 0.78rem;
  }
  .compare-note {
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
    align-self: start;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .compare-rows {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .compare-rows > div { border-top: 1px solid var(--line); padding-top: 0.85rem; }
  .compare-rows dt {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
  }
  .compare-rows dd {
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--ink);
    margin: 0.3rem 0 0;
  }
  .compare-cta {
    margin-top: auto;
    text-align: center;
  }
  .compare-foot {
    margin-top: 1.5rem;
    text-align: center;
    color: var(--muted);
    font-style: italic;
    font-size: 0.92rem;
  }
</style>
