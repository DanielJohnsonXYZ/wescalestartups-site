---
import { trustLogos } from "../site";
---

<section class="proof-strip" aria-label="Selected proof and ecosystem logos">
  <div class="shell proof-inner">
    <p>Selected client work and startup growth engagements</p>
    <div class="logo-row">
      {trustLogos.map((logo) => (
        <figure class="client-logo-tile">
          {"src" in logo ? <img src={logo.src} alt={logo.alt} loading="lazy" /> : <strong>{logo.label}</strong>}
          <figcaption>{logo.label}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
