---
import SectionIntro from "../../components/SectionIntro.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema, buildFaqSchema } from "../../lib/schema";
import { pricingTrustBullets, serviceSnapshots, servicesHubRelatedReading, siteConfig } from "../../site";

const servicesHubFaqs = [
  {
    question: "Which service should I start with?",
    answer:
      "If the bottleneck is unclear, start with Growth Diagnosis. If the constraint is visible, a sprint, acquisition system build, or fractional CMO may be cleaner — confirm on the diagnostic call."
  },
  {
    question: "Do I need an agency and WSS?",
    answer:
      "Often yes, in the right order: WSS clarifies the constraint and operating rules; agencies execute inside that system. Many teams already have agencies when we start."
  },
  {
    question: "How do pricing ranges work?",
    answer:
      "The pricing page publishes honest starting ranges. Final scope depends on team complexity, channel mix, urgency, and execution depth — agreed after the diagnostic call."
  }
];

const servicesSchema = [
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Services", path: "/services" }
  ]),
  buildFaqSchema(servicesHubFaqs)
];
---

<BaseLayout
  title="B2B SaaS Growth Services | We Scale Startups"
  description="Growth diagnosis, 90-day growth sprints, acquisition system builds, and fractional CMO support for post-PMF startup teams."
  keywords="growth diagnosis, 90-day growth sprint, acquisition system build, fractional CMO services, B2B SaaS GTM, post-PMF marketing"
  path="/services"
  breadcrumbItems={[
    { name: "Home", path: "/" },
    { name: "Services", path: "/services" }
  ]}
  schema={servicesSchema}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Services</p>
      <h1>Four ways to fix the bottleneck — pick the smallest that solves it.</h1>
      <p>
        Each offer includes who it is for, the problem it solves, timeline, starting price, and what ships. Confirm scope on a {siteConfig.bookingCallShort}.
      </p>
      <div class="hero-actions">
        <a
          class="button button-brand button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="services-hub-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="services-hub-scorecard">
          {siteConfig.scorecardLabel} →
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="offer-card-grid">
        {
          serviceSnapshots.map((service) => (
            <article class="feature-card offer-detail-card">
              <p class="card-kicker">{service.badge}</p>
              <h2>
                <a href={service.href}>{service.title}</a>
              </h2>
              <p>
                <strong>Who it is for:</strong> {service.bestFor}
              </p>
              <p>
                <strong>The problem:</strong> {service.problem}
              </p>
              <p>
                <strong>Timeline:</strong> {service.timeline} · <strong>Starting price:</strong> {service.price}
              </p>
              <div>
                <strong>Key deliverables</strong>
                <ul class="offer-deliverables">
                  {service.keyDeliverables.map((d) => (
                    <li>{d}</li>
                  ))}
                </ul>
              </div>
              <a class="button button-brand" href={service.href} data-cta={`services-hub-${service.shortTitle.toLowerCase()}`}>
                {service.cta} →
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <ul class="services-trust-list" aria-label="How engagements work">
        {pricingTrustBullets.map((line) => (
          <li>{line}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <SectionIntro
        eyebrow="How it works"
        title="Diagnose. Build. Test. Transfer."
        body="The work should leave the company more capable: clearer decisions, cleaner experiments, stronger proof, and less dependency on anyone guessing in a meeting."
      />
      <div class="grid-3">
        <article class="feature-card">
          <h3>Diagnose</h3>
          <p>Find the constraint that is actually slowing growth. Often it is positioning, sequencing, or weak evidence, not channel volume.</p>
        </article>
        <article class="feature-card">
          <h3>Build</h3>
          <p>Turn the strategy into pages, campaigns, research, measurement, and a weekly operating cadence.</p>
        </article>
        <article class="feature-card">
          <h3>Transfer</h3>
          <p>Document the system so founders, first marketers, agencies, and sales teams can keep running it.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Related reading</p>
      <h2>Pricing, proof, and how the work runs.</h2>
      <ul class="related-insights-list">
        {servicesHubRelatedReading.map((item) => (
          <li>
            <a class="card-link" href={item.href}>
              {item.label} →
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">FAQ</p>
      <h2>Choosing between the four engagements.</h2>
      <div class="grid-3">
        {servicesHubFaqs.map((item) => (
          <article class="feature-card">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Start here</p>
        <h2>Not sure which service fits?</h2>
        <p>Bring the current growth bottleneck. We will identify whether the constraint is diagnosis, sprint, acquisition system, or fractional leadership.</p>
      </div>
      <div class="hero-actions">
        <a
          class="button button-brand button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="services-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="services-scorecard">
          {siteConfig.scorecardLabel} →
        </a>
        <a class="button button-light" href="/contact" data-cta="services-contact">
          Contact →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .offer-card-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 900px) {
    .offer-card-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .offer-detail-card h2 {
    font-size: 1.35rem;
    margin: 0.25rem 0 0.75rem;
    letter-spacing: -0.02em;
  }
  .offer-detail-card h2 a {
    color: inherit;
    text-decoration: none;
  }
  .offer-detail-card h2 a:hover {
    color: var(--accent);
  }
  .offer-deliverables {
    margin: 0.5rem 0 0;
    padding-left: 1.2rem;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .offer-detail-card .button {
    margin-top: 1rem;
  }
  .services-trust-list {
    margin: 0 auto;
    padding: 1.15rem 1.25rem 1.2rem 1.5rem;
    max-width: 52rem;
    border: 1px solid var(--line);
    border-radius: 0.75rem;
    background: var(--surface);
    list-style: disc;
  }
  .services-trust-list li {
    margin: 0.35rem 0;
    padding-left: 0.15rem;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }
</style>
