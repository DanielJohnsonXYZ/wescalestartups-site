---
import { getCollection } from "astro:content";
import EmailSignup from "../components/EmailSignup.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionIntro from "../components/SectionIntro.astro";
import { buildBreadcrumbSchema, buildFaqSchema } from "../lib/schema";
import { formatDate, sortByOrder } from "../lib/utils";
import { insightsHubRelatedReading, insightsThemeGroups, siteConfig } from "../site";

const insights = sortByOrder(await getCollection("insights"));
const insightsById = new Map(insights.map((item) => [item.id, item]));

const insightsHubFaqs = [
  {
    question: "How is this different from generic marketing blogs?",
    answer:
      "Each note answers a founder question we see repeatedly: diagnosis, acquisition systems, AI visibility, and reducing founder dependency. The goal is a decision, not an archive."
  },
  {
    question: "Where should I start?",
    answer:
      "If the bottleneck is unclear, start with the scorecard or quiz, then read the note that matches your constraint. The proof page shows outcomes in one scroll."
  },
  {
    question: "Can I apply this without hiring WSS?",
    answer:
      "Many founders use the frameworks independently. When the constraint is political, cross-functional, or expensive to get wrong, the diagnostic call is the fastest honest check."
  }
];

const insightsSchema = [
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Insights", path: "/insights" }
  ]),
  buildFaqSchema(insightsHubFaqs)
];
---

<BaseLayout
  path="/insights"
  title="Growth notes for post-PMF founders | We Scale Startups"
  description="WSS insights organised around diagnosis, acquisition systems, fractional CMO leadership, and AI/LLM visibility — not a generic marketing blog archive."
  keywords="fractional CMO, B2B SaaS growth, growth diagnosis, acquisition system, GTM strategy, startup marketing, founder-led growth, pipeline bottleneck, We Scale Startups"
  schema={insightsSchema}
  lastUpdated={siteConfig.lastUpdated}
  breadcrumbItems={[
    { name: "Home", path: "/" },
    { name: "Insights", path: "/insights" }
  ]}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Insights</p>
      <h1>Growth notes for founders between traction and scale.</h1>
      <p class="lede">
        Notes are organised into four clusters (fractional CMO, GTM, AI-native marketing, and growth diagnostics), each with a pillar hub and spokes — so topics gain depth and internal links, not a flat archive. Pick a cluster below or scroll for every published note.
      </p>
      <div class="hero-actions">
        <a
          class="button button-dark button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="insights-hero-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="insights-hero-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
        <a class="button button-light" href="/fractional-cmo-vs-agency" data-cta="insights-hero-vs-agency">WSS vs agency</a>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <SectionIntro
        eyebrow="Content clusters"
        title="Four pillars with spokes — built for topical depth and internal links."
        body="Each cluster has a pillar page (the hub) and live spokes. More notes roll in until each cluster reaches 6–8 articles, all interlinked to the pillar and to relevant services."
      />
      <div class="insights-theme-grid">
        {insightsThemeGroups.map((theme) => {
          const pillar = insightsById.get(theme.pillarId);
          return (
            <article class="feature-card insights-theme-card">
              <h2>{theme.title}</h2>
              <p>{theme.description}</p>
              {pillar ? (
                <p class="insights-pillar-link">
                  <span class="insights-pillar-label">Pillar</span>
                  <a class="card-link" href={`/insights/${pillar.id}`}>
                    {pillar.data.title} →
                  </a>
                </p>
              ) : null}
              <ul class="insights-theme-links">
                {theme.spokeInsightIds.map((id) => {
                  const item = insightsById.get(id);
                  if (!item) return null;
                  return (
                    <li>
                      <a class="card-link" href={`/insights/${item.id}`}>
                        {item.data.title} →
                      </a>
                    </li>
                  );
                })}
              </ul>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionIntro
        eyebrow="Published notes"
        title="Start with the bottleneck, then choose the work."
        body="Each article is written to answer a real founder question, not to fill a blog archive."
      />
      <div class="grid-3">
        {insights.map((item) => (
          <article class="feature-card insight-card">
            <p class="card-kicker">{formatDate(item.data.publishedAt)}</p>
            <h2>{item.data.title}</h2>
            <p>{item.data.excerpt}</p>
            <div class="insight-tags">
              {item.data.tags.map((tag) => <span>{tag}</span>)}
            </div>
            <a class="card-link" href={`/insights/${item.id}`}>Read the note →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">Related reading</p>
      <h2>Frameworks and proof that pair with these notes.</h2>
      <ul class="related-insights-list">
        {insightsHubRelatedReading.map((item) => (
          <li>
            <a class="card-link" href={item.href}>
              {item.label} →
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">FAQ</p>
      <h2>How to use these notes.</h2>
      <div class="grid-3">
        {insightsHubFaqs.map((item) => (
          <article class="feature-card">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="shell">
      <EmailSignup
        heading="The Growth Bottleneck — weekly note"
        subtext="One actionable note for post-PMF founders: what’s stuck, what to do next, and why. No daily drip."
        formId="insights-footer"
      />
    </div>
  </section>

  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Apply this to your company</p>
        <h2>Diagnose the constraint before adding more activity.</h2>
        <p>
          Bring the current site, pipeline, campaigns, reporting, and team context. In {siteConfig.bookingCallDurationPhrase} we can usually decide which part of the system needs work first.
        </p>
      </div>
      <div class="hero-actions">
        <a
          class="button button-brand button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="insights-final-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="insights-final-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .insights-theme-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) {
    .insights-theme-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .insights-theme-card h2 {
    font-size: 1.08rem;
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }
  .insights-pillar-link {
    margin: 0.85rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .insights-pillar-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted, #5c5668);
  }
  .insights-theme-links {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
</style>
