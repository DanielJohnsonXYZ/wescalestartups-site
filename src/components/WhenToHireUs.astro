---
// WhenToHireUs.astro
// 5 buyer pain points — clear, scannable, helps unsure visitors
// self-qualify in under 30 seconds.
import { siteConfig } from "../site";

const signals = [
  { icon: "↗", title: "You have traction, but pipeline is inconsistent.", body: "Months land in waves. You can't predict next quarter's revenue with confidence." },
  { icon: "👤", title: "The founder is still the growth department.", body: "Decisions, copy, calls, dashboards — all routed through one person. It does not scale." },
  { icon: "💸", title: "You're spending on channels without knowing what to scale.", body: "Paid, content, outbound — running, but no single decision view. Every week feels like guessing." },
  { icon: "🤝", title: "Agencies are executing, but nobody owns the system.", body: "Specialists are doing tactics. Strategy lives in the founder's head. Reporting is activity, not commercial." },
  { icon: "🎯", title: "You need senior judgement before a full-time CMO.", body: "It's too early to commit to £150k base + equity. Too late to keep guessing." }
];
---

<section class="section when-to-hire" aria-labelledby="wth-heading">
  <div class="shell">
    <div class="when-to-hire-head">
      <p class="eyebrow">When to hire us</p>
      <h2 id="wth-heading">If any of these sound like you, we're a fit.</h2>
      <p class="lede">Five patterns we see in nearly every founder call. If any match, the answer is rarely more activity — it's a constraint named and a decision cadence installed.</p>
    </div>

    <div class="when-to-hire-grid">
      {signals.map((signal) => (
        <article class="when-card">
          <span class="when-icon" aria-hidden="true">{signal.icon}</span>
          <h3>{signal.title}</h3>
          <p>{signal.body}</p>
        </article>
      ))}
    </div>

    <div class="when-to-hire-cta">
      <a
        class="button button-brand"
        href={siteConfig.bookingUrl}
        data-cta="when-to-hire-book"
        title={siteConfig.bookingCallReassurance}
      >
        {siteConfig.bookingLabel} →
      </a>
      <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="when-to-hire-scorecard">
        Or, {siteConfig.scorecardLabel} →
      </a>
    </div>
  </div>
</section>

<style>
  .when-to-hire-head { max-width: 60ch; margin-bottom: 2.5rem; }
  .when-to-hire-head h2 { font-size: clamp(1.75rem, 4vw, 2.5rem); letter-spacing: -0.03em; line-height: 1.15; margin-top: 0.5rem; }
  .when-to-hire-head .lede { color: var(--muted); margin-top: 0.75rem; font-size: 1rem; line-height: 1.6; }

  .when-to-hire-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
    margin-bottom: 2rem;
  }
  @media (min-width: 720px) { .when-to-hire-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1080px) { .when-to-hire-grid { grid-template-columns: 1fr 1fr 1fr; } }

  .when-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 1.25rem;
    padding: 1.4rem 1.4rem 1.5rem;
    transition: border-color 180ms ease, transform 180ms ease;
  }
  .when-card:hover {
    border-color: color-mix(in srgb, var(--accent) 35%, var(--line));
    transform: translateY(-2px);
  }
  .when-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem; height: 2.4rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.85rem;
  }
  .when-card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0;
  }
  .when-card p {
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.55;
    margin-top: 0.5rem;
  }

  .when-to-hire-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
</style>
