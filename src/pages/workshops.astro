---
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema } from "../lib/schema";
import { siteConfig } from "../site";

const path = "/workshops";
const schema = [
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Workshops", path }
  ])
];
---

<BaseLayout
  path={path}
  title="Workshops | We Scale Startups"
  description="Hands-on workshops for portfolio teams and leadership groups: growth diagnosis, acquisition system design, and weekly operating cadence."
  schema={schema}
  breadcrumbItems={[
    { name: "Home", path: "/" },
    { name: "Workshops", path }
  ]}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Workshops</p>
      <h1>Diagnosis and system design in the room.</h1>
      <p class="lede">
        Formats for VCs, accelerators, and leadership offsites — bottleneck naming, experiment sequencing, and what &quot;transfer&quot; should look like. Enquire for agenda and audience fit.
      </p>
      <div class="hero-actions">
        <a class="button button-brand" href={siteConfig.bookingUrl} data-cta="workshops-book">{siteConfig.bookingLabel} →</a>
        <a class="button button-light" href={`mailto:${siteConfig.email}?subject=Workshop%20enquiry`}>Email workshop enquiry →</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="grid-3">
        <article class="feature-card">
          <h2>Growth diagnosis workshop</h2>
          <p>Half day. The leadership team scores the five constraints — positioning, acquisition, conversion, reporting, team ownership — against real numbers, and leaves with the bottleneck named and a sequenced 90-day plan.</p>
        </article>
        <article class="feature-card">
          <h2>Acquisition system design</h2>
          <p>Full day. Map the channel hierarchy, offer ladder, and weekly decision rule for your stage. The output is a one-page system the team can run on Monday, not a slide deck.</p>
        </article>
        <article class="feature-card">
          <h2>VC portfolio sessions</h2>
          <p>Repeatable 90-minute format for accelerators and funds: each founder leaves knowing which constraint to fix first and whether they need an agency, a hire, or a system. Runs for cohorts of 5–15 companies.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <div class="grid-3">
        <article class="feature-card">
          <h2>Who runs it</h2>
          <p>Daniel Johnson — 15 years operating in SaaS, fintech, healthtech and EdTech, two exits, 479+ founder sessions. Guest lecturer at Cambridge Judge, speaker at Imperial and Techstars.</p>
        </article>
        <article class="feature-card">
          <h2>Format and pricing</h2>
          <p>In person (London) or remote. Half-day, full-day, and portfolio cohort formats — pricing on enquiry. Materials, scorecards, and follow-up notes included.</p>
        </article>
        <article class="feature-card">
          <h2>What you leave with</h2>
          <p>A named constraint per team, a prioritised experiment backlog, and the weekly operating cadence to run it — the same artefacts our paid engagements produce, compressed into a room.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Next step</p>
        <h2>Book a workshop.</h2>
        <p>Tell us the team, the stage, and the constraint. We'll shape the session around it.</p>
      </div>
      <div class="hero-actions">
        <a class="button button-brand" href={siteConfig.bookingUrl} data-cta="workshops-final-book">{siteConfig.bookingLabel} →</a>
      </div>
    </div>
  </section>

</BaseLayout>
