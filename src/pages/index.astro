---
import { getCollection } from "astro:content";
import CaseCard from "../components/CaseCard.astro";
import SectionIntro from "../components/SectionIntro.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { sortByOrder } from "../lib/utils";
import { buildFaqSchema, buildPersonSchema } from "../lib/schema";
import { headlineMetrics, siteConfig, whoThisIsFor, faqs } from "../site";

const services = sortByOrder(await getCollection("services"));
const phases = services.filter((s) => s.data.order <= 3);
const delivery = services.filter((s) => s.data.order === 4);
const industries = sortByOrder(await getCollection("industries")).slice(0, 4);
const cases = sortByOrder(await getCollection("cases"));
const featuredCase = cases[0];
const marqueeItems = ["Google Launchpad", "Cambridge Judge", "GrowthMentor", "Newsflare", "Peachy", "Ned", "eQuoo", "LessonsUp"];
---

<BaseLayout schema={[buildPersonSchema(), buildFaqSchema()]}>
  <section class="hero">
    <div class="shell">
      <div class="hero-meta">
        <span>Fractional growth leadership</span>
        <span>Post-PMF B2B SaaS & AI · $1M–$10M ARR</span>
      </div>

      <h1>Senior growth operator for <em>post-PMF</em> B2B SaaS &amp; AI founders.</h1>

      <div class="hero-foot">
        <p class="hero-copy">Your product works. Acquisition is inconsistent. We Scale Startups is a senior operator — not an agency — who installs research, acquisition, and an operating cadence your team can keep running.</p>
        <dl class="hero-facts">
          <dt>Who</dt>
          <dd>$1M–$10M ARR B2B SaaS &amp; AI</dd>
          <dt>How</dt>
          <dd>Research → Acquisition → Operating Cadence</dd>
          <dt>Price</dt>
          <dd>{siteConfig.priceBand}</dd>
        </dl>
        <div class="hero-actions">
          <a class="button button-brand" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">{siteConfig.bookingLabel}</a>
          <a class="button button-light" href="/case-studies">See the proof</a>
        </div>
      </div>

      <div class="showcase">
        <div class="showcase-grid">
          <div class="showcase-copy">
            <p class="eyebrow">Track record</p>
            <h2 class="showcase-title">A decade operating growth for <em>product-led teams</em>.</h2>
            <p>We instrument the market, run the customer research, build the campaigns and conversion points, and install the operating cadence so the team can keep going after we leave.</p>
            <div class="showcase-stats">
              {headlineMetrics.map((metric) => (
                <div>
                  <span class="stat-number">{metric.value}</span>
                  <span class="stat-label">{metric.label}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="mock" aria-label="Growth system performance chart">
            <div class="mock-label">Weekly pipeline · signal</div>
            <div class="mock-value">2.84M</div>
            <div class="mock-badge">+184%</div>
            <div class="mock-chart" aria-hidden="true">
              <span></span><span></span><span></span><span></span><span></span>
              <span></span><span></span><span></span><span></span><span></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="marquee" aria-label="Selected proof and ecosystem names">
    <div class="marquee-track">
      {[...marqueeItems, ...marqueeItems].map((item) => (
        <>
          <span class="marquee-item">{item}</span>
          <span class="marquee-dot">✦</span>
        </>
      ))}
    </div>
  </div>

  <section class="section" id="who">
    <div class="shell">
      <SectionIntro
        eyebrow="Who this is for"
        title="Clear on fit. Clearer on non-fit."
        body="We don't take every engagement. A short call tells us both whether this is the right shape of help."
      />
      <div class="grid-2">
        <article class="fit-card fit-card-yes">
          <h3>For you if</h3>
          <ul>
            {whoThisIsFor.forYou.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article class="fit-card fit-card-no">
          <h3>Not for you if</h3>
          <ul>
            {whoThisIsFor.notForYou.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section" id="engine">
    <div class="shell">
      <SectionIntro
        eyebrow="The engine"
        title="Three phases. One delivery model."
        body="Research, Acquisition, and Operating Cadence are sequenced phases — each strengthens the same growth loop. Fractional CMO is the delivery model that runs all three."
      />

      <div class="engine-list">
        {phases.map((service, index) => {
          const words = service.data.shortTitle.split(" ");
          const first = words[0];
          const rest = words.slice(1).join(" ");
          return (
            <a class="engine-row" href={`/services/${service.id}`}>
              <span class="engine-num">{String(index + 1).padStart(2, "0")}</span>
              <h3>{first} {rest && <em>{rest}</em>}</h3>
              <p>{service.data.description}</p>
              <span class="engine-tag">{service.data.cta}</span>
            </a>
          );
        })}
        {delivery.map((service) => (
          <a class="engine-row engine-row-delivery" href={`/services/${service.id}`}>
            <span class="engine-num">△</span>
            <h3>{service.data.shortTitle} <em>· delivery</em></h3>
            <p>{service.data.description}</p>
            <span class="engine-tag">{service.data.cta}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="statement">
        <h2>Agencies pitch. <em>Operators install.</em></h2>
        <p>Operating principle · 01</p>
      </div>
    </div>
  </section>

  {featuredCase && (
    <section class="section" id="results">
      <div class="shell">
        <SectionIntro
          eyebrow="Results"
          title="Pipeline, proof, and learning velocity."
          body="Case studies stay grounded in actual constraints: market clarity, acquisition efficiency, and conversion."
        />
        <div class="case-feature">
          <div class="case-visual" aria-hidden="true">
            <span>{featuredCase.data.client} · deployment</span>
            <span>{featuredCase.data.results[0]}</span>
            <strong>{featuredCase.data.client.slice(0, 1)}</strong>
          </div>
          <div class="case-copy">
            <p class="eyebrow">{featuredCase.data.sector}</p>
            <h3>From scattered spend to a cleaner <em>growth system</em>.</h3>
            <p>{featuredCase.data.challenge}</p>
            <p>{featuredCase.data.summary}</p>
            <div class="case-metrics">
              {featuredCase.data.results.slice(0, 3).map((result) => (
                <div>
                  <span class="stat-number">{result.split(" ")[0]}</span>
                  <span class="stat-label">{result}</span>
                </div>
              ))}
            </div>
            <div class="hero-actions">
              <a class="button button-brand" href={`/case-studies/${featuredCase.id}`}>Read the case</a>
              <a class="button button-light" href="/case-studies">All proof</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <section class="section section-alt">
    <div class="shell operator-grid">
      <div class="operator-copy">
        <p class="eyebrow">The operator</p>
        <h2>Senior growth thinking without theatre.</h2>
        <p>Work directly with Daniel Johnson on the decisions that shape growth: which customer to pursue, how to reach them, what to test, and how to turn the lessons into a repeatable system.</p>
        <ul class="note-list">
          <li>10+ years operating growth across B2B SaaS, AI, fintech, healthtech, edtech</li>
          <li>388+ mentorship sessions on GrowthMentor, 4.93★ average rating</li>
          <li>£20M+ revenue influenced, £6M+ managed across paid acquisition</li>
          <li>UK-based, currently operating from Asia — clients US, UK, and Europe</li>
        </ul>
        <div class="hero-actions">
          <a class="button button-dark" href="/about">About Daniel</a>
          <a class="button button-light" href={siteConfig.founderLinkedin} rel="noreferrer" target="_blank">LinkedIn</a>
        </div>
      </div>
      <div class="founder-image">
        <img src="/images/daniel-headshot.png" alt="Daniel Johnson, founder of We Scale Startups" />
      </div>
    </div>
  </section>

  <section class="section" id="markets">
    <div class="shell">
      <SectionIntro
        eyebrow="Markets"
        title="Built around categories where trust and clarity matter."
        body="The same system adapts to different buying contexts: technical buyers, regulated categories, education users, and founders trying to make a new behaviour obvious."
      />
      <div class="grid-4">
        {industries.map((industry) => (
          <a class="industry-card" href={`/industries/${industry.id}`}>
            <p class="card-kicker">Market</p>
            <h3>{industry.data.title}</h3>
            <p>{industry.data.description}</p>
            <span class="card-link">Explore market</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <SectionIntro
        eyebrow="More proof"
        title="Real work beats generic promise."
        body="A few more examples of practical growth work across fintech, healthtech, and education."
      />
      <div class="grid-3">
        {cases.slice(1, 4).map((item) => (
          <CaseCard
            href={`/case-studies/${item.id}`}
            title={item.data.title}
            sector={item.data.sector}
            summary={item.data.summary}
            results={item.data.results}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="faq">
    <div class="shell">
      <SectionIntro
        eyebrow="FAQ"
        title="Questions we get before every first call."
      />
      <div class="faq-list">
        {faqs.map((item) => (
          <details class="faq-item">
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band" id="cta">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Next step</p>
        <h2>Bring your current growth bottleneck.</h2>
        <p>A 30-minute call to map the constraint, the priorities, and whether We Scale Startups is the right partner for the work. No deck, no pitch.</p>
      </div>
      <a class="button button-brand" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">{siteConfig.bookingLabel}</a>
    </div>
  </section>
</BaseLayout>
