---
import SectionIntro from "../../components/SectionIntro.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { serviceSnapshots, siteConfig } from "../../site";
---

<BaseLayout title="Services | We Scale Startups" description="Growth diagnosis, 90-day growth sprints, acquisition system builds, and fractional CMO support for post-PMF startup teams." path="/services">
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Services</p>
      <h1>Choose the growth path that matches the bottleneck.</h1>
      <p>Start with a diagnosis if the path is unclear. Move into a sprint, acquisition build, or fractional CMO support when the constraint is visible.</p>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="service-selector">
        <aside class="service-selector-aside">
          <p class="eyebrow">Service selector</p>
          <h3>Choose by bottleneck.</h3>
          <p>Every engagement has a job: find the constraint, ship focused work, build the system, or add senior leadership.</p>
        </aside>
        <div class="service-selector-list">
          {serviceSnapshots.map((service, idx) => (
            <a class:list={["service-selector-row", { "is-priority": idx === 0 }]} href={service.href}>
              <div class="service-selector-index">{String(idx + 1).padStart(2, "0")}</div>
              <div>
                <p class="card-kicker">{service.shortTitle}</p>
                <h3>{service.title}</h3>
                <p><strong>Best for:</strong> {service.bestFor}</p>
                <p><strong>What you get:</strong> {service.get}</p>
              </div>
              <div class="service-selector-meta">
                <span>{service.timeline}</span>
                <strong>{service.price}</strong>
                <em>{service.cta}</em>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <SectionIntro
        eyebrow="How it works"
        title="Diagnose. Build. Test. Transfer."
        body="The work should leave the company more capable: clearer decisions, cleaner experiments, stronger proof, and less dependency on anyone guessing in a meeting."
      />
      <div class="grid-3">
        <article class="feature-card">
          <h3>Diagnose</h3>
          <p>Find the constraint that is actually slowing growth. Often it is positioning, sequencing, or weak evidence, not channel volume.</p>
        </article>
        <article class="feature-card">
          <h3>Build</h3>
          <p>Turn the strategy into pages, campaigns, research, measurement, and a weekly operating cadence.</p>
        </article>
        <article class="feature-card">
          <h3>Transfer</h3>
          <p>Document the system so founders, first marketers, agencies, and sales teams can keep running it.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Start here</p>
        <h2>Not sure which service fits?</h2>
        <p>Bring the current growth bottleneck. We will identify whether the constraint is diagnosis, sprint, acquisition system, or fractional leadership.</p>
      </div>
      <a class="button button-brand" href={siteConfig.bookingUrl} data-cta="services-book">{siteConfig.bookingLabel}</a>
    </div>
  </section>
</BaseLayout>
