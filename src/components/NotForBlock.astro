---
import { notFor, siteConfig } from "../site";
import SectionIntro from "./SectionIntro.astro";
---

<section class="section section-alt not-for-section" aria-label="Who this is not for">
  <div class="shell">
    <SectionIntro
      eyebrow="Who this is not for"
      title="Be clear up-front so we don't waste your call."
      body="If any of these match, we'd rather say so now than three weeks into a kickoff. We'll point you somewhere better."
    />
    <div class="not-for-grid">
      {notFor.map((item) => (
        <article class="not-for-card">
          <span class="not-for-x" aria-hidden="true">✕</span>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
    <p class="not-for-footnote">
      If you're not sure which side of the line you're on, start with the{" "}
      <a href={siteConfig.scorecardUrl} data-cta="not-for-scorecard">{siteConfig.scorecardLabel}</a>
      — five minutes, plain-English read on where the bottleneck probably sits.
    </p>
  </div>
</section>
