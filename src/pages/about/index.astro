---
import BrandLogoSlot from "../../components/BrandLogoSlot.astro";
import ProofLogos from "../../components/ProofLogos.astro";
import TldrCallout from "../../components/TldrCallout.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema, buildFaqSchema } from "../../lib/schema";
import { aboutRelatedReading, canonicalProofMetrics, revenueInfluencedNote, siteConfig } from "../../site";

const aboutFaqs = [
  {
    question: "What does We Scale Startups actually do?",
    answer:
      "WSS diagnoses the real growth bottleneck, builds the acquisition system around it, and transfers the operating rhythm so post-PMF teams are not stuck in founder-led growth decisions."
  },
  {
    question: "Who is WSS for?",
    answer:
      "Post-PMF startups with traction and inconsistent acquisition — typically B2B SaaS, AI, fintech, healthtech, and similar markets — where positioning, channels, reporting, and team cadence need to work as one system."
  },
  {
    question: "How do we start?",
    answer: `Use the scorecard or ${siteConfig.bookingLabel.replace(/^Book /, "book ")} when the bottleneck is visible enough to discuss. The first job is naming the constraint before adding more activity.`
  }
];

const aboutSchema = [
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "About", path: "/about" }
  ]),
  buildFaqSchema(aboutFaqs)
];
---

<BaseLayout
  title="About | We Scale Startups"
  description="Founder-led growth consultancy: diagnosis, acquisition systems, and fractional CMO support for post-PMF startups. Founded by Daniel Johnson."
  keywords="We Scale Startups about, Daniel Johnson founder, growth consultancy London, post-PMF startup support, acquisition system builder"
  path="/about"
  schema={aboutSchema}
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">About</p>
      <h1>Founder-led growth consultancy for teams between traction and scale.</h1>
      <TldrCallout
        text="WSS is the operator bench for post-PMF B2B SaaS and AI startups: we diagnose the real constraint, wire acquisition and reporting into one system, and leave the team with a weekly rhythm they can run without founder heroics — not slides, not undifferentiated agency hours."
      />
      <p>
        We Scale Startups works with post-PMF teams that already have signal but need clearer positioning, sharper acquisition,
        and a repeatable operating rhythm — without committing to a £150k full-time CMO hire.
      </p>
    </div>
  </section>

  <ProofLogos />

  <section class="section section-alt" aria-label="Proof at a glance">
    <div class="shell">
      <p class="eyebrow">At a glance</p>
      <h2 class="visually-hidden">Key proof metrics</h2>
      <div class="hero-proof" style="grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); border-top: none; padding-top: 0;">
        {canonicalProofMetrics.map((metric) => (
          <div>
            <strong>{metric.value}</strong>
            <span>{metric.label}</span>
          </div>
        ))}
      </div>
      <p style="margin-top: 1rem; max-width: 52ch; color: var(--muted); font-size: 0.88rem;">
        <strong>£18M+ revenue influenced:</strong> {revenueInfluencedNote}
      </p>
    </div>
  </section>

  <!-- WHY WSS EXISTS -->
  <section class="section">
    <div class="shell">
      <div style="max-width: 70ch;">
        <p class="eyebrow">Why WSS exists</p>
        <h2>Founders kept getting stuck running marketing themselves.</h2>
        <p style="margin-top: 1rem;">
          After 15 years operating inside SaaS, fintech, healthtech and EdTech startups — including two exits —
          the same pattern kept showing up: founders with great products who were stuck running marketing themselves
          because nobody else on the team could read the numbers and decide what to scale.
        </p>
        <p style="margin-top: 0.85rem;">
          WSS was built to be the operator we wished was there. Senior judgement that diagnoses the real constraint,
          builds the acquisition system around it, and transfers the rhythm so growth doesn't depend on founder heroics.
          Not advisory decks. Not agency execution. The system in between.
        </p>
      </div>
    </div>
  </section>

  <!-- ABOUT DANIEL — strengthened -->
  <section class="section section-alt" id="daniel">
    <div class="shell split-section">
      <div class="founder-gallery">
        <div class="founder-image">
          <picture>
            <source
              srcset="/images/daniel-headshot-640.webp 640w, /images/daniel-headshot-960.webp 960w"
              sizes="(max-width: 640px) 100vw, 48vw"
              type="image/webp"
            />
            <img src="/images/daniel-headshot-960.webp" alt="Daniel Johnson, founder of We Scale Startups" width="960" height="1003" loading="eager" decoding="async" fetchpriority="high" />
          </picture>
        </div>
        <picture>
          <source
            srcset="/images/daniel-aircraft-640.webp 640w, /images/daniel-aircraft-960.webp 960w"
            sizes="(max-width: 640px) 100vw, 48vw"
            type="image/webp"
          />
          <img class="founder-secondary-photo" src="/images/daniel-aircraft-960.webp" alt="Daniel Johnson outside the office, personal photo for founder credibility" width="960" height="960" loading="lazy" decoding="async" />
        </picture>
      </div>
      <div class="founder-copy">
        <p class="eyebrow">About Daniel Johnson</p>
        <h2>The operator behind WSS.</h2>
        <p>
          Daniel is the founder of We Scale Startups. 15+ years operating inside founder-led startups across SaaS,
          AI, fintech, healthtech, and EdTech. Two operator-side exits. Now leads diagnostic, acquisition system,
          and fractional CMO engagements for post-PMF teams in the £1M–£10M ARR band.
        </p>

        <h3 class="founder-section-h3">Operator background</h3>
        <ul class="note-list">
          <li>Two operator-side startup exits — eQuoo (mental-health tech) and an eCommerce brand</li>
          <li>Senior in-house operating roles: Head of Growth at Shoprocket and NAVA</li>
          <li>15+ years across SaaS, AI, fintech, healthtech, EdTech, and eCommerce</li>
        </ul>

        <h3 class="founder-section-h3">Paid acquisition experience</h3>
        <ul class="note-list">
          <li>£6M+ paid acquisition spend managed across SaaS, fintech, healthtech, EdTech</li>
          <li>500+ qualified sign-ups from a single paid campaign at 8.6% CTR (US B2B fintech)</li>
          <li>35% CAC reduction in 8 weeks (fintech) via account structure + landing-page routing</li>
          <li>6× growth in monthly app downloads (2k → 12k+) over 6 months for an AI HealthTech</li>
        </ul>

        <h3 class="founder-section-h3">Mentoring &amp; speaking credibility</h3>
        <ul class="note-list">
          <li>Google for Startups and Techstars ecosystem mentor</li>
          <li>Speaking and teaching at Cambridge Judge Business School, Imperial College London, Nomad Summit, Shenzhen SaaS, Foundervine</li>
          <li>20+ post-PMF startups advised across Seed–Series B</li>
          <li>Top-rated mentor on GrowthMentor (4.93/5)</li>
        </ul>
        <div class="mt-6 flex flex-wrap items-center gap-4">
          <img src="/images/logos/google.webp" alt="Google for Startups — Mentor" class="h-8 w-auto" />
          <img src="/images/logos/cambridge.webp" alt="University of Cambridge — Visiting Lecturer" class="h-8 w-auto" />
          <BrandLogoSlot label="Imperial College" href="https://www.imperial.ac.uk/" />
          <BrandLogoSlot label="Techstars" href="https://www.techstars.com/" />
        </div>

        <h3 class="founder-section-h3">How Daniel works with founders</h3>
        <p>
          Direct, system-level, hands-on. Diagnose the constraint first, build the acquisition system around it,
          transfer the rhythm so the team can run it without us. Most engagements last 6–9 months. No long-tail
          retainers, no junior account managers, no quarterly strategy decks. The work shows up in pipeline,
          not in theatre.
        </p>

        <div class="hero-actions" style="margin-top: 1.5rem;">
          <a
            class="button button-brand"
            href={siteConfig.bookingUrl}
            data-cta="about-daniel-book"
            title={siteConfig.bookingCallReassurance}
          >
            {siteConfig.bookingLabel} →
          </a>
          <a class="button button-light" href={siteConfig.founderLinkedin} rel="noreferrer" target="_blank">
            Daniel on LinkedIn →
          </a>
          <a class="button button-light" href={siteConfig.danielSite} rel="noreferrer" target="_blank">
            DanielJohnson.xyz →
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Related reading</p>
      <h2>How we work and who it is for.</h2>
      <ul class="related-insights-list">
        {aboutRelatedReading.map((item) => (
          <li>
            <a class="card-link" href={item.href}>
              {item.label} →
            </a>
          </li>
        ))}
        <li>
          <a class="card-link" href={`${siteConfig.danielSite}/`} rel="noreferrer" target="_blank">
            Daniel Johnson · founder site →
          </a>
        </li>
      </ul>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">FAQ</p>
      <h2>About WSS in three questions.</h2>
      <div class="grid-3">
        {aboutFaqs.map((item) => (
          <article class="feature-card">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Next step</p>
        <h2>Bring the current bottleneck.</h2>
        <p>
          {siteConfig.bookingCallDurationPhrase}. No deck, no pitch. We'll diagnose the bottleneck and decide if working together makes sense.
        </p>
      </div>
      <div class="hero-actions">
        <a
          class="button button-brand button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="about-final-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="about-final-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
        <a class="button button-light" href="/contact" data-cta="about-final-contact">
          Contact →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .founder-section-h3 {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin: 1.75rem 0 0.65rem;
  }
</style>
