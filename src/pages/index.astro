---
import { getCollection } from "astro:content";
import CaseCard from "../components/CaseCard.astro";
import ProofLogos from "../components/ProofLogos.astro";
import SectionIntro from "../components/SectionIntro.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { sortByOrder } from "../lib/utils";
import { headlineMetrics, leadMagnets, proofStandards, siteConfig } from "../site";

const services = sortByOrder(await getCollection("services"));
const priorityIndustries = ["saas-growth", "fintech", "healthtech", "edtech"];
const industries = sortByOrder(await getCollection("industries")).filter((industry) => priorityIndustries.includes(industry.id));
const cases = sortByOrder(await getCollection("cases"));
const featuredCase = cases[0];

const fitSignals = [
  "Post-PMF, but growth is still too founder-dependent",
  "Traction is real, but the team has no repeatable system",
  "You need senior growth leadership before, alongside, or after a full-time hire",
  "Acquisition, reporting, and conversion need cleaner ownership",
  "Spend is live, but reporting does not explain what to scale",
  "Channels are active, but pipeline is inconsistent"
];

const aiUses = [
  "Customer research synthesis",
  "Call and review analysis",
  "ICP and pain mapping",
  "Landing page test briefs",
  "Reporting automation",
  "Experiment prioritisation",
  "Content workflow design"
];

const process = [
  ["Diagnose", "/services/growth-diagnosis", "Find the real constraint across ICP, positioning, funnel, channels, reporting, and team cadence."],
  ["Build", "/services/acquisition-system-build", "Turn the decision into pages, campaigns, workflows, dashboards, and a weekly rhythm."],
  ["Test", "/services/90-day-growth-sprint", "Run focused experiments with clear hypotheses, owners, and decision rules."],
  ["Transfer", "/transfer", "Document the system so the founder, team, and vendors can keep running it."]
] as const;

function metricLead(result: string) {
  return result.match(/(?:[$£])?\d+(?:\.\d+)?%?\+?/)?.[0] ?? result.split(" ")[0];
}
---

<BaseLayout
  path="/"
  title="We Scale Startups | Fractional CMO & Growth Systems for Post-PMF Startups"
  description="Premium growth consultancy for post-PMF startups that need senior growth leadership, clearer GTM, and more predictable acquisition."
>
  <section class="hero hero-with-portrait">
    <div class="shell hero-grid">
      <div>
        <div class="hero-meta">
          <span>Fractional CMO · Growth diagnosis · Acquisition systems</span>
          <span>Post-PMF startups</span>
        </div>

        <h1>Senior growth leadership for startups that need more predictable acquisition.</h1>

        <p class="hero-copy">
          We work alongside founders, teams, agencies, and existing marketing hires to turn messy growth activity into clearer positioning,
          sharper acquisition, and a pipeline rhythm the team can run.
        </p>

        <div class="hero-actions">
          <a class="button button-brand" href={siteConfig.bookingUrl} data-cta="hero-book">{siteConfig.bookingLabel}</a>
          <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="hero-scorecard">{siteConfig.scorecardLabel}</a>
        </div>

        <div class="hero-proof">
          {headlineMetrics.map((metric) => (
            <div>
              <strong>{metric.value}</strong>
              <span>{metric.label}</span>
            </div>
          ))}
        </div>
      </div>

      <aside class="hero-portrait-card" aria-label="Founder-led growth support">
        <div class="founder-image">
          <picture>
            <source
              srcset="/images/daniel-headshot-640.webp 640w, /images/daniel-headshot-960.webp 960w"
              sizes="(max-width: 640px) 100vw, 38vw"
              type="image/webp"
            />
            <img src="/images/daniel-headshot-960.webp" alt="Daniel Johnson, founder of We Scale Startups" width="960" height="1003" loading="eager" decoding="async" fetchpriority="high" />
          </picture>
        </div>
        <div class="hero-offer">
          <p class="eyebrow">What we fix</p>
          <ul class="note-list">
            <li>Positioning that does not convert</li>
            <li>Pipeline inconsistency</li>
            <li>Founder-led sales dependency</li>
            <li>Reporting that hides the real issue</li>
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <ProofLogos />

  <section class="section" id="fit">
    <div class="shell two-column">
      <div>
        <p class="eyebrow">Who this is for</p>
        <h2>For teams with traction, pressure, and no clean growth rhythm yet.</h2>
        <p class="lead-copy">The pattern is usually simple: the product works, the team is busy, but pipeline still depends on founder energy and scattered channel activity.</p>
      </div>
      <div class="grid">
        {fitSignals.map((item) => (
          <article class="feature-card compact-card">
            <p>{item}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="services">
    <div class="shell">
      <SectionIntro
        eyebrow="Services"
        title="Four clearer ways to work together."
        body="Start with a diagnosis if the path is unclear. Move into a sprint, acquisition build, or fractional CMO support when the constraint is visible."
      />

      <div class="grid-4">
        {services.map((service) => (
          <a class="service-card service-card-strong" href={`/services/${service.id}`}>
            <p class="card-kicker">{service.data.shortTitle}</p>
            <h3>{service.data.title}</h3>
            <p><strong>Who for:</strong> {service.data.audience}</p>
            <p><strong>What changes:</strong> {service.data.promise}</p>
            <span class="card-link">{service.data.cta}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell two-column">
      <div>
        <p class="eyebrow">AI-native, practically</p>
        <h2>AI speeds execution. Judgement decides priorities.</h2>
        <p class="lead-copy">
          We use AI where it shortens research, analysis, briefing, reporting, and iteration.
          Senior operator judgement still decides what gets used, what gets ignored, and what matters commercially.
        </p>
      </div>
      <div class="grid grid-2">
        {aiUses.map((item) => (
          <article class="feature-card compact-card">
            <p>{item}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell two-column">
      <div>
        <p class="eyebrow">Daniel credibility</p>
        <h2>Founder-led, but built to transfer into your team.</h2>
        <p class="lead-copy">
          Daniel brings the senior judgment, then turns that judgment into workflows, reporting, briefs, and handoff
          material your team can keep using.
        </p>
      </div>
      <div class="grid grid-2">
        {[
          "Google for Startups and Techstars ecosystem mentor",
          "GrowthMentor track record with hundreds of founder sessions",
          "Experience across SaaS, AI, fintech, healthtech, ecommerce, and education",
          "Practical operator background across paid, SEO, CRO, positioning, GTM, and reporting"
        ].map((item) => (
          <article class="feature-card compact-card">
            <p>{item}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {featuredCase && (
    <section class="section" id="results">
      <div class="shell">
        <SectionIntro
          eyebrow="Case studies"
          title="Before, work done, result."
          body="Proof should be easy to scan. Each case shows the commercial problem, the work, and what changed."
        />
        <div class="case-feature">
          <div class="case-visual" aria-hidden="true">
            <span>{featuredCase.data.client}</span>
            <span>{featuredCase.data.results[0]}</span>
            <strong>{featuredCase.data.client.slice(0, 1)}</strong>
          </div>
          <div class="case-copy">
            <p class="eyebrow">{featuredCase.data.sector}</p>
            <h3>{featuredCase.data.title}</h3>
            <div class="proof-steps">
              <div><span>Before</span><p>{featuredCase.data.challenge}</p></div>
              <div><span>Work done</span><p>{featuredCase.data.work.slice(0, 3).join(", ")}.</p></div>
              <div><span>Result</span><p>{featuredCase.data.results.slice(0, 2).join("; ")}.</p></div>
            </div>
            <div class="case-metrics">
              {featuredCase.data.results.slice(0, 3).map((result) => (
                <div>
                  <span class="stat-number">{metricLead(result)}</span>
                  <span class="stat-label">{result}</span>
                </div>
              ))}
            </div>
            <div class="hero-actions">
              <a class="button button-brand" href={`/case-studies/${featuredCase.id}`}>Read the case</a>
              <a class="button button-light" href="/case-studies">All proof</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <section class="section section-alt">
    <div class="shell">
      <SectionIntro
        eyebrow="Process"
        title="Diagnose. Build. Test. Transfer."
        body="The point is not to create dependency. The point is to leave the growth function clearer and easier to run."
      />
      <div class="grid-4">
        {process.map(([title, href, body], index) => (
          <a class="feature-card process-card" href={href}>
            <p class="card-kicker">{String(index + 1).padStart(2, "0")}</p>
            <h3>{title}</h3>
            <p>{body}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionIntro
        eyebrow="Resources"
        title="Useful before you spend more."
        body="Lightweight guides for founders, leadership teams, and portfolio teams trying to diagnose the growth constraint."
      />
      <div class="grid-3">
        {leadMagnets.map((item) => (
          <a class="feature-card" href={item.href}>
            <p class="card-kicker">{item.audience}</p>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="markets">
    <div class="shell">
      <SectionIntro
        eyebrow="Markets"
        title="Built for categories where trust and clarity matter."
        body="The system adapts to the buyer, proof required, channel economics, and team capacity."
      />
      <div class="grid-4">
        {industries.map((industry) => (
          <a class="industry-card" href={`/industries/${industry.id}`}>
            <p class="card-kicker">Market</p>
            <h3>{industry.data.title}</h3>
            <p>{industry.data.description}</p>
            <span class="card-link">Explore market</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <SectionIntro
        eyebrow="More proof"
        title="Practical work across SaaS, fintech, healthtech, and education."
      />
      <div class="grid-3">
        {cases.slice(1, 4).map((item) => (
          <CaseCard
            href={`/case-studies/${item.id}`}
            title={item.data.title}
            sector={item.data.sector}
            summary={item.data.summary}
            results={item.data.results}
          />
        ))}
      </div>
      <div class="mt-8 grid-3">
        {proofStandards.map((item) => (
          <article class="feature-card compact-card">
            <p>{item}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band" id="cta">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Next step</p>
        <h2>Find the right growth path.</h2>
        <p>Bring the current growth bottleneck. We will identify whether the constraint is diagnosis, sprint, acquisition system, or fractional leadership.</p>
      </div>
      <div class="hero-actions">
        <a class="button button-brand" href={siteConfig.bookingUrl} data-cta="final-book">{siteConfig.bookingLabel}</a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="final-scorecard">{siteConfig.scorecardLabel}</a>
      </div>
    </div>
  </section>
</BaseLayout>
