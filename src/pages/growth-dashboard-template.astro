---
import CfEmailOff from "../components/CfEmailOff.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema } from "../lib/schema";
import { siteConfig } from "../site";

const path = "/growth-dashboard-template";
const title = "Growth Dashboard Template";
const schema = [
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Resources", path: "/resources" },
    { name: title, path }
  ])
];

function requestMailto() {
  const subject = `Send me the ${title}`;
  const body = `Please send the ${title}.\n\nFound on: ${siteConfig.siteUrl}${path}`;
  return `mailto:${siteConfig.email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
}
---

<BaseLayout
  path={path}
  title="Growth Dashboard Template | We Scale Startups"
  description="Weekly growth dashboard template: pipeline, channel activity, and scale/stop/fix decisions — request by email."
  schema={schema}
  breadcrumbItems={[
    { name: "Home", path: "/" },
    { name: "Resources", path: "/resources" },
    { name: title, path }
  ]}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Template</p>
      <h1>{title}</h1>
      <p class="lede">
        A weekly view that ties pipeline to channel activity and decisions — designed so leadership sees what to scale, stop, or fix without vanity metrics.
      </p>
      <div class="hero-actions">
        <CfEmailOff>
          <a class="button button-brand" href={requestMailto()} data-cta="growth-dashboard-request">
            Request the template →
          </a>
        </CfEmailOff>
        <a class="button button-light" href={siteConfig.bookingUrl}>{siteConfig.bookingLabel} →</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="grid-3">
        <article class="feature-card">
          <h2>Inside the template</h2>
          <p>One weekly tab: pipeline value and stage movement, channel-by-channel activity and cost, and a scale / stop / fix decision column so every line ends in an action, not a chart.</p>
        </article>
        <article class="feature-card">
          <h2>Who it's for</h2>
          <p>Post-PMF founders and first marketing hires who report weekly to leadership or a board and need paid, organic, and outbound in one view instead of three dashboards.</p>
        </article>
        <article class="feature-card">
          <h2>How to use it</h2>
          <p>Fill it every Monday in under 30 minutes. The decision column forces the only question that matters each week: what gets more budget, what stops, and what needs fixing first.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Next step</p>
        <h2>Want the dashboard installed, not just the template?</h2>
        <p>The Acquisition System Build includes the reporting cadence wired into your stack.</p>
      </div>
      <div class="hero-actions">
        <a class="button button-brand" href={siteConfig.bookingUrl} data-cta="dashboard-final-book">{siteConfig.bookingLabel} →</a>
      </div>
    </div>
  </section>

</BaseLayout>
