---
import { getCollection } from "astro:content";
import EmailSignup from "../components/EmailSignup.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionIntro from "../components/SectionIntro.astro";
import { buildBreadcrumbSchema } from "../lib/schema";
import { formatDate, sortByOrder } from "../lib/utils";
import { siteConfig } from "../site";

const insights = sortByOrder(await getCollection("insights"));
---

<BaseLayout
  path="/insights"
  title="Growth notes for founders between traction and scale | We Scale Startups"
  description="Original WSS insights on growth diagnosis, acquisition systems, AI visibility, and reducing founder dependency."
  keywords="fractional CMO, B2B SaaS growth, growth diagnosis, acquisition system, GTM strategy, startup marketing, founder-led growth, pipeline bottleneck, We Scale Startups"
  schema={buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Insights", path: "/insights" }
  ])}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Insights</p>
      <h1>Growth notes for founders between traction and scale.</h1>
      <p class="lede">
        Practical writing on diagnosing bottlenecks, building acquisition systems, and making expertise easier for buyers and AI search systems to trust.
      </p>
      <div class="hero-actions">
        <a
          class="button button-dark button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="insights-hero-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="insights-hero-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
        <a class="button button-light" href="/fractional-cmo-vs-agency" data-cta="insights-hero-vs-agency">WSS vs agency</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionIntro
        eyebrow="Published notes"
        title="Start with the bottleneck, then choose the work."
        body="Each article is written to answer a real founder question, not to fill a blog archive."
      />
      <div class="grid-3">
        {insights.map((item) => (
          <article class="feature-card insight-card">
            <p class="card-kicker">{formatDate(item.data.publishedAt)}</p>
            <h2>{item.data.title}</h2>
            <p>{item.data.excerpt}</p>
            <div class="insight-tags">
              {item.data.tags.map((tag) => <span>{tag}</span>)}
            </div>
            <a class="card-link" href={`/insights/${item.id}`}>Read the note →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="shell">
      <EmailSignup
        heading="Get the weekly growth note."
        subtext="One insight a week. What founders at your stage are actually doing to break through plateaus."
        formId="insights-footer"
      />
    </div>
  </section>

  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Apply this to your company</p>
        <h2>Diagnose the constraint before adding more activity.</h2>
        <p>
          Bring the current site, pipeline, campaigns, reporting, and team context. In {siteConfig.bookingCallDurationPhrase} we can usually decide which part of the system needs work first.
        </p>
      </div>
      <div class="hero-actions">
        <a
          class="button button-brand button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="insights-final-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="insights-final-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
