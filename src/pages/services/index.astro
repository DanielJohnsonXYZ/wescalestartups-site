---
import { getCollection } from "astro:content";
import SectionIntro from "../../components/SectionIntro.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sortByOrder } from "../../lib/utils";
import { siteConfig } from "../../site";

const services = sortByOrder(await getCollection("services"));
const phases = services.filter((s) => s.data.order <= 3);
const delivery = services.filter((s) => s.data.order === 4);
---

<BaseLayout title="Services | We Scale Startups" description="Three phases — Research, Acquisition, Operating Cadence — delivered as a Fractional CMO engagement. Pricing £5k–£15k/mo." path="/services">
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Services</p>
      <h1>Three phases. One delivery model.</h1>
      <p>Research, Acquisition, and Operating Cadence are sequenced phases that compound. Fractional CMO is the delivery model that runs them as one system.</p>
      <p class="price-signal"><strong>Pricing:</strong> {siteConfig.priceBand}. {siteConfig.priceBandNote}</p>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionIntro eyebrow="The phases" title="Sequenced, not parallel." body="Research settles the message. Acquisition turns it into pipeline. Operating Cadence makes both repeatable." />
      <div class="grid-3">
        {phases.map((service) => (
          <a class="service-card" href={`/services/${service.id}`}>
            <p class="card-kicker">Phase {service.data.order}</p>
            <h3>{service.data.title}</h3>
            <p>{service.data.promise}</p>
            <span class="card-link">{service.data.cta}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <SectionIntro eyebrow="The delivery model" title="Fractional CMO runs all three." body="A senior operator in the room — accountable for sequencing, decisions, and execution quality — until you're ready for a full-time hire." />
      <div class="grid-1">
        {delivery.map((service) => (
          <a class="service-card service-card-delivery" href={`/services/${service.id}`}>
            <p class="card-kicker">Delivery model</p>
            <h3>{service.data.title}</h3>
            <p>{service.data.promise}</p>
            <span class="card-link">{service.data.cta}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionIntro
        eyebrow="How it works"
        title="Diagnose, build, transfer."
        body="The work should leave the company more capable: clearer decisions, cleaner experiments, stronger proof, and less dependency on anyone guessing in a meeting."
      />
      <div class="grid-3">
        <article class="feature-card">
          <h3>Diagnose</h3>
          <p>Find the constraint actually slowing growth. Usually positioning, sequencing, or weak evidence — not channel volume.</p>
        </article>
        <article class="feature-card">
          <h3>Build</h3>
          <p>Turn the strategy into pages, campaigns, research, measurement, and a weekly operating cadence.</p>
        </article>
        <article class="feature-card">
          <h3>Transfer</h3>
          <p>Document the system so the founder, first marketer, or new CMO can keep running it.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Start here</p>
        <h2>Not sure which phase fits?</h2>
        <p>Bring the current growth bottleneck. A 30-minute call identifies whether the constraint is Research, Acquisition, or Operating Cadence — and whether Fractional CMO is the right shape.</p>
      </div>
      <a class="button button-brand" href={siteConfig.bookingUrl} rel="noreferrer" target="_blank">{siteConfig.bookingLabel}</a>
    </div>
  </section>
</BaseLayout>
