---
import { founderStory, siteConfig } from "../site";
---

<section class="section daniel-story-section" aria-label="Why Daniel built We Scale Startups">
  <div class="shell daniel-grid">
    <div class="daniel-visuals">
      <div class="daniel-photo">
        <picture>
          <source
            srcset="/images/daniel-headshot-640.webp 640w, /images/daniel-headshot-960.webp 960w"
            sizes="(max-width: 640px) 100vw, 38vw"
            type="image/webp"
          />
          <img
            src="/images/daniel-headshot-640.webp"
            alt="Daniel Johnson, founder of We Scale Startups — headshot"
            width="640"
            height="668"
            loading="lazy"
            decoding="async"
          />
        </picture>
      </div>
      <div class="daniel-photo daniel-photo--contextual">
        <picture>
          <source
            srcset="/images/daniel-aircraft-640.webp 640w, /images/daniel-aircraft-960.webp 960w"
            sizes="(max-width: 640px) 100vw, 38vw"
            type="image/webp"
          />
          <img
            src="/images/daniel-aircraft-640.webp"
            alt="Daniel Johnson — informal photo for founder context"
            width="640"
            height="640"
            loading="lazy"
            decoding="async"
          />
        </picture>
      </div>
      <p class="daniel-visuals-caption">Formal headshot and an in-context frame — same operator, less “stock consultant” repetition.</p>
    </div>
    <div class="daniel-copy">
      <p class="eyebrow">Why I built WSS</p>
      <h2>"Founders kept getting stuck running marketing themselves."</h2>
      <p class="lead-copy hero-firstperson-aside">
        I'm Daniel Johnson — fractional CMO and founder of We Scale Startups. For speaking, writing, and media context, see{" "}
        <a href={siteConfig.danielSite} rel="me">{siteConfig.danielSite.replace(/^https:\/\//, "")}</a>.
      </p>
      <p class="lead-copy">{founderStory.intro}</p>
      <p class="lead-copy">{founderStory.why}</p>
      <ul class="daniel-credentials">
        {founderStory.credentials.map((cred) => (
          <li>{cred}</li>
        ))}
      </ul>
      <div class="hero-actions">
        <a class="button button-light" href={siteConfig.founderLinkedin} rel="me noopener" target="_blank">Daniel on LinkedIn →</a>
        <a class="button button-brand" href={siteConfig.bookingUrl} data-cta="daniel-story-book">{siteConfig.bookingLabel}</a>
      </div>
    </div>
  </div>
</section>
