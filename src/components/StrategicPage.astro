---
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema, buildFaqSchema } from "../lib/schema";
import { siteConfig, strategicPageRelatedInsights } from "../site";

interface Props {
  path: string;
  eyebrow: string;
  title: string;
  /** Shorter `<title>` / social title when the H1 is long for SERP previews. */
  metaTitle?: string;
  description: string;
  lede: string;
  sections: Array<{
    title: string;
    body: string;
    points: string[];
  }>;
  faqs: Array<{
    question: string;
    answer: string;
  }>;
  /** Optional override; defaults to `strategicPageRelatedInsights[path]`. */
  relatedInsights?: Array<{ href: string; label: string }>;
}

const { path, eyebrow, title, metaTitle, description, lede, sections, faqs, relatedInsights: relatedInsightsProp } = Astro.props;
const relatedInsights = relatedInsightsProp ?? [...(strategicPageRelatedInsights[path] ?? [])];
const schema = [
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: title, path }
  ]),
  buildFaqSchema(faqs)
];
---

<BaseLayout
  title={metaTitle ?? `${title} | We Scale Startups`}
  description={description}
  path={path}
  schema={schema}
  breadcrumbItems={[
    { name: "Home", path: "/" },
    { name: title, path }
  ]}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="lede">{lede}</p>
      <div class="hero-actions">
        <a
          class="button button-dark button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="strategic-hero-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="strategic-hero-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
        <a class="button button-light" href="/services" data-cta="strategic-hero-services">Compare services</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell strategic-grid">
      {sections.map((section, idx) => (
        <article class:list={["strategic-panel", { "strategic-panel-dark": idx === 1 }]}>
          <span>{String(idx + 1).padStart(2, "0")}</span>
          <h2>{section.title}</h2>
          <p>{section.body}</p>
          <ul>
            {section.points.map((point) => <li>{point}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <div class="section-intro">
        <div>
          <p class="eyebrow">Questions</p>
          <h2>What founders usually ask here.</h2>
        </div>
        <p>Short, visible answers help humans scan the page and help search systems understand what the page is about.</p>
      </div>
      <div class="grid-3">
        {faqs.map((faq) => (
          <article class="feature-card">
            <h3>{faq.question}</h3>
            <p>{faq.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {
    relatedInsights.length > 0 && (
      <section class="section">
        <div class="shell">
          <p class="eyebrow">Related reading</p>
          <h2>Notes that pair with this page.</h2>
          <ul class="related-insights-list">
            {relatedInsights.map((item) => (
              <li>
                <a class="card-link" href={item.href}>
                  {item.label} →
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Next step</p>
        <h2>Find the acquisition constraint before you add more activity.</h2>
        <p>
          Bring the current site, pipeline, campaigns, reporting, and team context. In {siteConfig.bookingCallDurationPhrase} we can usually tell which part of the system needs work first.
        </p>
      </div>
      <div class="hero-actions">
        <a
          class="button button-brand button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="strategic-final-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="strategic-final-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
