---
import { getCollection } from "astro:content";
import CaseCard from "../components/CaseCard.astro";
import FounderVideo from "../components/FounderVideo.astro";
import LeadMagnetForm from "../components/LeadMagnetForm.astro";
import ObjectionsFAQ from "../components/ObjectionsFAQ.astro";
import PricingGuide from "../components/PricingGuide.astro";
import ProofLogos from "../components/ProofLogos.astro";
import SectionIntro from "../components/SectionIntro.astro";
import TrustStrip from "../components/TrustStrip.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildFAQSchema, buildPersonSchema, buildProfessionalServiceSchema } from "../lib/schema";
import { sortByOrder } from "../lib/utils";
import { headlineMetrics, leadMagnets, objections, painSignals, proofStandards, siteConfig } from "../site";

const services = sortByOrder(await getCollection("services"));
const priorityIndustries = ["b2b-saas", "saas-growth", "ai-genai", "fintech"];
const industries = sortByOrder(await getCollection("industries")).filter((industry) => priorityIndustries.includes(industry.id));
const cases = sortByOrder(await getCollection("cases"));
const featuredCase = cases[0];

const process = [
  ["Diagnose", "/services/growth-diagnosis", "Find the real constraint across ICP, positioning, funnel, channels, reporting, and team cadence."],
  ["Build", "/services/acquisition-system-build", "Turn the decision into pages, campaigns, workflows, dashboards, and a weekly rhythm."],
  ["Test", "/services/90-day-growth-sprint", "Run focused experiments with clear hypotheses, owners, and decision rules."],
  ["Transfer", "/transfer", "Document the system so the founder, team, and vendors can keep running it."]
] as const;

function metricLead(result: string) {
  return result.match(/(?:[$£])?\d+(?:\.\d+)?%?\+?/)?.[0] ?? result.split(" ")[0];
}

const faqSchema = buildFAQSchema(objections.map((o) => ({ question: o.question, answer: o.answer })));
const personSchema = buildPersonSchema();
const serviceSchema = buildProfessionalServiceSchema();
---

<BaseLayout
  path="/"
  title="Fractional CMO for B2B SaaS & AI Startups | We Scale Startups"
  description="Fractional CMO and growth systems for post-PMF B2B SaaS and AI startups (£1M–£10M ARR). Build predictable pipeline before you hire a £150k full-time CMO."
  schema={[faqSchema, personSchema, serviceSchema]}
>
  <section class="hero hero-with-portrait">
    <div class="shell hero-grid">
      <div>
        <div class="hero-meta">
          <span>Fractional CMO · Growth audits · Acquisition systems</span>
          <span>B2B SaaS &amp; AI · £1M–£10M ARR</span>
        </div>

        <h1>Build predictable pipeline <em>before</em> you hire a £150k CMO.</h1>

        <p class="hero-copy">
          Fractional CMO and growth systems for post-PMF B2B SaaS and AI founders.
          We fix messy growth and build the repeatable revenue engine your team can actually run — without the full-time hire.
        </p>

        <div class="hero-actions">
          <a class="button button-brand" href={siteConfig.bookingUrl} data-cta="hero-book">{siteConfig.bookingLabel}</a>
          <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="hero-scorecard">{siteConfig.scorecardLabel}</a>
        </div>

        <div class="hero-proof">
          {headlineMetrics.map((metric) => (
            <div>
              <strong>{metric.value}</strong>
              <span>{metric.label}</span>
            </div>
          ))}
        </div>
      </div>

      <aside class="hero-portrait-card" aria-label="Founder-led growth support">
        <div class="founder-image">
          <picture>
            <source
              srcset="/images/daniel-headshot-640.webp 640w, /images/daniel-headshot-960.webp 960w"
              sizes="(max-width: 640px) 100vw, 38vw"
              type="image/webp"
            />
            <img src="/images/daniel-headshot-960.webp" alt="Daniel Johnson, founder of We Scale Startups — fractional CMO for B2B SaaS and AI startups" width="960" height="1003" loading="eager" decoding="async" fetchpriority="high" />
          </picture>
        </div>
        <div class="hero-offer">
          <p class="eyebrow">Led by Daniel Johnson</p>
          <p class="hero-offer-role">Senior operator. Not a junior account team. You work directly with Daniel.</p>
          <ul class="note-list">
            <li>15+ years across paid, SEO, CRO, and GTM</li>
            <li>Google for Startups &amp; Techstars mentor</li>
            <li>£10M+ in paid media managed</li>
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <TrustStrip />

  <ProofLogos />

  <section class="section" id="pain">
    <div class="shell two-column">
      <div>
        <p class="eyebrow">The pain</p>
        <h2>Growth gets messy after product–market fit.</h2>
        <p class="lead-copy">
          Once there's traction, the problem isn't effort. It's that pipeline still depends on founder energy,
          scattered channel activity, and reporting that doesn't actually explain what's working.
        </p>
      </div>
      <div class="grid grid-2">
        {painSignals.map((item) => (
          <article class="feature-card compact-card">
            <p>{item}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt" id="services">
    <div class="shell">
      <SectionIntro
        eyebrow="Services"
        title="Four ways to fix it."
        body="Start with a Growth Audit if the path is unclear. Move into a sprint, acquisition build, or fractional CMO engagement once the constraint is visible."
      />

      <div class="grid-4">
        {services.map((service) => (
          <a class="service-card service-card-strong" href={`/services/${service.id}`}>
            <p class="card-kicker">{service.data.shortTitle}</p>
            <h3>{service.data.title}</h3>
            <p><strong>Who for:</strong> {service.data.audience}</p>
            <p><strong>What changes:</strong> {service.data.promise}</p>
            <span class="card-link">{service.data.cta}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <FounderVideo />

  {featuredCase && (
    <section class="section section-alt" id="results">
      <div class="shell">
        <SectionIntro
          eyebrow="Results"
          title="Before, work done, result."
          body="Proof should be easy to scan. Each case shows the commercial problem, the work, and what changed."
        />
        <div class="case-feature">
          <div class="case-visual" aria-hidden="true">
            <span>{featuredCase.data.client}</span>
            <span>{featuredCase.data.results[0]}</span>
            <strong>{featuredCase.data.client.slice(0, 1)}</strong>
          </div>
          <div class="case-copy">
            <p class="eyebrow">{featuredCase.data.sector}</p>
            <h3>{featuredCase.data.title}</h3>
            <div class="proof-steps">
              <div><span>Before</span><p>{featuredCase.data.challenge}</p></div>
              <div><span>Work done</span><p>{featuredCase.data.work.slice(0, 3).join(", ")}.</p></div>
              <div><span>Result</span><p>{featuredCase.data.results.slice(0, 2).join("; ")}.</p></div>
            </div>
            <div class="case-metrics">
              {featuredCase.data.results.slice(0, 3).map((result) => (
                <div>
                  <span class="stat-number">{metricLead(result)}</span>
                  <span class="stat-label">{result}</span>
                </div>
              ))}
            </div>
            <div class="hero-actions">
              <a class="button button-brand" href={`/case-studies/${featuredCase.id}`}>Read the case</a>
              <a class="button button-light" href="/case-studies">See all results</a>
            </div>
          </div>
        </div>

        <div class="grid-3 mt-8">
          {cases.slice(1, 4).map((item) => (
            <CaseCard
              href={`/case-studies/${item.id}`}
              title={item.data.title}
              sector={item.data.sector}
              summary={item.data.summary}
              results={item.data.results}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <PricingGuide />

  <ObjectionsFAQ />

  <section class="section">
    <div class="shell">
      <SectionIntro
        eyebrow="Process"
        title="Diagnose. Build. Test. Transfer."
        body="The point is not to create dependency. It is to leave the growth function clearer and easier for your team to run."
      />
      <div class="grid-4">
        {process.map(([title, href, body], index) => (
          <a class="feature-card process-card" href={href}>
            <p class="card-kicker">{String(index + 1).padStart(2, "0")}</p>
            <h3>{title}</h3>
            <p>{body}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <LeadMagnetForm />

  <section class="section section-alt" id="markets">
    <div class="shell">
      <SectionIntro
        eyebrow="Markets"
        title="Built for B2B SaaS and AI — extends into Fintech and HealthTech."
        body="The system adapts to the buyer, proof required, channel economics, and team capacity."
      />
      <div class="grid-4">
        {industries.map((industry) => (
          <a class="industry-card" href={`/industries/${industry.id}`}>
            <p class="card-kicker">Market</p>
            <h3>{industry.data.title}</h3>
            <p>{industry.data.description}</p>
            <span class="card-link">Explore market</span>
          </a>
        ))}
      </div>
      <div class="mt-8 grid-3">
        {proofStandards.map((item) => (
          <article class="feature-card compact-card">
            <p>{item}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band" id="cta">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Next step</p>
        <h2>Diagnose what's actually blocking growth.</h2>
        <p>Bring your current growth bottleneck to a 20-minute call. Leave with a plain-English view of the constraint — and whether we're the right help for it.</p>
      </div>
      <div class="hero-actions">
        <a class="button button-brand" href={siteConfig.bookingUrl} data-cta="final-book">{siteConfig.bookingLabel}</a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="final-scorecard">{siteConfig.scorecardLabel}</a>
      </div>
    </div>
  </section>
</BaseLayout>
