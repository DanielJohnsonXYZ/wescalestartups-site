---
import { getCollection } from "astro:content";
import HomeProofV3 from "../components/HomeProofV3.astro";
import SectionIntro from "../components/SectionIntro.astro";
import TestimonialsBlock from "../components/TestimonialsBlock.astro";
import VsAgencyBlock from "../components/VsAgencyBlock.astro";
import NotForBlock from "../components/NotForBlock.astro";
import DanielStory from "../components/DanielStory.astro";
import WhoThisIsForIcp from "../components/WhoThisIsForIcp.astro";
import ServiceComparisonTable from "../components/ServiceComparisonTable.astro";
import CtaLadder from "../components/CtaLadder.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/home-hero-v3.css";
import { buildFaqSchema } from "../lib/schema";
import { sortByOrder } from "../lib/utils";
import {
  buyerFaqs,
  canonicalProofMetrics,
  first30Days,
  homeHeroProofLine,
  homeRelatedReading,
  proofStandards,
  siteConfig,
  testimonials
} from "../site";

const cases = sortByOrder(await getCollection("cases"));
const featuredCase = cases.find((item) => item.id === "ned") ?? cases[0];
const otherCases = cases.filter((item) => item.id !== featuredCase?.id).slice(0, 4);

const featuredCaseLabel = featuredCase?.data.client ?? "";

const engagementShapes = [
  {
    step: "01",
    label: "Diagnose",
    title: "Bottleneck diagnosis",
    body: "One-week deep-dive. Your binding constraint named in plain English with a fix-or-skip recommendation.",
    meta: "⏱ 1 week · fixed scope",
    href: "/services/growth-diagnosis"
  },
  {
    step: "02",
    label: "Sprint",
    title: "90-day growth sprint",
    body: "Targeted intervention against the named bottleneck. Built, run, measured, transferred.",
    meta: "⏱ 90 days · best for fast signal",
    href: "/services/90-day-growth-sprint"
  },
  {
    step: "03",
    label: "Build",
    title: "Acquisition system build",
    body: "Channel hierarchy, narrative, reporting cadence, hiring spec — installed end-to-end.",
    meta: "⏱ 8–12 weeks · flagship",
    href: "/services/acquisition-system-build"
  },
  {
    step: "04",
    label: "Embed",
    title: "Embedded fractional CMO",
    body: "2–3 days/week leadership when the fit is right. You don't need a £150k hire to get the seat.",
    meta: "⏱ Ongoing · selective",
    href: "/services/fractional-cmo"
  }
];

const homeTestimonials = [
  ...testimonials.filter((t) => t.category === "paid-client"),
  ...testimonials.filter((t) => t.category === "advisory")
].slice(0, 8);

function metricLead(result: string) {
  return result.match(/(?:[$£])?\d+(?:\.\d+)?%?\+?/)?.[0] ?? result.split(" ")[0];
}
---

<BaseLayout
  path="/"
  title={siteConfig.title}
  description={siteConfig.description}
  schema={buildFaqSchema([...buyerFaqs])}
  showSiteHeader={true}
  bodyClass="page-home-v3"
  announcementVariant="brand"
  announcementText={`New resource: ${siteConfig.scorecardName}. ${siteConfig.scorecardTagline}`}
  announcementHref={siteConfig.scorecardUrl}
  announcementLinkText={`${siteConfig.scorecardLabel} →`}
>
  <section class="h3-hero" aria-label="We Scale Startups hero">
    <div class="h3-container">
      <div class="h3-rail">
        <span class="h3-tag">// WSS</span>
        <span>Fractional CMO</span>
        <span class="h3-dotsep"></span>
        <span>Fractional growth leadership</span>
        <span class="h3-dotsep"></span>
        <span>Post-PMF B2B SaaS &amp; AI</span>
      </div>

      <div class="h3-hero-grid">
        <div>
          <h1 class="h3-h1">
            Predictable B2B SaaS pipeline<br />
            <span class="strike">without</span> a <span class="num">£150k</span> CMO hire.
          </h1>

          <p class="h3-hero-proof">
            <a href={homeHeroProofLine.href} data-cta="hero-proof-line">{homeHeroProofLine.text}</a>
          </p>

          <div class="h3-name-line">
            <span class="h3-av" aria-hidden="true">DJ</span>
            <span
              >{siteConfig.founderName} · Fractional CMO · <a href={siteConfig.growthMentor} rel="noopener noreferrer" target="_blank"
                ><span class="h3-star">★</span> 4.93 GrowthMentor</a
              > · 479+ founder sessions</span
            >
          </div>

          <p class="h3-lede">
            I help <strong>post-PMF B2B SaaS and AI founders</strong> name the growth bottleneck, build a coherent acquisition system, and transfer the weekly rhythm — so pipeline compounds <strong>without every decision routing through the founder</strong>.
          </p>

          <div class="h3-shapes" aria-label="Engagement shapes">
            <a class="h3-shape" href="/services/growth-diagnosis" data-cta="hero-shape-diagnose"><span class="n">01</span> Diagnose</a>
            <a class="h3-shape" href="/services/90-day-growth-sprint" data-cta="hero-shape-sprint"><span class="n">02</span> 90-day sprint</a>
            <a class="h3-shape" href="/services/acquisition-system-build" data-cta="hero-shape-build"><span class="n">03</span> System build</a>
            <a class="h3-shape" href="/services/fractional-cmo" data-cta="hero-shape-embed"><span class="n">04</span> Embedded CMO</a>
          </div>

          <div class="h3-cta-row">
            <a class="h3-btn h3-btn-primary" href={siteConfig.bookingUrl} data-cta="hero-book" title={siteConfig.bookingCallReassurance}>
              Book a 30-minute growth diagnostic <span class="arrow" aria-hidden="true">→</span>
            </a>
            <a class="h3-btn h3-btn-ghost" href={siteConfig.scorecardUrl} data-cta="hero-scorecard">
              {siteConfig.scorecardLabel} <span class="arrow" aria-hidden="true">→</span>
            </a>
            <a class="h3-btn h3-btn-link" href="/contact" data-cta="hero-contact">or send a written enquiry</a>
          </div>
          <p class="h3-cta-sub">
            You'll leave the call with your <strong>biggest growth bottleneck named in plain English</strong>. No pitch — just a clear view of what's blocking pipeline.
            {" "}<a class="h3-start-here" href="/start-here" data-cta="hero-start-here">First time here? Start here →</a>
          </p>

          <div class="h3-trust">
            {canonicalProofMetrics.slice(0, 4).map((m) => (
              <span class="h3-chip">
                <span class="num">{m.value}</span> {m.label}
              </span>
            ))}
            <span class="h3-chip h3-chip-note" title={canonicalProofMetrics[0]?.note}>
              <span class="swatch"></span> Techstars · Google · Cambridge Judge
            </span>
          </div>
          <p class="h3-trust-footnote">
            {canonicalProofMetrics[0]?.value} revenue influenced — {canonicalProofMetrics[0]?.note}
          </p>
        </div>

        <aside class="h3-panel" aria-label="Live growth diagnostic sample output">
          <div class="h3-panel-head">
            <div class="h3-panel-title"><span class="live" aria-hidden="true"></span> Growth Diagnostic — Sample Output</div>
            <div class="h3-panel-meta">WK 01 / 12</div>
          </div>

          <div class="h3-kpis">
            <div class="h3-kpi">
              <div class="l">Pipeline today</div>
              <div class="v">£42k <span style="font-size:14px;color:var(--h3-muted)">/ wk</span></div>
              <div class="delta flat">— flat 6 wks</div>
            </div>
            <div class="h3-kpi">
              <div class="l">12-wk projection</div>
              <div class="v">£128k <span style="font-size:14px;color:var(--h3-muted)">/ wk</span></div>
              <div class="delta up">▲ 3.0× compounding</div>
            </div>
            <div class="h3-kpi">
              <div class="l">Bottleneck</div>
              <div class="v" style="color:var(--h3-violet)">Acquisition</div>
              <div class="delta" style="color:var(--h3-violet)">88% confidence</div>
            </div>
          </div>

          <div class="h3-chart-wrap">
            <div class="h3-chart-legend">
              <span class="k dotted">Pipeline (now)</span>
              <span class="k b">Pipeline (system)</span>
            </div>
            <svg class="h3-spark" id="h3-hero-spark" viewBox="0 0 600 160" preserveAspectRatio="none" aria-hidden="true">
              <defs>
                <linearGradient id="h3-g1" x1="0" x2="1" y1="0" y2="0">
                  <stop offset="0%" stop-color="#5e2bff"></stop>
                  <stop offset="50%" stop-color="#9b3dff"></stop>
                  <stop offset="100%" stop-color="#d046ff"></stop>
                </linearGradient>
                <linearGradient id="h3-g1f" x1="0" x2="0" y1="0" y2="1">
                  <stop offset="0%" stop-color="#9b3dff" stop-opacity=".30"></stop>
                  <stop offset="100%" stop-color="#9b3dff" stop-opacity="0"></stop>
                </linearGradient>
              </defs>
              <g stroke="#eee7d4" stroke-width="1">
                <line x1="0" x2="600" y1="40" y2="40"></line>
                <line x1="0" x2="600" y1="80" y2="80"></line>
                <line x1="0" x2="600" y1="120" y2="120"></line>
              </g>
              <path
                class="area"
                d="M0,120 C60,114 120,108 180,98 C240,86 300,70 360,52 C420,36 480,24 540,18 L600,12 L600,160 L0,160 Z"
                fill="url(#h3-g1f)"></path>
              <path
                d="M0,114 C40,110 80,118 120,114 C160,108 200,116 240,112 C280,107 320,116 360,110 C400,105 440,114 480,108 C520,103 560,111 600,107"
                fill="none"
                stroke="#bfb8a4"
                stroke-width="2"
                stroke-dasharray="4 5"></path>
              <path
                class="draw"
                d="M0,120 C60,114 120,108 180,98 C240,86 300,70 360,52 C420,36 480,24 540,18 L600,12"
                fill="none"
                stroke="url(#h3-g1)"
                stroke-width="3.2"
                stroke-linecap="round"></path>
              <g transform="translate(220,86)">
                <line x1="0" y1="0" x2="0" y2="-30" stroke="#ff6a1a" stroke-width="1.5" stroke-dasharray="2 3"></line>
                <circle cx="0" cy="0" r="4" fill="#ff6a1a"></circle>
                <rect x="6" y="-44" width="118" height="22" rx="6" fill="#fff" stroke="#ffd0aa" stroke-width="1"></rect>
                <text x="14" y="-29" font-family="JetBrains Mono, monospace" font-size="10" fill="#7a3a06" font-weight="700" letter-spacing="0.5">ACQUISITION FIX</text>
              </g>
              <g class="endnode">
                <circle cx="600" cy="12" r="12" fill="#d046ff" fill-opacity=".15"></circle>
                <circle cx="600" cy="12" r="5" fill="#d046ff"></circle>
              </g>
            </svg>
          </div>

          <div class="h3-rows">
            <div class="h3-row-item h3-good">
              <span class="ico">01</span>
              <span class="lbl">Positioning <small>ICP clear · category owned</small><span class="h3-meter"><span style="width:78%"></span></span></span>
              <span class="h3-verdict">Healthy</span>
            </div>
            <div class="h3-row-item h3-bad">
              <span class="ico">02</span>
              <span class="lbl">Acquisition <small>Channel concentration risk · single-source</small><span class="h3-meter"><span style="width:88%"></span></span></span>
              <span class="h3-verdict">Bottleneck</span>
            </div>
            <div class="h3-row-item h3-warn">
              <span class="ico">03</span>
              <span class="lbl">Conversion <small>Demo → SQL leak · no playbook</small><span class="h3-meter"><span style="width:54%"></span></span></span>
              <span class="h3-verdict">Watch</span>
            </div>
            <div class="h3-row-item h3-good">
              <span class="ico">04</span>
              <span class="lbl">Reporting <small>Weekly cadence · founder-trusted</small><span class="h3-meter"><span style="width:71%"></span></span></span>
              <span class="h3-verdict">Healthy</span>
            </div>
            <div class="h3-row-item h3-warn">
              <span class="ico">05</span>
              <span class="lbl">Team ownership <small>Founder-dependent on most decisions</small><span class="h3-meter"><span style="width:48%"></span></span></span>
              <span class="h3-verdict">Watch</span>
            </div>
          </div>

          <div class="h3-panel-foot">
            <div class="summary"><strong>Verdict.</strong> Acquisition is the binding constraint — run a 90-day sprint.</div>
            <a class="h3-btn h3-btn-ghost" href={siteConfig.scorecardUrl} data-cta="diag-take-yours" style="padding:9px 12px;font-size:13px"
              >Take yours <span class="arrow" aria-hidden="true">→</span></a
            >
          </div>
        </aside>
      </div>
    </div>
  </section>

  <HomeProofV3 />

  <section class="h3-strip" aria-label="Offer routing">
    <div class="h3-container">
      <div class="h3-head">
        <div>
          <span class="h3-eyebrow">Four offers · one ladder</span>
          <h2>
            Diagnosis finds the bottleneck. Sprint tests the next move. <strong>Acquisition System Build</strong> installs the rhythm. Fractional CMO operates it with your team.
          </h2>
        </div>
        <div class="h3-sub">Pick the smallest commitment that answers your biggest question — then confirm on the call.</div>
      </div>
      <div class="h3-stages">
        {engagementShapes.map((shape) => (
          <a class="h3-stage" href={shape.href} data-cta={`engagement-${shape.label.toLowerCase()}`}>
            <span class="step">{shape.step} · {shape.label}</span>
            <h3>{shape.title}</h3>
            <p>{shape.body}</p>
            <div class="dur">{shape.meta}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const spark = document.getElementById("h3-hero-spark");
      if (!spark) return;
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (reduced) {
        spark.classList.add("is-animated");
        return;
      }
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((en) => {
            if (!en.isIntersecting) return;
            spark.classList.add("is-animated");
            io.disconnect();
          });
        },
        { threshold: 0.2 }
      );
      io.observe(spark);
    })();
  </script>

  <CtaLadder />

  <WhoThisIsForIcp />

  <NotForBlock />

  <!-- BEFORE / AFTER — core problem in concrete terms -->
  <section class="section before-after-section">
    <div class="shell">
      <p class="eyebrow">The core problem</p>
      <h2>Early traction hides weak systems — here's what changes when the rhythm is in.</h2>
      <div class="ba-grid">
        <article class="ba-card">
          <div class="ba-before">
            <span class="ba-label">Before</span>
            <p>Founder approves every campaign — the team executes, but every decision routes through you.</p>
          </div>
          <div class="ba-arrow" aria-hidden="true">→</div>
          <div class="ba-after">
            <span class="ba-label">After</span>
            <p>Team runs a weekly decision cadence. Scale, stop, or fix calls happen without the founder in the room.</p>
          </div>
        </article>
        <article class="ba-card">
          <div class="ba-before">
            <span class="ba-label">Before</span>
            <p>Channels report in isolation — paid, SEO, and outbound each have their own numbers, none connected to pipeline.</p>
          </div>
          <div class="ba-arrow" aria-hidden="true">→</div>
          <div class="ba-after">
            <span class="ba-label">After</span>
            <p>One dashboard. One view. Each week you see exactly what to scale, what to stop, and what to fix.</p>
          </div>
        </article>
        <article class="ba-card">
          <div class="ba-before">
            <span class="ba-label">Before</span>
            <p>Agency owns the channel logic — you get reports, invoices, and reasons why it didn't work.</p>
          </div>
          <div class="ba-arrow" aria-hidden="true">→</div>
          <div class="ba-after">
            <span class="ba-label">After</span>
            <p>Company owns the system. The agency executes inside a brief your team controls — and the IP stays with you.</p>
          </div>
        </article>
      </div>
      <!-- Proof callout — grounds abstract claims with specific evidence -->
      <div class="why-now-proof">
        <p class="wnp-label">These aren't theoretical — here's what it looks like in practice:</p>
        <ul class="wnp-list">
          <li><strong>Founder-led growth replaced:</strong> Healthtech (anonymous) — CEO moved from doing all marketing to weekly review within the first 30 days.</li>
          <li><strong>Channels unified:</strong> FinTech — paid, organic, and outbound connected to one decision view; 8.6% CTR and 500+ sign-ups in two months.</li>
          <li><strong>Team given direction:</strong> EdTech — acquisition focus narrowed from five channels to one ICP and one channel with a clear experiment backlog.</li>
        </ul>
        <a class="wnp-link" href="/case-studies">See all case studies →</a>
      </div>
    </div>
  </section>

  <section class="section section-alt flagship-system-section" aria-labelledby="flagship-heading">
    <div class="shell">
      <SectionIntro
        eyebrow="Flagship offer"
        title="The WSS Acquisition System"
        body="For post-PMF SaaS teams that have tried channels in isolation and now need one repeatable pipeline rhythm — channel hierarchy, offer map, reporting cadence, and a weekly decision format your team (and agencies) can run inside."
      />
      <div class="hero-actions" style="margin-top:1rem">
        <a class="button button-brand" href="/services/acquisition-system-build" data-cta="home-flagship-build">Explore Acquisition System Build →</a>
        <a class="button button-light" href={siteConfig.bookingUrl} data-cta="home-flagship-book">{siteConfig.bookingLabel}</a>
      </div>
    </div>
  </section>

  <ServiceComparisonTable />

  {featuredCase && (
    <section class="section" id="results">
      <div class="shell">
        <SectionIntro
          eyebrow="Case studies"
          title="Real engagements. Same Problem / Action / Result format every time."
          body="Read the row. If it sounds like you, click through."
        />
        <div class="case-feature">
          <div class="case-visual" aria-hidden="true">
            <span>{featuredCaseLabel}</span>
            <span>{featuredCase.data.results[0]}</span>
            <strong>{featuredCaseLabel.slice(0, 1)}</strong>
          </div>
          <div class="case-copy">
            <p class="eyebrow">{featuredCase.data.sector}</p>
            <h3>{featuredCaseLabel}: {featuredCase.data.title.replace(/^.*?:\s*/, '')}</h3>
            <div class="par-grid">
              <div class="par-row par-problem"><span class="par-label">Problem</span><p>{featuredCase.data.challenge}</p></div>
              <div class="par-row par-action"><span class="par-label">What we changed</span><p>{featuredCase.data.work.slice(0, 3).join(". ")}.</p></div>
              <div class="par-row par-result"><span class="par-label">Commercial result</span><p>{featuredCase.data.results.slice(0, 2).join("; ")}.</p></div>
            </div>
            <div class="case-metrics">
              {featuredCase.data.results.slice(0, 3).map((r) => (
                <div><span class="stat-number">{metricLead(r)}</span><span class="stat-label">{r}</span></div>
              ))}
            </div>
            <div class="hero-actions">
              <a class="button button-brand" href={`/case-studies/${featuredCase.id}`}>Read the full case</a>
              <a class="button button-light" href="/proof">All proof</a>
            </div>
          </div>
        </div>

        <div class="grid-3 mt-8">
          {otherCases.map((item) => (
            <article class="case-mini">
              <div class="case-scan-strip" aria-label="Case at a glance">
                <p class="case-scan-meta">
                  <strong>{item.data.client}</strong>
                  <span class="case-scan-sep" aria-hidden="true">·</span>
                  <span>{item.data.sector}</span>
                </p>
                <p class="case-scan-narrative">
                  <span class="case-scan-bit">{item.data.challenge}</span>
                  <span class="case-scan-sep" aria-hidden="true">→</span>
                  <span class="case-scan-bit">{item.data.work[0]}</span>
                  <span class="case-scan-sep" aria-hidden="true">→</span>
                  <span class="case-scan-bit">{item.data.results[0]}</span>
                </p>
              </div>
              <h4>{item.data.title}</h4>
              <dl class="par-mini">
                <dt>Problem</dt><dd>{item.data.challenge}</dd>
                <dt>What we changed</dt><dd>{item.data.work[0]}.</dd>
                <dt>Commercial result</dt><dd>{item.data.results[0]}{item.data.results[1] ? "; " + item.data.results[1] : ""}.</dd>
              </dl>
              <a class="card-link" href={`/case-studies/${item.id}`}>Read the case →</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <VsAgencyBlock />

  <section class="section section-alt" aria-labelledby="first30-home-heading">
    <div class="shell">
      <SectionIntro
        eyebrow="First 30 days"
        title="What happens in month one."
        body="Same sequence on most engagements — emphasis shifts based on whether the constraint is positioning, acquisition, conversion, or reporting."
        titleId="first30-home-heading"
      />
      <div class="timeline home-first30-timeline">
        {first30Days.map((item) => (
          <article class="timeline-row">
            <span class="timeline-week">{item.week}</span>
            <div>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </div>
          </article>
        ))}
      </div>
      <p class="home-first30-more">
        <a class="link-arrow" href="/first-30-days">Full first 30 days detail →</a>
        {" · "}
        <a class="link-arrow" href="/how-it-works">How it works →</a>
      </p>
    </div>
  </section>

  <TestimonialsBlock testimonials={homeTestimonials} />

  <DanielStory />

  <!-- FAQ -->
  <section class="section section-alt">
    <div class="shell">
      <SectionIntro
        eyebrow="FAQ"
        title="Know what to fix before you spend more."
        body="Short answers for teams deciding whether they need more execution, sharper diagnosis, or senior growth ownership."
      />
      <div class="home-faq-stack">
        {buyerFaqs.map((faq, index) => (
          <details class="home-faq-item" open={index === 0}>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- PROOF STANDARDS -->
  <section class="section">
    <div class="shell">
      <SectionIntro eyebrow="How we show proof" title="No miracle claims. No anonymous wins." />
      <div class="grid-3">
        {proofStandards.map((item) => (<article class="feature-card compact-card"><p>{item}</p></article>))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">Explore the site</p>
      <h2>Structured paths for buyers and search.</h2>
      <ul class="related-insights-list">
        {homeRelatedReading.map((item) => (
          <li>
            <a class="card-link" href={item.href}>
              {item.label} →
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="cta-band" id="cta">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Next step</p>
        <h2>Find the bottleneck before you spend more.</h2>
        <p>
          Bring the current growth picture. In {siteConfig.bookingCallDurationPhrase} you'll leave with a plain-English view of what's blocking pipeline — and which of the four engagements actually fits.
        </p>
      </div>
      <div class="hero-actions">
        <a
          class="button button-brand button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="final-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="final-scorecard">
