---
import { getCollection } from "astro:content";
import SectionIntro from "../../components/SectionIntro.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sortByOrder } from "../../lib/utils";

const allowedIndustries = ["saas-growth", "fintech", "healthtech", "edtech"];
const industries = sortByOrder(await getCollection("industries")).filter((industry) => allowedIndustries.includes(industry.id));
---

<BaseLayout
  title="Industries | We Scale Startups"
  description="Growth systems for SaaS, fintech, healthtech, and EdTech teams where trust and clarity matter."
  keywords="SaaS growth consultancy, fintech GTM, healthtech marketing, EdTech acquisition, B2B startup industries"
  path="/industries"
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Industries</p>
      <h1>Four markets where proof, trust, and timing matter.</h1>
      <p>The system adapts to the buyer, proof required, channel economics, and internal team capacity.</p>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionIntro eyebrow="Markets" title="Where the work fits best." />
      <div class="grid-3">
        {industries.map((industry) => (
          <a class="industry-card" href={`/industries/${industry.id}`}>
            <p class="card-kicker">Market</p>
            <h3>{industry.data.title}</h3>
            <p>{industry.data.description}</p>
            <span class="card-link">Explore {industry.data.title}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
