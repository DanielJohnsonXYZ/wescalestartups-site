---
import EasterEgg from "../components/EasterEgg.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import AnnouncementBanner from "../components/AnnouncementBanner.astro";
import { buildOrganizationSchema, buildPersonSchema, buildWebSiteSchema } from "../lib/schema";
import { absoluteUrl, normalizePath } from "../lib/utils";
import { siteConfig } from "../site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  /** Optional extra discoverability meta for hub pages (insights, resources, etc.). */
  keywords?: string;
  path?: string;
  ogImage?: string;
  /** Alt text for social preview images (defaults to title). */
  ogImageAlt?: string;
  /** Open Graph type; use `article` for long-form insights. */
  ogType?: "website" | "article";
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  lastUpdated?: string | false;
  /** Override default robots meta (e.g. noindex for utility pages). */
  metaRobots?: string;
  /** Visible breadcrumb trail (mirrors JSON-LD when provided). Last item is current page. */
  breadcrumbItems?: Array<{ name: string; path: string }>;
  /** When false, the page supplies its own header (e.g. homepage hero v3). */
  showSiteHeader?: boolean;
  /** Extra classes on `<body>` (space-separated). */
  bodyClass?: string;
  /** Override default sitewide announcement banner. */
  announcementText?: string;
  announcementHref?: string;
  announcementLinkText?: string;
  announcementDismissible?: boolean;
  announcementVariant?: "default" | "brand" | "muted" | "dark-hero";
  announcementPill?: string;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  keywords,
  path = Astro.url.pathname,
  ogImage = siteConfig.ogImage,
  ogImageAlt: ogImageAltProp,
  ogType = "website",
  articlePublishedTime,
  articleModifiedTime,
  schema = [],
  lastUpdated = false,
  metaRobots = "index,follow,max-image-preview:large",
  breadcrumbItems,
  showSiteHeader = true,
  bodyClass = "",
  announcementText = `New resource: ${siteConfig.scorecardName}. ${siteConfig.scorecardTagline}`,
  announcementHref = siteConfig.scorecardUrl,
  announcementLinkText = `${siteConfig.scorecardLabel} →`,
  announcementDismissible = true,
  announcementVariant = "brand",
  announcementPill
} = Astro.props;

const currentPath = normalizePath(path);
const canonical = absoluteUrl(currentPath);
const imageUrl = absoluteUrl(ogImage);
const ogImageAlt = ogImageAltProp ?? title;
const ogImageMime = ogImage.toLowerCase().endsWith(".svg") ? "image/svg+xml" : ogImage.toLowerCase().endsWith(".png") ? "image/png" : ogImage.toLowerCase().match(/\.(jpe?g)$/) ? "image/jpeg" : undefined;
const pageSchemas = Array.isArray(schema) ? schema : [schema];
const allSchemas = [buildPersonSchema(), buildOrganizationSchema(), buildWebSiteSchema(), ...pageSchemas].filter(Boolean);
const serializedSchemas = allSchemas.map((item) => JSON.stringify(item).replace(/</g, "\\u003c"));
// GTM bootstrap — dataLayer initialised immediately so events queue; gtm.js deferred to first interaction or idle (3s cap) to keep it off the critical path.
const gtmScript = `window.dataLayer=window.dataLayer||[];window.dataLayer.push({'gtm.start':new Date().getTime(),event:'gtm.js'});
(function(){var loaded=false;function load(){if(loaded)return;loaded=true;var j=document.createElement('script');j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id=${siteConfig.gtmId}';document.head.appendChild(j);}
['pointerdown','keydown','scroll','touchstart'].forEach(function(e){addEventListener(e,load,{once:true,passive:true});});
if('requestIdleCallback' in window){requestIdleCallback(load,{timeout:3000});}else{setTimeout(load,3000);}})();`;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Analytics: GTM loads gtm.js here; dataLayer events — page_context (page load); cta_click, calendly_click, scorecard_start, pricing_click, resource_click, outbound_link_click (link clicks with label); form_submit; resource_download. Home: home_scorecard_hook_select. Configure GTM Custom Events + Data Layer variables. CMP: use GTM if opt-in regions. -->
    <!-- Google Tag Manager — high in <head> per install instructions (GTM loads before other head assets). -->
    <script is:inline set:html={gtmScript} />
    <!-- End Google Tag Manager -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="robots" content={metaRobots} />
    {siteConfig.bingSiteVerification && (
      <meta name="msvalidate.01" content={siteConfig.bingSiteVerification} />
    )}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {currentPath === "/" && (
      <>
        <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM / agent summary (plain text)" />
        <link rel="alternate" type="text/markdown" href="/llms-full.txt" title="Extended context (markdown)" />
        <link rel="alternate" type="text/markdown" href="/markdown/home.md" title="Homepage as markdown" />
        <link rel="api-catalog" href="/.well-known/api-catalog" />
        <link rel="alternate" type="application/json" href="/.well-known/agent-skills/index.json" title="Agent skills index" />
      </>
    )}

    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    {ogImageMime && <meta property="og:image:type" content={ogImageMime} />}
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    {ogType === "article" && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {ogType === "article" && articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={siteConfig.twitterHandle} />
    <meta name="twitter:creator" content={siteConfig.twitterHandle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    <meta name="ai:summary" content={description} />
    <meta name="ai:role" content="Growth consultancy and fractional CMO support for post-PMF startups" />
    <meta name="ai:serves" content="Post-PMF SaaS, AI, fintech, healthtech, ecommerce, and education startups" />
    <meta name="ai:contact" content={`${siteConfig.siteUrl}${siteConfig.bookingUrl}`} />
    <meta
      name="ai:entity"
      content={`${siteConfig.name}; ${siteConfig.founderName}; Fractional CMO; ${siteConfig.danielSite}; ${siteConfig.podcastUrl}`}
    />
    <meta
      name="ai:credibility"
      content="Cambridge Judge Business School; Google for Startups; Techstars; GrowthMentor"
    />

    <!--email_off-->
    {serializedSchemas.map((json) => <script is:inline type="application/ld+json" set:html={json} />)}
    <!--/email_off-->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: "page_context",
        page_path: window.location.pathname,
        page_title: document.title,
        page_location: window.location.href
      });

      document.addEventListener("click", (event) => {
        const target = event.target;
        const link = target instanceof Element ? target.closest("a") : null;
        if (!link) return;

        if (link.hasAttribute("download")) {
          const href = link.href || "";
          const label = link.dataset.cta || link.textContent?.trim() || "resource_download";
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            event: "resource_download",
            download_url: href,
            download_label: label,
            page_path: window.location.pathname
          });
          return;
        }

        const label = link.dataset.cta || link.textContent?.trim();
        if (!label) return;

        const href = link.href || "";
        const isCalendly = href.includes("calendly.com") || href.includes("cal.wescalestartups.com");
        const isScorecard = href.includes("growth-bottleneck-scorecard");
        const isPricing = href.includes("/pricing") || link.closest("[data-pricing-link]");
        const isResource = href.includes("/resources") || link.closest("[data-resource-link]");
        const isOutbound = href.startsWith("http") && !href.includes(window.location.hostname);

        let eventName = "cta_click";
        if (isCalendly) eventName = "calendly_click";
        else if (isScorecard) eventName = "scorecard_start";
        else if (isPricing) eventName = "pricing_click";
        else if (isResource) eventName = "resource_click";
        else if (isOutbound) eventName = "outbound_link_click";

        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: eventName,
          cta_label: label,
          cta_href: href,
          page_path: window.location.pathname
        });
      });

      document.addEventListener("submit", (event) => {
        const form = event.target;
        if (!(form instanceof HTMLFormElement)) return;
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: "form_submit",
          form_id: form.id || form.name || "unknown",
          form_action: form.action || "unknown",
          page_path: window.location.pathname
        });
      });
    </script>
  </head>
  <body class={bodyClass}>
    <!-- Google Tag Manager (noscript) — immediately after <body> per GTM install instructions. -->
    <noscript>
      <iframe
        height="0"
        src={`https://www.googletagmanager.com/ns.html?id=${siteConfig.gtmId}`}
        style="display:none;visibility:hidden"
        width="0"
      />
    </noscript>
    <!-- End Google Tag Manager (noscript) -->
    <a class="skip-link" href="#main-content">Skip to content</a>
    {showSiteHeader && <SiteHeader currentPath={currentPath} />}
    <AnnouncementBanner
      text={announcementText}
      href={announcementHref}
      linkText={announcementLinkText}
      dismissible={announcementDismissible}
      variant={announcementVariant}
      pill={announcementPill}
    />
    <main id="main-content">
      {
        breadcrumbItems && breadcrumbItems.length > 0 && (
          <div class="breadcrumb-wrap">
            <div class="shell">
              <nav aria-label="Breadcrumb" class="breadcrumb-nav">
                <ol>
                  {breadcrumbItems.map((item, index) => {
                    const isLast = index === breadcrumbItems.length - 1;
                    const href = item.path.startsWith("/") ? normalizePath(item.path) : `/${normalizePath(item.path)}`;
                    return (
                      <li>
                        {isLast ? (
                          <span aria-current="page">{item.name}</span>
                        ) : (
                          <a href={href}>{item.name}</a>
                        )}
                      </li>
                    );
                  })}
                </ol>
              </nav>
            </div>
          </div>
        )
      }
      <slot />
      {lastUpdated && (
        <section class="last-updated-band" aria-label="Page freshness">
          <div class="shell">
            <p>Last updated: {lastUpdated}</p>
          </div>
        </section>
      )}
    </main>
    <SiteFooter />
    <EasterEgg />
  </body>
</html>
