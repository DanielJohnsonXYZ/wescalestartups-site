---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { buildOrganizationSchema, buildWebSiteSchema } from "../lib/schema";
import { absoluteUrl, normalizePath } from "../lib/utils";
import { siteConfig } from "../site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  path?: string;
  ogImage?: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  path = Astro.url.pathname,
  ogImage = siteConfig.ogImage,
  schema = []
} = Astro.props;

const currentPath = normalizePath(path);
const canonical = absoluteUrl(currentPath);
const imageUrl = absoluteUrl(ogImage);
const pageSchemas = Array.isArray(schema) ? schema : [schema];
const allSchemas = [buildOrganizationSchema(), buildWebSiteSchema(), ...pageSchemas].filter(Boolean);
const serializedSchemas = allSchemas.map((item) => JSON.stringify(item).replace(/</g, "\\u003c"));
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={siteConfig.twitterHandle} />
    <meta name="twitter:creator" content={siteConfig.twitterHandle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    {serializedSchemas.map((json) => <script is:inline type="application/ld+json" set:html={json} />)}
    <script is:inline>
      document.addEventListener("click", (event) => {
        const target = event.target;
        const link = target instanceof Element ? target.closest("a") : null;
        if (!link) return;

        const label = link.dataset.cta || link.textContent?.trim();
        if (!label) return;

        const href = link.href || "";
        const isCalendly = href.includes("calendly.com");
        const isScorecard = href.includes("growth-bottleneck-scorecard");
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: isCalendly ? "calendly_click" : isScorecard ? "scorecard_start" : "cta_click",
          cta_label: label,
          cta_href: href,
          page_path: window.location.pathname
        });
      });

      document.addEventListener("submit", (event) => {
        const form = event.target;
        if (!(form instanceof HTMLFormElement)) return;
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: "form_submit",
          form_id: form.id || form.name || "unknown",
          page_path: window.location.pathname
        });
      });
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <SiteHeader currentPath={currentPath} />
    <main id="main-content">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
