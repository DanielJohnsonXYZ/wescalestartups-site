---
// SiteFooter.astro — restructured into 5 clean groups:
// Work with us · Proof · Resources · Company · Legal
import EmailSignup from "./EmailSignup.astro";
import { siteConfig } from "../site";

const groups = [
  {
    label: "Work with us",
    links: [
      { href: "/services/growth-diagnosis", label: "Growth Diagnosis" },
      { href: "/services/90-day-growth-sprint", label: "90-Day Growth Sprint" },
      { href: "/services/acquisition-system-build", label: "Acquisition System Build" },
      { href: "/services/fractional-cmo", label: "Fractional CMO" },
      { href: "/pricing", label: "Pricing" },
      { href: "/contact", label: "Contact" }
    ]
  },
  {
    label: "Proof",
    links: [
      { href: "/proof", label: "All proof" },
      { href: "/case-studies", label: "Case studies" },
      { href: "/testimonials", label: "Testimonials" },
      { href: "/industries", label: "Industries we serve" },
      { href: "/fractional-cmo-vs-agency", label: "WSS vs agency" }
    ]
  },
  {
    label: "Resources",
    links: [
      { href: "/start-here", label: "Start here" },
      { href: siteConfig.scorecardUrl, label: siteConfig.scorecardName },
      { href: "/resources", label: "All resources & templates" },
      { href: "/growth-operating-system", label: "Growth Operating System" },
      { href: "/insights", label: "Insights" },
      { href: "/gtm-strategy", label: "GTM Strategy Guide" },
      { href: "/podcast", label: "Podcast" }
    ]
  },
  {
    label: "Company",
    links: [
      { href: "/about", label: "About WSS" },
      { href: "/team", label: "Team" },
      { href: "/about/daniel", label: "About Daniel" },
      { href: "/press", label: "Speaking & press" },
      { href: "/workshops", label: "Workshops" },
      { href: "/contact", label: "Contact" },
      { href: siteConfig.linkedin, label: "LinkedIn", external: true }
    ]
  },
  {
    label: "Legal",
    links: [
      { href: "/privacy", label: "Privacy" },
      { href: "/terms", label: "Terms" }
    ]
  }
];
---

<footer class="site-footer site-footer-v2">
  <div class="shell footer-grid">
    <div class="footer-brand">
      <img class="footer-logo" src="/images/logos/wss-logo.webp" alt="We Scale Startups" width="128" height="72" loading="lazy" decoding="async" />
      <p class="footer-summary">
        We help founder-led startups turn scattered marketing activity into a weekly growth system — diagnose the bottleneck, build the system, transfer it.
      </p>
      <p class="footer-brand-arch">
        <strong>Brand note:</strong> This is the We Scale Startups commercial site (services, proof, systems). Daniel&apos;s personal brand — speaking, writing, media — lives at{" "}
        <a href={siteConfig.danielSite} rel="noopener" target="_blank">danieljohnson.xyz</a>.
      </p>
      <a
        class="button button-brand"
        href="/contact"
        data-cta="footer-contact"
        title="Contact We Scale Startups"
      >
        Contact →
      </a>
      <p class="footer-book-reassurance">Send the growth context, stage, bottleneck, budget, and timeline. We will reply with the clearest next step.</p>
      <p class="footer-secondary-cta">
        Or, <a href={siteConfig.scorecardUrl}>{siteConfig.scorecardLabel} →</a>
      </p>
      <div class="footer-newsletter" aria-label="Newsletter signup">
        <EmailSignup
          variant="light"
          formId="footer-newsletter"
          heading={siteConfig.newsletterName}
          subtext={`${siteConfig.newsletterDescription} ${siteConfig.newsletterFrequencyLine}`}
        />
      </div>
    </div>

    {groups.map((group) => (
      <div class="footer-col">
        <h2>{group.label}</h2>
        <nav class="footer-links" aria-label={`${group.label} links`}>
          {group.links.map((link) => (
            <a
              href={link.href}
              {...(link.external ? { target: "_blank", rel: "noopener" } : {})}
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    ))}
  </div>

  <div class="shell footer-bottom">
    <p>© 2026 We Scale Startups. All rights reserved.</p>
    <p>{siteConfig.address}</p>
    <p class="founder-line">
      Founded by <a href="/about#daniel">{siteConfig.founderName}</a> ·
      <a href={siteConfig.danielSite} rel="noopener" target="_blank">danieljohnson.xyz</a>
    </p>
  </div>
</footer>

<style>
  .site-footer-v2 { padding-top: 4rem; padding-bottom: 2rem; }
  .site-footer-v2 .footer-grid {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1fr;
    margin-bottom: 3rem;
  }
  @media (min-width: 720px) {
    .site-footer-v2 .footer-grid {
      grid-template-columns: 1.4fr repeat(2, 1fr);
    }
  }
  @media (min-width: 1080px) {
    .site-footer-v2 .footer-grid {
      grid-template-columns: 1.6fr repeat(5, 1fr);
    }
  }

  .footer-brand p.footer-summary {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 1rem 0 1.25rem;
    max-width: 32ch;
  }
  .footer-brand-arch {
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 1.55;
    margin: -0.5rem 0 1.25rem;
    max-width: 40ch;
  }
  .footer-brand-arch a {
    color: var(--ink);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .footer-book-reassurance {
    margin: 0.65rem 0 0;
    max-width: 42ch;
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--muted);
  }
  .footer-secondary-cta {
    margin-top: 0.85rem;
    font-size: 0.82rem;
    color: var(--muted);
  }
  .footer-secondary-cta a {
    color: var(--ink);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer-newsletter {
    margin-top: 1.25rem;
    max-width: 36rem;
    min-width: 0;
  }
  .footer-newsletter :global(.email-signup-strip) {
    margin: 0;
    padding: 1.1rem 1.15rem;
  }
  .footer-newsletter :global(.email-signup-heading) {
    font-size: 1rem;
  }
  .footer-newsletter :global(.email-signup-sub) {
    font-size: 0.82rem;
  }
  .footer-newsletter :global(.email-signup-form) {
    flex-direction: column;
  }
  .footer-newsletter :global(.email-signup-form input[type="email"]),
  .footer-newsletter :global(.email-signup-form .button) {
    width: 100%;
  }

  .footer-col h2 {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin: 0 0 0.85rem;
  }
  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .footer-links a {
    color: var(--muted);
    font-size: 0.88rem;
    text-decoration: none;
    transition: color 150ms ease;
  }
  .footer-links a:hover { color: var(--ink); }

  .footer-bottom {
    border-top: 1px solid var(--line);
    padding-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    color: var(--muted);
    font-size: 0.82rem;
  }
  .footer-bottom p { margin: 0; }
  .founder-line { margin-left: auto; }
  .founder-line a {
    color: var(--ink);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid var(--line);
  }
  .founder-line a:hover {
    border-bottom-color: var(--accent);
  }
</style>
