---
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema } from "../lib/schema";
import { siteConfig, staticPathLastModified } from "../site";

const dimensions = [
  {
    dimension: "Positioning clarity",
    description: "Can a stranger say what you sell, who it's for, and why now — in one sentence?",
    scoreLabels: ["Weak", "Improving", "Clear"],
    weight: "High — drives every other channel"
  },
  {
    dimension: "Acquisition system",
    description: "Are paid, SEO, outbound, and content working as one system with shared ICP and offer?",
    scoreLabels: ["Siloed", "Partially linked", "One system"],
    weight: "High — compounds when fixed"
  },
  {
    dimension: "Conversion flow",
    description: "Does the homepage → demo/lead capture convert at 3%+ for your ICP traffic?",
    scoreLabels: ["<1%", "1–3%", "3%+"],
    weight: "Medium — often a quick win"
  },
  {
    dimension: "Reporting & decisions",
    description: "Is there one weekly view that says what to scale, stop, or fix this week?",
    scoreLabels: ["No view", "Activity only", "Decision view"],
    weight: "High — without this, growth stays founder-led"
  },
  {
    dimension: "Team ownership",
    description: "Can the team run the growth rhythm without founder input for 2+ weeks?",
    scoreLabels: ["Founder only", "Mixed", "Team-owned"],
    weight: "High — the exit condition for fractional work"
  },
  {
    dimension: "Offer & pricing",
    description: "Is the offer sharp for one ICP segment, with pricing that signals confidence?",
    scoreLabels: ["Blurry", "Clear but broad", "Sharp & segmented"],
    weight: "Medium — positioning flows from this"
  },
  {
    dimension: "Experiment cadence",
    description: "Are 2–4 growth experiments live at any time, with owners and decision rules?",
    scoreLabels: ["None", "Ad-hoc", "2–4 active"],
    weight: "Medium — speed of learning"
  },
  {
    dimension: "Founder time",
    description: "How many growth hours per week does the founder spend, and is it the right 5 hours?",
    scoreLabels: [">15 hrs", "8–15 hrs", "<8 hrs"],
    weight: "High — founder bottleneck score"
  }
];

const schema = [
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "WSS Scale Score", path: "/wss-scale-score" }
  ])
];
---

<BaseLayout
  title="WSS Scale Score | We Scale Startups"
  description="Score your startup across 8 growth dimensions: positioning, acquisition, conversion, reporting, team ownership, offer, experimentation, and founder time."
  keywords="growth scorecard, startup growth assessment, fractional CMO audit, post-PMF growth checklist, acquisition system score"
  path="/wss-scale-score"
  schema={schema}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">WSS Scale Score</p>
      <h1>How ready is your growth system?</h1>
      <p class="lede">
        Score your startup across 8 dimensions in 5 minutes.
        At the end you'll see which constraint will block scale first — and what to fix.
      </p>
      <div class="hero-actions">
        <a class="button button-brand" href={siteConfig.bookingUrl} data-cta="scale-score-book">
          {siteConfig.bookingLabel}
          <span class="arr" aria-hidden="true">→</span>
        </a>
        <a class="button button-light" href="/resources#growth-bottleneck-scorecard" data-cta="scale-score-resource">
          Or use the simpler scorecard →
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">The 8 dimensions</p>
      <h2 style="font-family:'Fraunces Variable',Georgia,serif;font-size:clamp(2.2rem,3.6vw,3rem);line-height:1.05;font-weight:380;margin:0.4rem 0 2rem;">
        What we measure, and why it predicts scale.
      </h2>
      <div class="grid-2" style="gap:1.5rem;">
        {dimensions.map((dim, i) => (
          <article class="feature-card" style="padding:1.5rem 1.5rem 1.8rem;">
            <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:0.75rem;">
              <h3 style="font-size:1.1rem;font-weight:700;letter-spacing:-0.02em;margin:0;">0{i + 1}. {dim.dimension}</h3>
              <span style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);">{dim.weight}</span>
            </div>
            <p style="font-size:0.92rem;color:var(--muted);line-height:1.6;margin:0 0 0.75rem;">{dim.description}</p>
            <div style="display:flex;gap:0.5rem;font-size:0.78rem;">
              {dim.scoreLabels.map((label, j) => (
                <span style={`padding:0.25rem 0.6rem;border-radius:0.4rem;border:1px solid var(--line);color:var(--muted);background:${j === 0 ? "var(--surface)" : j === 1 ? "var(--surface)" : "var(--accent)/10"}`}>
                  {label}
                </span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">How to use this</p>
      <h2 style="font-family:'Fraunces Variable',Georgia,serif;font-size:clamp(2.2rem,3.6vw,3rem);line-height:1.05;font-weight:380;margin:0.4rem 0 2rem;">
        A diagnostic tool, not a vanity quiz.
      </h2>
      <div class="grid-3">
        <article class="feature-card compact-card">
          <h3>1. Score honestly</h3>
          <p>Get a founder, a growth lead, and one IC in the room. Score each dimension separately, then compare.</p>
        </article>
        <article class="feature-card compact-card">
          <h3>2. Find the low score</h3>
          <p>The dimension with the lowest score is usually the constraint that's blocking repeatable pipeline.</p>
        </article>
        <article class="feature-card compact-card">
          <h3>3. Book a diagnostic</h3>
          <p>Bring the scores to a 30-minute diagnostic. We'll confirm the constraint and recommend the engagement shape.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">What the score predicts</p>
      <h2 style="font-family:'Fraunces Variable',Georgia,serif;font-size:clamp(2.2rem,3.6vw,3rem);line-height:1.05;font-weight:380;margin:0.4rem 0 2rem;">
        Low scores here are why pipeline plateaus.
      </h2>
      <div class="grid-2" style="gap:1.25rem;">
        <div style="padding:1.25rem;border:1px solid var(--line);border-radius:0.85rem;">
          <h3 style="font-size:1rem;font-weight:700;margin:0 0 0.5rem;color:var(--accent);">Positioning + Offer below 2/3</h3>
          <p style="font-size:0.9rem;color:var(--muted);line-height:1.55;margin:0;">Acquisition spend leaks. Channels attract the wrong ICP. CAC climbs while conversion falls.</p>
        </div>
        <div style="padding:1.25rem;border:1px solid var(--line);border-radius:0.85rem;">
          <h3 style="font-size:1rem;font-weight:700;margin:0 0 0.5rem;color:var(--accent);">Acquisition system below 2/3</h3>
          <p style="font-size:0.9rem;color:var(--muted);line-height:1.55;margin:0;">Channels work in isolation but pipeline arrives in waves. No compound effect week over week.</p>
        </div>
        <div style="padding:1.25rem;border:1px solid var(--line);border-radius:0.85rem;">
          <h3 style="font-size:1rem;font-weight:700;margin:0 0 0.5rem;color:var(--accent);">Reporting & Decisions below 2/3</h3>
          <p style="font-size:0.9rem;color:var(--muted);line-height:1.55;margin:0;">Activity gets reported but no one decides what to scale, stop, or fix. Weeks pass without a sharp call.</p>
        </div>
        <div style="padding:1.25rem;border:1px solid var(--line);border-radius:0.85rem;">
          <h3 style="font-size:1rem;font-weight:700;margin:0 0 0.5rem;color:var(--accent);">Team Ownership below 2/3</h3>
          <p style="font-size:0.9rem;color:var(--muted);line-height:1.55;margin:0;">Growth still depends on founder heroics. The system isn't transferable. Fractional work can't finish.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Ready to diagnose?</p>
        <h2>Book a 30-minute growth diagnostic.</h2>
        <p>
          Bring your WSS Scale Score. In {siteConfig.bookingCallDurationPhrase} we'll confirm the constraint and recommend the engagement that fits — or tell you where else to go.
        </p>
      </div>
      <div class="hero-actions">
        <a class="button button-brand button-with-subcopy" href={siteConfig.bookingUrl} data-cta="scale-score-final-book">
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href="/services" data-cta="scale-score-services">
          Compare services →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
