            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Case proof — social proof before FAQs -->
  {details.caseProof && details.caseProof.length > 0 && (
    <section class="section case-proof-section">
      <div class="shell">
        <p class="eyebrow">In their words</p>
        <h2>What founders say after the engagement.</h2>
