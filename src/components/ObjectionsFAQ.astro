---
import { objections } from "../site";
---

<section class="section" id="objections" aria-labelledby="objections-heading">
  <div class="shell">
    <div class="section-intro">
      <p class="eyebrow">Common questions</p>
      <h2 id="objections-heading">Founder questions we hear before every engagement.</h2>
      <p>Straight answers, no spin. If something isn't here, email daniel@wescalestartups.com.</p>
    </div>
    <div class="objections-grid">
      {objections.map((item, index) => (
        <details class="objection-card" open={index === 0}>
          <summary>
            <span class="objection-q">{item.question}</span>
            <span class="objection-chev" aria-hidden="true">+</span>
          </summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
