---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema, buildFaqSchema } from "../../lib/schema";
import { siteConfig, testimonials } from "../../site";

const featuredBookingQuote = testimonials[0];
const calendlyEmbedUrl = siteConfig.calendlyUrl;

const bookServiceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: siteConfig.bookingLabel,
  description: siteConfig.bookingCallReassurance,
  provider: { "@id": `${siteConfig.siteUrl}/#organization` },
  url: `${siteConfig.siteUrl}/book`
};

const bookFaqs = [
  {
    question: "What happens on the diagnostic call?",
    answer: siteConfig.bookingCallReassurance
  },
  {
    question: "How long is the call?",
    answer: `The diagnostic is ${siteConfig.bookingCallDurationPhrase}. It is structured in short phases so you leave with a named bottleneck, not a vague conversation.`
  },
  {
    question: "Do I need to prepare a deck?",
    answer: "No deck required. Bring the current growth picture: funnel, channels, reporting, and what you think is blocking pipeline."
  },
  {
    question: "Is there a pitch at the end?",
    answer: "Only if there is a genuine fit. The default outcome is a clear next step — including telling you not to hire us yet when that is the honest answer."
  }
];

const bookSchema = [
  bookServiceSchema,
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Book", path: "/book" }
  ]),
  buildFaqSchema(bookFaqs)
];
---

<BaseLayout
  title={`${siteConfig.bookingLabel} | We Scale Startups`}
  description={`${siteConfig.bookingLabel} with We Scale Startups. Bring your current bottleneck — we name the constraint in plain English, then pick a Calendly slot.`}
  keywords="book growth call, startup growth diagnostic, Calendly We Scale Startups, 20 minute growth audit"
  path="/book"
  schema={bookSchema}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Book call</p>
      <h1>{siteConfig.bookingLabel}</h1>
      <p class="lede">{siteConfig.bookingSubcopy}</p>
      <div class="hero-actions">
        <a class="button button-brand button-with-subcopy" href="#book-calendly" data-cta="book-hero-calendly" title={siteConfig.bookingCallReassurance}>
          <span class="button-label">Pick a time</span>
          <span class="button-subcopy">Inline calendar below · {siteConfig.bookingCallDurationPhrase}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="book-hero-scorecard">
          Not ready? {siteConfig.scorecardLabel} →
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Free or paid?</p>
      <h2>This call is free. Here is when to pay for more.</h2>
      <div class="free-paid-grid">
        <div class="free-paid-card is-free">
          <p class="fp-price">Free · {siteConfig.bookingCallDurationPhrase}</p>
          <h3>20-minute Growth Audit (this call)</h3>
          <p>For founders who want their bottleneck named fast and an honest read on the next move.</p>
          <ul>
            <li>Bottleneck named in plain English</li>
            <li>Likely cause and next best move</li>
            <li>Whether WSS is the right fit — no pitch</li>
          </ul>
        </div>
        <div class="free-paid-card">
          <p class="fp-price">Paid · from £4k</p>
          <h3>Growth Diagnosis (1 week)</h3>
          <p>When you want the full evidence-backed diagnosis and a sequenced plan, not just a 20-minute read.</p>
          <ul>
            <li>Evidence review across the funnel</li>
            <li>Constraint map + quick-win shortlist</li>
            <li>Sequenced 90-day recommendation</li>
          </ul>
          <p style="margin:.7rem 0 0"><a class="card-link" href="/services/growth-diagnosis">See Growth Diagnosis →</a></p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">What you leave with</p>
      <h2>Four things, in writing, by the end of the call.</h2>
      <ul class="bring-checklist">
        <li><strong>Your named bottleneck</strong> — the one constraint holding pipeline back, in plain English.</li>
        <li><strong>The likely cause</strong> — positioning, acquisition, conversion, reporting, or team ownership.</li>
        <li><strong>Your next best move</strong> — the highest-leverage action to take next, whether or not you work with us.</li>
        <li><strong>An honest fit call</strong> — whether WSS is the right help right now, or who to point you to instead.</li>
      </ul>
      {featuredBookingQuote && (
        <figure class="booking-quote" style="margin-top:1.5rem">
          <blockquote><p>“{featuredBookingQuote.quote}”</p></blockquote>
          <figcaption>— {featuredBookingQuote.name}, {featuredBookingQuote.company}</figcaption>
        </figure>
      )}
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">How the {siteConfig.bookingCallDurationPhrase} run</p>
      <ol class="call-phase-list">
        {siteConfig.bookingCallPhases.map((step) => (
          <li><strong>{step.phase}</strong><span>{step.detail}</span></li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section section-alt" id="book-calendly" aria-labelledby="book-calendly-heading">
    <div class="shell">
      <p class="eyebrow">Pick a time</p>
      <h2 id="book-calendly-heading">Book inline — no extra tabs required.</h2>
      <div class="calendly-inline-widget" data-url={calendlyEmbedUrl} style="min-width: 320px; height: 700px;" />
      <p class="calendly-lede" style="margin-top:1rem;">
        <strong>Calendar not loading?</strong> Some privacy or cookie blockers stop the embed.{" "}
        <a href={siteConfig.calendlyUrl} rel="noreferrer" target="_blank">Open Calendly in a new tab</a>, or{" "}
        <a href="/contact#growth-enquiry">send the context via the enquiry form</a> — stage, bottleneck, and what you want help deciding — and we will reply with times.
      </p>
    </div>
  </section>

  <script is:inline async src="https://assets.calendly.com/assets/external/widget.js"></script>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">FAQ</p>
      <h2>Booking the audit.</h2>
      <div class="grid-2">
        {bookFaqs.map((item) => (
          <article class="feature-card">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
