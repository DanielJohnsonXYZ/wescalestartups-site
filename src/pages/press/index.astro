---
import ProofLogos from "../../components/ProofLogos.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema, buildFaqSchema } from "../../lib/schema";
import { headlineMetrics, pressRelatedReading, siteConfig } from "../../site";

const pressFaqs = [
  {
    question: "Can we use the company boilerplate verbatim?",
    answer:
      "Yes. The boilerplate on this page is written for publication. Attribute to We Scale Startups and link to the primary site when possible. If you need a shorter pull-quote, email and we will trim to length."
  },
  {
    question: "Where should we verify metrics before publication?",
    answer:
      "Use the proof hub and linked case studies, which follow a consistent Problem / Action / Result structure. For commentary on a live decision or client-confidential detail, book a short clarification call — we can usually separate what is on the record."
  },
  {
    question: "Where are media assets and a longer founder bio?",
    answer: `For headshots, podcast and speaking topics, and expert commentary positioning, use ${siteConfig.founderName}'s media kit on danieljohnson.xyz. This page is the company-level press kit for We Scale Startups.`
  },
  {
    question: "Who handles press and fact-checking enquiries?",
    answer:
      "Use the Email We Scale Startups button on this page for company-level questions. For founder-led podcast, stage, and expert requests, use Daniel Johnson's media kit link above."
  }
];

const pressSchema = [
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Press kit", path: "/press" }
  ]),
  buildFaqSchema(pressFaqs)
];

const boilerplateShort =
  "We Scale Startups helps post-PMF B2B SaaS and AI startups diagnose growth constraints and install a repeatable acquisition operating rhythm.";

const boilerplateMedium =
  "We Scale Startups is a founder-led growth consultancy helping post-PMF startups build repeatable growth systems before hiring a full-time CMO. Engagements span growth diagnosis, 90-day sprints, acquisition system builds, and fractional CMO leadership.";

const boilerplateLong = `${boilerplateMedium} Work is delivered through Daniel Johnson and senior operators, with proof-oriented reporting — Problem / Action / Result — and explicit transfer so growth stops depending on founder heroics.`;

const founderBio =
  "Daniel Johnson is a fractional CMO and GTM operator who helps post-PMF AI and B2B SaaS startups build repeatable growth systems. He is the founder of We Scale Startups and mentors founders through Google for Startups, Techstars, and GrowthMentor.";

const whatWeDo =
  "Growth diagnosis, sprint execution, acquisition systems, and fractional CMO leadership — with dashboards, experiment cadence, and leadership rituals designed to transfer ownership.";

const whoWeHelp =
  "Most often Seed–Series B teams with real traction and uneven acquisition — typically founder-led GTM, inconsistent pipeline, or agencies executing tactics without a single decision view.";

const pressAngles = [
  "Why post-PMF teams plateau when acquisition channels run in isolation.",
  "Founder dependency vs weekly operating rhythm — how teams decide what to scale, stop, or fix.",
  "Fractional CMO vs agency: systems ownership vs channel execution.",
  "AI-era visibility and credibility — reporting formats AI assistants can cite."
];

const brandAssets = [
  { label: "Primary logo (webp)", href: "/images/logos/wss-logo.webp" },
  { label: "Open Graph default", href: "/og/default.svg" },
  { label: "Favicon", href: "/favicon.svg" }
];

/** Scannable examples for journalists — names anonymised where required. */
const pressClientWorkRows = [
  {
    company: "B2B fintech",
    type: "Acquisition",
    work: "Paid search and landing-page campaign",
    outcome: "500+ qualified sign-ups (see proof hub)"
  },
  {
    company: "AI / health",
    type: "GTM build",
    work: "Marketing function and acquisition narrative from a thin base",
    outcome: "Foundation for repeatable pipeline"
  },
  {
    company: "HealthTech / mental health",
    type: "Positioning",
    work: "Offer narrative and message-market alignment",
    outcome: "Clearer GTM story for buyers and investors"
  },
  {
    company: "EdTech",
    type: "Acquisition",
    work: "Channel and messaging sequencing",
    outcome: "Sharper message-market fit"
  },
  {
    company: "Financial wellness",
    type: "Trust-led GTM",
    work: "Positioning and acquisition foundations",
    outcome: "Stronger trust narrative in a regulated category"
  }
];
---

<BaseLayout
  title="Company Press Kit | We Scale Startups"
  description="Press kit for We Scale Startups: company boilerplate, founder bio, proof metrics, logos, and media contact. For podcasts and speaking, use Daniel Johnson’s personal media kit on danieljohnson.xyz."
  keywords="We Scale Startups press kit, company boilerplate, startup PR assets, Daniel Johnson media"
  path="/press"
  schema={pressSchema}
>
  <section class="page-hero" aria-labelledby="press-kit-heading">
    <div class="shell">
      <p class="eyebrow">Company press kit</p>
      <h1 id="press-kit-heading">Official press information for We Scale Startups.</h1>
      <p class="press-hero-deck">
        For accurate company descriptions, proof, and media assets. Podcast, speaking, and expert commentary:{" "}
        <a href={`${siteConfig.danielSite}/media-kit/`} rel="noreferrer" target="_blank">{siteConfig.founderName}&rsquo;s media kit</a>.
      </p>
    </div>
  </section>

  <section class="section section-alt" aria-labelledby="press-one-line-heading">
    <div class="shell">
      <p class="eyebrow">At a glance</p>
      <h2 id="press-one-line-heading" class="visually-hidden">One-line description</h2>
      <p class="press-one-liner">{boilerplateShort}</p>
    </div>
  </section>

  <section class="section" aria-labelledby="press-boilerplate-heading">
    <div class="shell">
      <p class="eyebrow">For publication</p>
      <h2 id="press-boilerplate-heading">Company boilerplates</h2>
      <div class="detail-grid" style="margin-top: 1rem;">
        <article class="content-block">
          <h3 class="press-subhead">Short</h3>
          <p>{boilerplateShort}</p>
          <h3 class="press-subhead">Medium</h3>
          <p>{boilerplateMedium}</p>
          <h3 class="press-subhead">Long</h3>
          <p>{boilerplateLong}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell detail-grid">
      <article class="content-block">
        <p class="eyebrow">What we do</p>
        <h2 class="press-at-glance-title">Company-level positioning.</h2>
        <p>{whatWeDo}</p>
      </article>
      <article class="content-block">
        <p class="eyebrow">Who we help</p>
        <h2 class="press-at-glance-title">Typical fit.</h2>
        <p>{whoWeHelp}</p>
      </article>
    </div>
  </section>

  <section class="section" aria-labelledby="press-proof-heading">
    <div class="shell">
      <p class="eyebrow">Credibility</p>
      <h2 id="press-proof-heading">Proof points</h2>
      <article class="content-block" style="margin-top: 1rem; max-width: 62ch;">
        <ul>
          {headlineMetrics.map((metric) => <li><strong>{metric.value}</strong> {metric.label}</li>)}
        </ul>
        <p class="press-verify-note">
          Verify against <a href="/proof">the proof hub</a> and linked case studies before citing metrics.
        </p>
      </article>
    </div>
  </section>

  <ProofLogos />

  <section class="section" aria-labelledby="press-clients-heading">
    <div class="shell">
      <p class="eyebrow">Selected client work</p>
      <h2 id="press-clients-heading">Examples journalists can scan quickly.</h2>
      <p class="lede" style="max-width: 62ch; margin-top: 0.75rem;">
        Some names are anonymised where confidentiality applies. Verify numbers against{" "}
        <a href="/proof">the proof hub</a> and linked case studies before publication.
      </p>
      <div class="press-table-wrap" style="margin-top: 1.25rem; overflow-x: auto;">
        <table class="press-client-table">
          <thead>
            <tr>
              <th scope="col">Company / category</th>
              <th scope="col">Type of work</th>
              <th scope="col">Summary</th>
              <th scope="col">Outcome signal</th>
            </tr>
          </thead>
          <tbody>
            {pressClientWorkRows.map((row) => (
              <tr>
                <td>{row.company}</td>
                <td>{row.type}</td>
                <td>{row.work}</td>
                <td>{row.outcome}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section section-alt" aria-labelledby="press-founder-heading">
    <div class="shell">
      <p class="eyebrow">Leadership</p>
      <h2 id="press-founder-heading">Founder bio</h2>
      <article class="content-block" style="margin-top: 1rem; max-width: 62ch;">
        <p>{founderBio}</p>
        <p>
          For podcast, speaking, or expert commentary requests, see{" "}
          <a href={`${siteConfig.danielSite}/media-kit/`} rel="noreferrer" target="_blank">Daniel Johnson&apos;s media kit</a>.
        </p>
      </article>
    </div>
  </section>

  <section class="section" aria-labelledby="press-brand-heading">
    <div class="shell">
      <p class="eyebrow">Brand assets</p>
      <h2 id="press-brand-heading">Logos and default social preview.</h2>
      <p class="lede" style="max-width: 62ch; margin-top: 1rem;">
        Use these URLs when you need raster or SVG marks. For founder photography and speaker topics, use Daniel&apos;s{" "}
        <a href={`${siteConfig.danielSite}/media-kit/`} rel="noreferrer" target="_blank">personal media kit</a>.
      </p>
      <ul class="brand-assets-list">
        {brandAssets.map((asset) => (
          <li>
            <a href={asset.href}>{asset.label}</a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section-alt" aria-labelledby="press-angles-heading">
    <div class="shell">
      <p class="eyebrow">Press angles</p>
      <h2 id="press-angles-heading">Story hooks that match how we work.</h2>
      <ul class="press-angles-list">
        {pressAngles.map((angle) => (
          <li>{angle}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section" aria-labelledby="press-contact-heading">
    <div class="shell">
      <p class="eyebrow">Media contact</p>
      <h2 id="press-contact-heading">Company press and fact-checking</h2>
      <div class="press-contact-routing" style="max-width: 62ch; margin-top: 0.75rem; line-height: 1.55;">
        <p>
          <strong>Company / WSS:</strong> boilerplate, metrics, logos, partner background, and fact-checking on published case formats — use the email below.
        </p>
        <p style="margin-top: 0.65rem;">
          <strong>Podcast, speaking, expert commentary:</strong>{" "}
          <a href={`${siteConfig.danielSite}/media-kit/`} rel="noreferrer" target="_blank">{siteConfig.founderName}&rsquo;s personal media kit</a>{" "}
          (headshots, topics, how to describe Daniel).
        </p>
      </div>
      <div class="press-contact-body">
        <div class="hero-actions">
          <!--email_off-->
          <a class="button button-dark" href={`mailto:${siteConfig.email}`} data-cta="press-email">Email We Scale Startups</a>
          <!--/email_off-->
        </div>
        <p>
          <!--email_off-->
          <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
          <!--/email_off-->
        </p>
        <p><a href={siteConfig.founderLinkedin} rel="noreferrer" target="_blank">Daniel Johnson on LinkedIn</a></p>
        <p><a href={`${siteConfig.danielSite}/media-kit/`} rel="noreferrer" target="_blank">Daniel Johnson media kit</a></p>
        <p><a href="/proof">Proof hub</a> · <a href="/case-studies">Case studies</a></p>
        <p>{siteConfig.address}</p>
      </div>
    </div>
  </section>

  <!-- Removed duplicate "Last updated" section — BaseLayout already renders one
       at the bottom of the page when lastUpdated is passed. Source: Notion
       354f99a79fdb8183a59ad998378f5663. -->

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Related reading</p>
      <h2>Verify claims on the main site.</h2>
      <ul class="related-insights-list">
        {pressRelatedReading.map((item) => (
          <li>
            <a class="card-link" href={item.href}>
              {item.label} →
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">FAQ</p>
      <h2>Press and fact-checking.</h2>
      <div class="grid-3">
        {pressFaqs.map((item) => (
          <article class="feature-card">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Fact-checking</p>
      <h2>Verify outcomes before you cite them.</h2>
      <p class="lede" style="max-width: 62ch;">
        Published cases and the proof hub use the same Problem / Action / Result structure. For commentary on a live growth decision, book a short call — we can usually clarify what is on the record vs client-confidential.
      </p>
      <div class="hero-actions" style="margin-top: 1.25rem;">
        <a class="button button-brand" href="/proof" data-cta="press-verify-proof">See proof hub →</a>
        <a class="button button-light" href="/case-studies" data-cta="press-verify-cases">All case studies →</a>
        <a
          class="button button-light"
          href={siteConfig.bookingUrl}
          data-cta="press-verify-book"
          title={siteConfig.bookingCallReassurance}
        >
          {siteConfig.bookingLabel} →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .press-hero-deck {
    max-width: 62ch;
    margin-top: 0.85rem;
    color: var(--muted);
    line-height: 1.55;
  }
  .press-one-liner {
    font-size: clamp(1.15rem, 2.4vw, 1.35rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.45;
    color: var(--ink);
    margin: 0.5rem 0 0;
    max-width: 52ch;
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .press-at-glance-title {
    font-size: clamp(1.25rem, 2.5vw, 1.45rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0.35rem 0 0.75rem;
    color: var(--ink);
  }
  .press-subhead {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    margin: 1.25rem 0 0.5rem;
  }
  .press-subhead:first-of-type {
    margin-top: 0;
  }
  .press-verify-note {
    font-size: 0.88rem;
    color: var(--muted);
    margin-top: 0.85rem;
  }
  .press-angles-list {
    margin: 1rem 0 0;
    padding-left: 1.15rem;
    max-width: 62ch;
    display: grid;
    gap: 0.5rem;
    color: var(--ink);
    line-height: 1.55;
  }
  .brand-assets-list {
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.45rem;
  }
  .brand-assets-list a {
    font-weight: 600;
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .press-contact-body {
    margin-top: 1rem;
    max-width: 62ch;
    display: grid;
    gap: 0.65rem;
    line-height: 1.55;
  }
  .press-contact-body a:not(.button) {
    font-weight: 600;
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .press-last-updated-section {
    padding-block: 1.5rem;
  }
  .press-last-updated {
    margin: 0;
    font-size: 0.9rem;
    color: var(--muted);
  }
  .press-client-table {
    width: 100%;
    min-width: 640px;
    border-collapse: collapse;
    font-size: 0.9rem;
    line-height: 1.45;
  }
  .press-client-table th,
  .press-client-table td {
    border: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);
    padding: 0.65rem 0.75rem;
    text-align: left;
    vertical-align: top;
  }
  .press-client-table thead th {
    background: color-mix(in oklab, var(--violet) 8%, var(--bg));
    font-weight: 700;
  }
</style>
