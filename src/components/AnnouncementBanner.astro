---
interface Props {
  text: string;
  href?: string;
  linkText?: string;
  dismissible?: boolean;
  variant?: "default" | "brand" | "muted" | "dark-hero";
  /** Optional label chip (dark-hero variant). */
  pill?: string;
}

const { text, href, linkText = "Learn more →", dismissible = true, variant = "default", pill } = Astro.props;

// Generate a unique ID for this banner (for localStorage dismiss)
const bannerId = "banner-" + (href ? href.replace(/\//g, "-") : "global");
---

<div
  id={bannerId}
  class:list={["announcement-banner", `announcement-banner--${variant}`]}
  role="banner"
  data-dismissible={dismissible}
>
  <div class="shell banner-inner">
    {pill && variant === "dark-hero" && <span class="banner-pill">{pill}</span>}
    <p class="banner-text">{text}</p>
    {href && (
      <a class="banner-link" href={href}>{linkText}</a>
    )}
    {dismissible && (
      <button class="banner-dismiss" aria-label="Dismiss announcement" data-dismiss-id={bannerId}>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    )}
  </div>
</div>

<script>
  // Check if banner was previously dismissed
  document.querySelectorAll('[data-dismissible="true"]').forEach((banner) => {
    if (!(banner instanceof HTMLElement)) return;
    const id = banner.id;
    if (localStorage.getItem(`banner-dismissed-${id}`)) {
      banner.style.display = "none";
    }
  });

  // Handle dismiss button clicks
  document.querySelectorAll("[data-dismiss-id]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const id = btn.getAttribute("data-dismiss-id");
      if (!id) return;
      const banner = document.getElementById(id);
      if (banner instanceof HTMLElement) {
        banner.style.display = "none";
        localStorage.setItem(`banner-dismissed-${id}`, "true");
      }
    });
  });
</script>

<style>
  .announcement-banner {
    padding: 0.55rem 0;
    font-size: 0.88rem;
    line-height: 1.4;
    text-align: center;
    border-bottom: 1px solid var(--line);
  }
  .announcement-banner--default {
    background: var(--surface);
    color: var(--ink);
  }
  .announcement-banner--brand {
    background: color-mix(in oklab, var(--violet) 12%, var(--surface));
    color: var(--ink);
  }
  .announcement-banner--muted {
    background: var(--paper);
    color: var(--muted);
  }
  .announcement-banner--dark-hero {
    background: #0d0c09;
    color: #f5efde;
    border-bottom: 1px solid #1f1d18;
    font-size: 13px;
  }
  .announcement-banner--dark-hero .banner-text {
    text-align: center;
  }
  .announcement-banner--dark-hero .banner-link {
    color: #fff;
    opacity: 0.85;
    border-bottom: 1px dotted rgba(255, 255, 255, 0.4);
    text-decoration: none;
    font-weight: 600;
  }
  .announcement-banner--dark-hero .banner-link:hover {
    opacity: 1;
  }
  .announcement-banner--dark-hero .banner-dismiss {
    color: rgba(255, 255, 255, 0.55);
  }
  .announcement-banner--dark-hero .banner-dismiss:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.08);
  }
  .banner-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 9px;
    border-radius: 999px;
    background: linear-gradient(95deg, rgba(94, 43, 255, 0.3), rgba(208, 70, 255, 0.3));
    border: 1px solid rgba(208, 70, 255, 0.4);
    color: #f5edff;
    font-weight: 600;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .banner-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .banner-text {
    margin: 0;
  }
  .banner-link {
    font-weight: 600;
    color: var(--violet);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }
  .banner-link:hover {
    text-decoration-thickness: 2px;
  }
  .banner-dismiss {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    border-radius: 4px;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .banner-dismiss:hover {
    background: rgba(0, 0, 0, 0.06);
    color: var(--ink);
  }
</style>
