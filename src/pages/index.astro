  {/* ============ FINAL CTA ============ */}
  <section class="final-cta">
    <div class="shell">
      <span class="spec-label">→ Next step</span>
      <h2 class="reveal">The next step is a <em>20-minute call</em>.</h2>
      <p class="reveal" data-d="1">Bring your current growth picture. You'll leave with your bottleneck named in plain English, and an honest read on whether we're the right call.</p>
      <a href={siteConfig.bookingUrl} class="btn-primary reveal" data-d="2">{siteConfig.bookingLabel} <span>→</span></a>
    </div>
  </section>

  <script is:inline>
    // =========== Scroll-reveal ===========
    (function(){
      const els = document.querySelectorAll('.reveal');
      if (!('IntersectionObserver' in window)) { els.forEach(e => e.classList.add('in')); return; }
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      els.forEach(e => io.observe(e));
    })();

    // =========== Pointer-tracked glow on cards ===========
    (function(){
      if (window.matchMedia('(hover: none)').matches) return;
      document.querySelectorAll('.glow-card').forEach(card => {
        card.addEventListener('pointermove', (e) => {
          const r = card.getBoundingClientRect();
          card.style.setProperty('--mx', ((e.clientX - r.left) / r.width * 100) + '%');
          card.style.setProperty('--my', ((e.clientY - r.top) / r.height * 100) + '%');
        });
      });
    })();

    // =========== Animated counters on scroll ===========
    (function(){
      const counters = document.querySelectorAll('.counter');
      const ease = t => 1 - Math.pow(1 - t, 3);
      function animate(el) {
        const target = parseFloat(el.dataset.target);
        const decimals = parseInt(el.dataset.decimals) || 0;
        const suffix = el.dataset.suffix || '';
        const prefix = el.dataset.prefix || '';
        const dur = 1400;
        const start = performance.now();
        const wrap = el.querySelector('span');
        const wrapHTML = wrap ? wrap.outerHTML : '';
        function tick(now) {
          const p = Math.min((now - start) / dur, 1);
          const v = ease(p) * target;
          el.firstChild.nodeValue = prefix + v.toFixed(decimals) + suffix;
          if (wrap) el.innerHTML = prefix + v.toFixed(decimals) + suffix + wrapHTML;
          if (p < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      }
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (e.isIntersecting && !e.target.dataset.animated) {
              e.target.dataset.animated = '1';
              animate(e.target);
              io.unobserve(e.target);
            }
          });
        }, { threshold: 0.3 });
        counters.forEach(c => io.observe(c));
      }
    })();

    // =========== Diagnostic widget — tab switcher ===========
    (function(){
      const scenarios = {
        saas: {
          title: 'What 20 minutes looks like.',
          sub: 'A real diagnosis from a recent B2B SaaS call. Yours follows the same shape.',
          now: '£42k<span class="unit">/wk</span>', flat: '— flat 6 wks',
          proj: '£128k<span class="unit">/wk</span>', growth: '▲ 3.0× compounding',
          bn: 'Acq.', conf: '88% conf.',
          verdict: 'Run a 90-day sprint against <em>acquisition</em>.',
          bars: [38, 42, 36, 40, 48, 58, 68, 78, 88, 100],
          tags: ['ok', 'bad', 'watch', 'ok', 'watch']
        },
        fintech: {
          title: 'A fintech founder, last quarter.',
          sub: 'Pipeline strong on the brand channel; nothing else carrying weight.',
          now: '£68k<span class="unit">/wk</span>', flat: '— spiky 12 wks',
          proj: '£170k<span class="unit">/wk</span>', growth: '▲ 2.5× diversified',
          bn: 'Conv.', conf: '92% conf.',
          verdict: 'Tighten the demo-to-SQL playbook. <em>Sprint</em> recommended.',
          bars: [55, 62, 48, 70, 58, 65, 78, 72, 88, 100],
          tags: ['ok', 'ok', 'bad', 'watch', 'ok']
        },
        healthtech: {
          title: 'A healthtech founder, this month.',
          sub: 'Strong clinical product. Marketing function did not exist.',
          now: '£12k<span class="unit">/wk</span>', flat: '— inconsistent',
          proj: '£64k<span class="unit">/wk</span>', growth: '▲ 5.3× building',
          bn: 'All five', conf: '—',
          verdict: 'Marketing function from zero. <em>System Build</em> required.',
          bars: [10, 15, 8, 18, 22, 38, 52, 68, 82, 100],
          tags: ['watch', 'bad', 'watch', 'bad', 'bad']
        }
      };
      const tabs = document.querySelectorAll('.diag-tab');
      function setTag(el, cls) {
        el.classList.remove('ok', 'bad', 'watch');
        el.classList.add(cls);
        el.textContent = cls === 'ok' ? 'Healthy' : cls === 'bad' ? 'Bottleneck' : 'Watch';
      }
      tabs.forEach(t => {
        t.addEventListener('click', () => {
          tabs.forEach(o => o.classList.remove('active'));
          t.classList.add('active');
          const s = scenarios[t.dataset.tab];
          document.getElementById('diag-title').textContent = s.title;
          document.getElementById('diag-sub').textContent = s.sub;
          document.querySelector('[data-m="now"]').innerHTML = s.now;
          document.querySelector('[data-m="flat"]').textContent = s.flat;
          document.querySelector('[data-m="proj"]').innerHTML = s.proj;
          document.querySelector('[data-m="growth"]').textContent = s.growth;
          document.querySelector('[data-m="bn"]').textContent = s.bn;
          document.querySelector('[data-m="conf"]').textContent = s.conf;
          document.getElementById('verdict').innerHTML = '<strong>Verdict.</strong> ' + s.verdict;
          const bars = document.querySelectorAll('#chart .bar');
          s.bars.forEach((h, i) => { if (bars[i]) bars[i].style.height = h + '%'; });
          const tags = document.querySelectorAll('[data-t]');
          s.tags.forEach((t, i) => { if (tags[i]) setTag(tags[i], t); });
        });
      });
    })();

    // =========== Find-your-bottleneck interactive ===========
    (function(){
      const data = {
        positioning: { meta: '01 · POSITIONING', title: 'Your story lands in the room. Not in the market.', desc: 'The product narrative is right, but it does not carry beyond a live conversation. Demos go well, pipeline does not.', svc: 'Growth Diagnosis', meta2: 'from £4k · 1 week · Best starting point', link: '/services/growth-diagnosis' },
        acquisition: { meta: '02 · ACQUISITION', title: 'One channel carries the funnel.', desc: 'Diversify before the dip — design the second engine and the weekly decision rule that scales it.', svc: 'Acquisition System Build', meta2: 'from £30k · 8–12 weeks · Flagship', link: '/services/acquisition-system-build' },
        conversion: { meta: '03 · CONVERSION', title: 'Demos and trials do not progress.', desc: 'No shared playbook for what to say, when. 90-day sprint installs the test loop and decision cadence.', svc: '90-Day Growth Sprint', meta2: 'from £15k · 12 weeks · Best for fast signal', link: '/services/90-day-growth-sprint' },
        reporting: { meta: '04 · REPORTING', title: 'No single weekly view of scale, stop, or fix.', desc: 'Paid, organic, outbound each report in their own dashboards. Build installs one decision view your team owns.', svc: 'Acquisition System Build', meta2: 'from £30k · 8–12 weeks · Flagship', link: '/services/acquisition-system-build' },
        team: { meta: '05 · TEAM OWNERSHIP', title: 'Every campaign and brief routes through the founder.', desc: 'Senior judgement without a £150k hire. Embedded leadership 2–3 days/week, transferring the rhythm.', svc: 'Fractional CMO', meta2: 'from £8k/mo · 3-month min', link: '/services/fractional-cmo' }
      };
      const cards = document.querySelectorAll('.bf-card');
      function update(key) {
        const d = data[key];
        document.getElementById('bf-meta').textContent = d.meta;
        document.getElementById('bf-title').textContent = d.title;
        document.getElementById('bf-desc').textContent = d.desc;
        document.getElementById('bf-svc').textContent = d.svc;
        document.getElementById('bf-svc-meta').textContent = d.meta2;
        document.getElementById('bf-link').href = d.link;
        document.getElementById('bf-link').textContent = d.svc + ' →';
      }
      cards.forEach(c => {
        c.addEventListener('click', () => {
          cards.forEach(o => o.classList.remove('active'));
          c.classList.add('active');
          update(c.dataset.bn);
        });
      });
    })();
  </script>
</BaseLayout>
