---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig, buyerFaqs } from "../site";
import { buildFaqSchema } from "../lib/schema";
import "../styles/home-v7.css";

const faqSchema = buildFaqSchema([...buyerFaqs]);

// "Not a founder?" routing — investors / corporate / operators
const subAudiences = [
  {
    title: "Investors & funds.",
    body: "Diagnose growth across a portfolio in two weeks. Same framework, applied across companies.",
    href: "/resources/vc-portfolio-growth-diagnosis",
    label: "VC Portfolio Diagnosis"
  },
  {
    title: "Corporate & accelerator partners.",
    body: "Workshops, keynote talks, and programme advisory for cohorts and innovation teams.",
    href: "/speaking",
    label: "Speaking & workshops"
  },
  {
    title: "Operators, advisors & referrers.",
    body: "Refer a founder, come on the podcast, or partner on a deal. Drop a line.",
    href: "/contact",
    label: "Get in touch"
  }
];
---
<BaseLayout
  title="We Scale Startups — Fractional CMO for Post-PMF B2B SaaS & AI"
  description="Fractional CMO who installs a repeatable growth system in 90 days, for post-PMF B2B SaaS and AI founders doing £1–10M ARR."
  path="/"
  schema={faqSchema}
  bodyClass="page-home-v7"
>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@500;600;700;800;900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

  {/* HERO */}
  <section class="hero">
    <div class="shell">
      <span class="spec-label">Fractional CMO · Post-PMF B2B SaaS &amp; AI</span>
      <div class="hero-grid">
        <div>
          <h1>Your pipeline shouldn't depend on <span class="hl">you running</span> it.</h1>
          <p class="lede">We install the acquisition system your team can run <strong>without the founder in every decision</strong> — in 90 days, for the cost of a senior hire's first quarter.</p>

          <div class="step-chips">
            <a href="/services/growth-diagnosis" class="step-chip"><span class="n">01</span> Diagnose</a>
            <a href="/services/90-day-growth-sprint" class="step-chip"><span class="n">02</span> Sprint</a>
            <a href="/services/acquisition-system-build" class="step-chip"><span class="n">03</span> Build</a>
            <a href="/services/fractional-cmo" class="step-chip"><span class="n">04</span> Embed</a>
          </div>

          <div class="hero-ctas">
            <a href={siteConfig.bookingUrl} class="btn-primary">{siteConfig.bookingLabel} <span>→</span></a>
            <a href={siteConfig.scorecardUrl} class="btn-secondary">Take the 5-min scorecard <span>→</span></a>
          </div>

          <div class="hero-trust">
            <div class="trust"><span class="trust-v counter" data-target="18" data-suffix="M+" data-prefix="£">£18M+</span><span class="trust-l">Revenue<br />influenced</span></div>
            <div class="trust"><span class="trust-v counter" data-target="6" data-suffix="M+" data-prefix="£">£6M+</span><span class="trust-l">Paid spend<br />managed</span></div>
            <div class="trust"><span class="trust-v counter" data-target="479" data-suffix="+">479+</span><span class="trust-l">Founder<br />sessions</span></div>
            <div class="trust"><span class="trust-v counter" data-target="4.93" data-decimals="2">4.93<span style="font-size:0.55em;color:var(--ink-3);font-weight:500;">/5</span></span><span class="trust-l">GrowthMentor<br />rating</span></div>
          </div>
        </div>

        {/* Diagnostic widget — with tab switcher */}
        <aside class="diag-card">
          <div class="diag-tabs" role="tablist">
            <button class="diag-tab active" data-tab="saas" role="tab">B2B SaaS</button>
            <button class="diag-tab" data-tab="fintech" role="tab">Fintech</button>
            <button class="diag-tab" data-tab="healthtech" role="tab">Healthtech</button>
          </div>
          <div class="diag-head">
            <span class="diag-head-l">Growth Diagnostic — Live Sample</span>
            <span class="diag-head-r" id="diag-wk">WK 01/12</span>
          </div>
          <div class="diag-title" id="diag-title">What 20 minutes looks like.</div>
          <div class="diag-sub" id="diag-sub">A real diagnosis from a recent call. Yours follows the same shape, with your numbers.</div>
          <div class="diag-metrics">
            <div><div class="m-label">Pipeline today</div><div class="m-val" data-m="now">£42k<span class="unit">/wk</span></div><div class="m-foot" data-m="flat">— flat 6 wks</div></div>
            <div><div class="m-label">12-wk projection</div><div class="m-val violet" data-m="proj">£128k<span class="unit">/wk</span></div><div class="m-foot up" data-m="growth">▲ 3.0× compounding</div></div>
            <div><div class="m-label">Bottleneck</div><div class="m-val violet" data-m="bn">Acq.</div><div class="m-foot" data-m="conf">88% conf.</div></div>
          </div>
          <div class="chart-row" id="chart">
            <div class="bar dim" style="height:38%"></div>
            <div class="bar dim" style="height:42%"></div>
            <div class="bar dim" style="height:36%"></div>
            <div class="bar dim" style="height:40%"></div>
            <div class="bar" style="height:48%"></div>
            <div class="bar" style="height:58%"></div>
            <div class="bar" style="height:68%"></div>
            <div class="bar" style="height:78%"></div>
            <div class="bar" style="height:88%"></div>
            <div class="bar" style="height:100%"></div>
          </div>
          <div class="constraints" id="constraints">
            <div class="constraint"><span class="constraint-name"><span class="constraint-n">01</span><span class="constraint-text"><strong>Positioning</strong><span data-c="01">ICP clear · category owned</span></span></span><span class="tag ok" data-t="01">Healthy</span></div>
            <div class="constraint bn"><span class="constraint-name"><span class="constraint-n">02</span><span class="constraint-text"><strong>Acquisition</strong><span data-c="02">Single-source channel</span></span></span><span class="tag bad" data-t="02">Bottleneck</span></div>
            <div class="constraint"><span class="constraint-name"><span class="constraint-n">03</span><span class="constraint-text"><strong>Conversion</strong><span data-c="03">Demo → SQL leak</span></span></span><span class="tag watch" data-t="03">Watch</span></div>
            <div class="constraint"><span class="constraint-name"><span class="constraint-n">04</span><span class="constraint-text"><strong>Reporting</strong><span data-c="04">Weekly cadence trusted</span></span></span><span class="tag ok" data-t="04">Healthy</span></div>
            <div class="constraint"><span class="constraint-name"><span class="constraint-n">05</span><span class="constraint-text"><strong>Team ownership</strong><span data-c="05">Founder-dependent</span></span></span><span class="tag watch" data-t="05">Watch</span></div>
          </div>
          <div class="verdict" id="verdict"><strong>Verdict.</strong> Run a 90-day sprint against <em style="color:var(--violet);font-style:italic;">acquisition</em>.</div>
        </aside>
      </div>
    </div>
  </section>

  {/* LOGO WALL — credentials, replacing the duplicate-stat proof bar */}
  <section class="logo-wall">
    <div class="shell">
      <div class="logo-wall-label">Trusted by founders, programmes &amp; platforms</div>
      <div class="logo-row">
        <a href="https://www.jbs.cam.ac.uk/" class="logo-item lg-cambridge-wrap" rel="noopener noreferrer" target="_blank" aria-label="Cambridge Judge Business School — guest lecturer">
          <span class="lg-cambridge">
            <svg viewBox="0 0 40 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M20 2 L36 8 L36 26 C36 36 28 44 20 46 C12 44 4 36 4 26 L4 8 Z" fill="#A50034" stroke="#A50034" stroke-width="1"/>
              <path d="M12 14 Q15 12 18 14 Q15 16 12 14 M22 14 Q25 12 28 14 Q25 16 22 14 M12 22 Q15 20 18 22 Q15 24 12 22 M22 22 Q25 20 28 22 Q25 24 22 22 M12 30 Q15 28 18 30 Q15 32 12 30 M22 30 Q25 28 28 30 Q25 32 22 30" fill="#FFC72C" stroke="#FFC72C" stroke-width="0.5"/>
            </svg>
            <span class="lg-cambridge-text">UNIVERSITY OF<br />CAMBRIDGE<span class="judge">Judge Business School</span></span>
          </span>
          <span class="logo-meta">Guest Lecturer</span>
        </a>
        <a href="https://startup.google.com/" class="logo-item" rel="noopener noreferrer" target="_blank" aria-label="Google for Startups — mentor">
          <span class="lg-google"><span class="g-b">G</span><span class="g-o">o</span><span class="g-y">o</span><span class="g-b">g</span><span class="g-g">l</span><span class="g-o">e</span><span class="g-suffix">for Startups</span></span>
          <span class="logo-meta">Mentor</span>
        </a>
        <a href="https://www.techstars.com" class="logo-item" rel="noopener noreferrer" target="_blank" aria-label="Techstars — speaker">
          <span class="lg-techstars">techstars<span class="lg-techstars-underscore">_</span></span>
          <span class="logo-meta">Speaker</span>
        </a>
        <a href="https://app.growthmentor.com/mentors/daniel-johnson" class="logo-item" rel="noopener noreferrer" target="_blank" aria-label="GrowthMentor — 4.93 across 479+ sessions">
          <span class="lg-growthmentor">
            <svg viewBox="0 0 40 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M20 0 C28 6 34 14 34 22 C34 30 28 36 20 36 C12 36 6 30 6 22 C6 14 12 6 20 0 Z M20 8 L20 30 M14 14 C14 18 17 21 20 21 M26 14 C26 18 23 21 20 21 M14 22 C14 26 17 28 20 28 M26 22 C26 26 23 28 20 28" fill="none" stroke="#6d28d9" stroke-width="3" stroke-linecap="round"/>
              <line x1="20" y1="36" x2="20" y2="46" stroke="#6d28d9" stroke-width="3" stroke-linecap="round"/>
            </svg>
            growthmentor
          </span>
          <span class="logo-meta">★ 4.93 · 479+ sessions</span>
        </a>
        <a href="https://www.imperial.ac.uk/business-school" class="logo-item" rel="noopener noreferrer" target="_blank" aria-label="Imperial College Business School — speaker">
          <span class="lg-imperial">
            IMPERIAL
            <span class="lg-imperial-sub">BUSINESS SCHOOL</span>
          </span>
          <span class="logo-meta">Speaker</span>
        </a>
        <a href="https://mentorcruise.com/mentor/danieljohnson/" class="logo-item lg-mentorcruise" rel="noopener noreferrer" target="_blank" aria-label="MentorCruise — Top Mentor">
          <svg viewBox="0 0 177 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
