---
import CfEmailOff from "../../components/CfEmailOff.astro";
import SectionIntro from "../../components/SectionIntro.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema, buildFaqSchema } from "../../lib/schema";
import { resourcesRelatedReading, siteConfig } from "../../site";

function guideRequestMailto(title: string, id: string) {
  const outlineUrl = `${siteConfig.siteUrl}/resources#${id}`;
  const subject = `Send me the ${title}`;
  const body = `Please send the ${title}.\n\nOn-page outline: ${outlineUrl}`;
  return `mailto:${siteConfig.email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
}

const resourcesFaqs = [
  {
    question: "Are these resources really free?",
    answer:
      "Yes. They exist to help founders self-diagnose and brief agencies or operators with clearer context. Optional email capture may apply on some flows."
  },
  {
    question: "Do resources replace an engagement?",
    answer:
      "No. They sharpen the question. If the bottleneck is still unclear after the scorecard or guides, diagnosis or a sprint is usually the next step."
  },
  {
    question: "How do I request a specific guide?",
    answer:
      "Use the request button on each card. Your email will include a link to the on-page outline so we know which asset you mean."
  }
];

const resourcesSchema = [
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Resources", path: "/resources" }
  ]),
  buildFaqSchema(resourcesFaqs)
];

const guides = [
  {
    id: "growth-bottleneck-scorecard",
    title: "Growth Bottleneck Scorecard",
    format: "Founder checklist",
    bestFor: "Post-PMF teams with activity but unclear priorities",
    sections: [
      "ICP clarity",
      "Channel signal",
      "Landing page conversion",
      "Founder-led sales dependency",
      "Reporting and decision cadence"
    ]
  },
  {
    id: "90-day-growth-sprint-planner",
    title: "90-Day Growth Sprint Planner",
    format: "Sprint planning worksheet",
    bestFor: "Leadership teams preparing a quarter of focused growth work",
    sections: [
      "Diagnosis inputs",
      "Experiment backlog",
      "Decision rules",
      "Weekly review rhythm",
      "Transfer checklist"
    ]
  },
  {
    id: "vc-portfolio-growth-diagnosis",
    title: "VC Portfolio Growth Diagnosis Template",
    format: "Portfolio workshop guide",
    bestFor: "Investors, accelerators, and venture studios supporting founder growth decisions",
    sections: [
      "Founder bottleneck prompts",
      "Channel and conversion questions",
      "Board-ready next steps",
      "Referral routes",
      "Sprint or fractional CMO fit"
    ]
  },
  {
    id: "acquisition-channel-matrix",
    title: "Acquisition Channel Decision Matrix",
    format: "Channel selection worksheet",
    bestFor: "Teams choosing where to invest next quarter's acquisition budget",
    sections: [
      "Paid vs organic fit by stage",
      "Team capacity requirements",
      "ICP alignment scoring",
      "Time-to-signal by channel",
      "Decision matrix template"
    ]
  },
  {
    id: "fractional-cmo-hiring-checklist",
    title: "Fractional CMO Hiring Checklist",
    format: "Hiring assessment worksheet",
    bestFor: "Founders preparing to hire senior GTM leadership",
    sections: [
      "Questions to ask in interview",
      "Artefacts to expect in week 1",
      "Red flags during diagnosis",
      "Handoff criteria for internal hire",
      "Equity vs cash trade-offs"
    ]
  },
  {
    id: "ai-native-gtm-stack-map",
    title: "AI-Native GTM Stack Map",
    format: "Stack assessment template",
    bestFor: "Teams adopting AI for research, messaging, and campaign iteration",
    sections: [
      "Current stack audit",
      "AI research acceleration points",
      "Message testing with AI",
      "Reporting automation gaps",
      "Implementation priority map"
    ]
  }
];
---

<BaseLayout
  title="Resources | We Scale Startups"
  description="Free growth diagnosis guides, sprint planners, and portfolio templates for post-PMF startups building repeatable growth systems."
  keywords="growth bottleneck scorecard, 90-day growth sprint, VC portfolio template, startup growth diagnosis, post-PMF GTM, fractional CMO resources"
  path="/resources"
  schema={resourcesSchema}
  lastUpdated={siteConfig.lastUpdated}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Resources</p>
      <h1>Practical growth guides for teams between traction and scale.</h1>
      <p>Use these when you need a clearer diagnosis before hiring, briefing an agency, or adding more channel activity.</p>
      <div class="hero-actions">
        <a
          class="button button-dark button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="resources-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="resources-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
        <a class="button button-light" href="/proof" data-cta="resources-proof">See proof</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionIntro
        eyebrow="Lead magnets"
        title="Downloadable enough to use, lightweight enough to read."
        body="The point is to help a founder make the next growth decision, not bury them in a decorative PDF."
      />
      <div class="grid-3">
        {guides.map((guide) => (
          <article class="feature-card" id={guide.id}>
            <p class="card-kicker">{guide.format}</p>
            <h3>{guide.title}</h3>
            <p><strong>Best for:</strong> {guide.bestFor}</p>
            <ul>
              {guide.sections.map((item) => <li>{item}</li>)}
            </ul>
            <p class="resource-outline-link">
              <a
                class="card-link"
                href={`/resources/${guide.id}`}
                data-cta={`resources-fullpage-${guide.id}`}
              >
                See the full landing page →
              </a>
            </p>
            <CfEmailOff>
              <a class="button button-light" href={guideRequestMailto(guide.title, guide.id)} data-cta={`resources-request-${guide.id}`}>
                Request the guide
              </a>
            </CfEmailOff>
          </article>
        ))}
      </div>
    </div>
  </section>

      <section class="section section-alt">
        <div class="shell">
          <SectionIntro
            eyebrow="Deliverable examples"
            title="What the work looks like — before we tailor it to you."
            body="These are illustrative examples of the artefacts you take away: constraint maps, experiment cards, channel briefs, and weekly decision logs."
          />
          <div class="grid-3">
            <article class="feature-card">
              <p class="card-kicker">Constraint map</p>
              <h3>One-page diagnosis output</h3>
              <p>Positions the bottleneck across 5 dimensions, evidence table, and 90-day priority sequence. <a href="/proof#deliverables">See proof →</a></p>
            </article>
            <article class="feature-card">
              <p class="card-kicker">Experiment card</p>
              <h3>ICE-scored sprint backlog</h3>
              <p>Hypothesis, owner, success metric, and decision rule for every test. <a href="/diagnose">See diagnostic framework →</a></p>
            </article>
            <article class="feature-card">
              <p class="card-kicker">Channel brief</p>
              <h3>Campaign-ready acquisition brief</h3>
              <p>Audience, offer, landing page wireframe, and tracking spec for each channel. <a href="/services/acquisition-system-build">See acquisition build →</a></p>
            </article>
          </div>
        </div>
      </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Related reading</p>
      <h2>Frameworks, quizzes, and notes that pair with these guides.</h2>
      <ul class="related-insights-list">
        {resourcesRelatedReading.map((item) => (
          <li>
            <a class="card-link" href={item.href}>
              {item.label} →
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">FAQ</p>
      <h2>Using the resource hub.</h2>
      <div class="grid-3">
        {resourcesFaqs.map((item) => (
          <article class="feature-card">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Need the diagnosis done with you?</p>
        <h2>Bring the current growth mess.</h2>
        <p>
          In {siteConfig.bookingCallDurationPhrase}, we will identify whether the constraint is positioning, acquisition, conversion, reporting, or senior leadership — no pitch unless there is a clear fit.
        </p>
      </div>
      <div class="hero-actions">
        <a
          class="button button-brand button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="resources-final-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="resources-final-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .resource-outline-link {
    margin: 0.5rem 0 0.75rem;
    font-size: 0.9rem;
  }
</style>
