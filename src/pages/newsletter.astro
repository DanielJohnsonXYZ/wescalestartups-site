---
import BaseLayout from "../layouts/BaseLayout.astro";
import EmailSignup from "../components/EmailSignup.astro";
import { buildBreadcrumbSchema } from "../lib/schema";
import { insightsHubRelatedReading, siteConfig } from "../site";

const schemas = [
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Newsletter", path: "/newsletter" }
  ])
];
---

<BaseLayout
  title={`${siteConfig.newsletterName} — newsletter | We Scale Startups`}
  description={`${siteConfig.newsletterDescription} ${siteConfig.newsletterFrequencyLine}`}
  path="/newsletter"
  schema={schemas}
  lastUpdated={siteConfig.lastUpdated}
>
  <section class="page-hero" aria-labelledby="wss-newsletter-title">
    <div class="shell max-w-3xl">
      <p class="eyebrow">Newsletter</p>
      <h1 id="wss-newsletter-title">{siteConfig.newsletterName}</h1>
      <p class="hero-copy">
        {siteConfig.newsletterDescription} {siteConfig.newsletterFrequencyLine} Sent from Daniel Johnson ·{" "}
        <span class="whitespace-nowrap">{siteConfig.email}</span>.
      </p>
      <p class="mt-4 text-[color:var(--muted)]">
        Same list as the site footer — one name and cadence everywhere.
      </p>
      <p class="mt-6 text-sm leading-relaxed text-[color:var(--muted)]">
        For Daniel’s personal writing list (occasional growth notes from{" "}
        <a class="link-arrow" href={`${siteConfig.danielSite}/newsletter/`} rel="noopener">
          danieljohnson.xyz
        </a>
        ), use that page — this list is the We Scale Startups / operator lens.
      </p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell max-w-2xl">
      <h2 class="text-2xl font-bold tracking-[-0.04em] mb-4">Get the next issue</h2>
      <p class="text-[color:var(--muted)] mb-8">
        Single opt-in — you’ll get the next send as soon as you confirm. Unsubscribe any time.
      </p>
      <div class="card p-8 md:p-10">
        <EmailSignup
          variant="light"
          formId="page-newsletter-growth-bottleneck"
          heading={siteConfig.newsletterName}
          subtext={`${siteConfig.newsletterDescription} ${siteConfig.newsletterFrequencyLine}`}
        />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell max-w-3xl">
      <h2 class="text-2xl font-bold tracking-[-0.04em] mb-6">What you’ll read</h2>
      <ul class="space-y-3 text-[color:var(--muted)] list-disc pl-5">
        <li>How to name the real constraint before you add channel spend</li>
        <li>Systems vs activity — what “repeatable acquisition” actually looks like</li>
        <li>Patterns from fractional CMO work with Seed–Series B teams</li>
        <li>Links to deeper essays on <a class="link-arrow" href="/insights">Insights</a> when a topic deserves the long version</li>
      </ul>
      <p class="mt-8">
        Prefer a call? <a class="link-arrow" href={siteConfig.bookingUrl}>{siteConfig.bookingLabel} →</a>
      </p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell max-w-3xl">
      <p class="eyebrow">Keep exploring</p>
      <h2 class="text-xl font-bold tracking-[-0.04em] mb-6">Related on the site</h2>
      <ul class="grid gap-3 sm:grid-cols-2">
        {insightsHubRelatedReading.map((link) => (
          <li>
            <a class="link-arrow" href={link.href}>
              {link.label} →
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
