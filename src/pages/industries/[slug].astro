---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema, buildFaqSchema } from "../../lib/schema";
import { indexableIndustrySlugs, industryDetailRelatedReading, siteConfig } from "../../site";

export async function getStaticPaths() {
  const industries = await getCollection("industries");
  return industries.map((industry) => ({
    params: { slug: industry.id },
    props: { industry }
  }));
}

const { industry } = Astro.props;
const path = `/industries/${industry.id}`;

const industryFaqs = [
  {
    question: `What usually breaks for ${industry.data.title} teams post-PMF?`,
    answer: industry.data.buyerProblem
  },
  {
    question: "What is the first step if we might be a fit?",
    answer: `Run the scorecard or ${siteConfig.bookingLabel.replace(/^Book /, "book ")} with your current funnel and proof context. The goal is to name the bottleneck before adding more channel activity.`
  },
  {
    question: "Do you only work with companies in this sector?",
    answer:
      "No. This page translates common buyer, proof, and channel economics patterns for the sector. If your motion is similar — trust-heavy, committee buying, proof bar — the diagnostic still applies."
  }
];

// Thin-content guard: only industry pages backed by a named case study stay indexable.
// The rest remain useful for navigation but are noindexed until they carry unique proof
// (a real case study + sector-specific insight), to avoid doorway-page classification.
const indexableIndustries = new Set<string>(indexableIndustrySlugs);
const industryRobots = indexableIndustries.has(industry.id)
  ? undefined
  : "noindex,follow";

const industrySchema = [
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Industries", path: "/industries" },
    { name: industry.data.title, path }
  ]),
  buildFaqSchema(industryFaqs)
];
---

<BaseLayout
  title={`${industry.data.title} | We Scale Startups`}
  description={industry.data.description}
  path={path}
  schema={industrySchema}
  metaRobots={industryRobots}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Industry</p>
      <h1>{industry.data.title}</h1>
      <p>{industry.data.description}</p>
      <div class="hero-actions">
        <a
          class="button button-dark button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="industry-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="industry-hero-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
        <a class="button button-light" href="/industries">All industries</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell detail-grid">
      <aside class="detail-aside">
        <p class="eyebrow">Buyer problem</p>
        <p>{industry.data.buyerProblem}</p>
      </aside>
      <div class="detail-body">
        <article class="content-block">
          <h2>Useful when</h2>
          <ul>
            {industry.data.usefulWhen.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article class="content-block">
          <h2>Growth system</h2>
          <ul>
            {industry.data.growthSystem.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article class="content-block">
          <h2>Market-specific proof</h2>
          <ul>
            {industry.data.proof.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        {industry.data.readingBlocks?.map((block) => (
          <article class="content-block">
            <h2>{block.heading}</h2>
            {block.paragraphs?.map((p) => (
              <p>{p}</p>
            ))}
            {block.bullets && block.bullets.length > 0 ? (
              <ul>
                {block.bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            ) : null}
          </article>
        ))}
        <article class="content-block">
          <h2>Lead magnet</h2>
          <p>
            {siteConfig.scorecardLabelLong} and use it to decide whether the issue is positioning, acquisition, conversion,
            reporting, or leadership capacity in this market.
          </p>
          <p>
            <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="industry-scorecard">
              {siteConfig.scorecardLabel} →
            </a>
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Related reading</p>
      <h2>Hubs that pair with this market.</h2>
      <ul class="related-insights-list">
        {industryDetailRelatedReading.map((item) => (
          <li>
            <a class="card-link" href={item.href}>
              {item.label} →
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">FAQ</p>
      <h2>Questions founders ask on industry fit.</h2>
      <div class="grid-3">
        {industryFaqs.map((item) => (
          <article class="feature-card">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Market-specific diagnosis</p>
        <h2>Want a clearer growth path for {industry.data.title.toLowerCase()}?</h2>
        <p>We will connect the buyer problem, proof requirement, channel economics, and team capacity into a practical next step.</p>
      </div>
      <div class="hero-actions">
        <a
          class="button button-brand button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="industry-final-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="industry-final-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
