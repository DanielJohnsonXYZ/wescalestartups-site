---
// Compact named-client line directly under the homepage hero (Growth Hub: trust near CTA).
import { proofClients } from "../site";
---

<section class="hero-client-strip" aria-label="Selected client work">
  <div class="shell hero-client-strip-inner">
    <span class="hero-client-strip-label">Selected client work</span>
    <p class="hero-client-strip-names">
      {
        proofClients.map((client, i) => (
          <>
            {i > 0 && <span aria-hidden="true"> · </span>}
            <a href={`/case-studies/${client.caseSlug}`} data-cta={`hero-client-${client.caseSlug}`}>
              {client.label}
            </a>
          </>
        ))
      }
    </p>
    <a class="hero-client-strip-proof" href="/proof" data-cta="hero-client-strip-proof">
      Full proof →
    </a>
  </div>
</section>
