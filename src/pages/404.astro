---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found | We Scale Startups" description="The page you were looking for could not be found." path="/404">
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">404</p>
      <h1>This page wandered off.</h1>
      <p>The useful paths are still here: services, industries, proof, or contact.</p>
      <div class="hero-actions">
        <a class="button button-dark" href="/">Go home</a>
        <a class="button button-light" href="/contact">Contact</a>
      </div>
    </div>
  </section>
</BaseLayout>
