              <footer>— {c.who}</footer>
            </blockquote>
          ))}
        </div>
      </div>
    </section>
  )}

  {
    relatedForService.length > 0 && (
      <section class="section">
        <div class="shell">
          <p class="eyebrow">Related reading</p>
          <h2>Notes and hubs that pair with this engagement.</h2>
          <ul class="related-insights-list">
            {relatedForService.map((item) => (
              <li>
                <a class="card-link" href={item.href}>
                  {item.label} →
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <!-- Service-specific FAQs (6 standardised questions) -->
  <section class="section section-alt service-faqs">
    <div class="shell">
      <p class="eyebrow">FAQ</p>
      <h2>What founders ask before they book.</h2>
      <div class="service-faqs-grid">
        {details.faqs.map(([question, answer]: [string, string]) => (
