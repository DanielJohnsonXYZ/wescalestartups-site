# Copy to .env locally. For production, set variables in the host UI:
# - Cloudflare Pages: Project → Settings → Environment variables (Production + Preview)
# - Vercel: Project → Settings → Environment Variables

# Mautic newsletter / lead forms (EmailSignup component)
# In Mautic: Forms → open the form → ID is in the URL or form settings.
# Use the public base URL of your Mautic instance (no trailing slash).
# PUBLIC_MAUTIC_BASE_URL=https://comms.wescalestartups.com
# PUBLIC_MAUTIC_NEWSLETTER_FORM_ID=
#
# After deploy, verify the form renders and submissions arrive in Mautic
# before relying on newsletter capture on high-traffic pages.
