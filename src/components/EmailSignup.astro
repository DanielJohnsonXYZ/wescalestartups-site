---
// EmailSignup.astro - inline email capture; posts to Mautic (see site.ts).
import { mauticNewsletter } from "../site";

interface Props {
  heading?: string;
  subtext?: string;
  formId?: string;
  variant?: "light" | "dark";
  buttonLabel?: string;
  sourceType?: "newsletter" | "lead_magnet" | "contact_enquiry";
  sourcePage?: string;
  leadMagnet?: string;
}

const {
  heading = "Get the weekly growth note.",
  subtext = "One actionable insight for post-PMF founders. No padding, no pitch.",
  formId = "email-signup",
  variant = "light",
  buttonLabel = "Get the note ->",
  sourceType = "newsletter",
  sourcePage = Astro.url.pathname,
  leadMagnet = ""
} = Astro.props;

const { submitUrl, formId: mauticFormId } = mauticNewsletter;
const sourcePageValue = sourcePage || Astro.url.pathname;
---

<div class={`email-signup-strip email-signup-strip--${variant}`} data-form-id={formId}>
  <div class="email-signup-inner">
    <div class="email-signup-copy">
      <p class="email-signup-heading">{heading}</p>
      <p class="email-signup-sub">{subtext}</p>
    </div>
    <form
      class="email-signup-form"
      id={formId}
      action={submitUrl}
      method="post"
      accept-charset="UTF-8"
      data-cta={`email-signup-${formId}`}
      data-mautic-source-form
    >
      <input type="hidden" name="mauticform[formId]" value={mauticFormId} />
      <input type="hidden" name="mauticform[source_type]" value={sourceType} />
      <input type="hidden" name="mauticform[source_page]" value={sourcePageValue} data-source-page />
      <input type="hidden" name="mauticform[lead_magnet]" value={leadMagnet} />
      <input type="hidden" name="mauticform[utm_source]" value="" data-utm-field="utm_source" />
      <input type="hidden" name="mauticform[utm_medium]" value="" data-utm-field="utm_medium" />
      <input type="hidden" name="mauticform[utm_campaign]" value="" data-utm-field="utm_campaign" />
      <label class="sr-only" for={`email-field-${formId}`}>Your email address</label>
      <input
        id={`email-field-${formId}`}
        type="email"
        name="mauticform[email]"
        placeholder="you@company.com"
        required
        autocomplete="email"
      />
      <button type="submit" class="button button-brand">{buttonLabel}</button>
    </form>
    <p class="email-signup-fine">No spam. Unsubscribe any time.</p>
  </div>
</div>

<script is:inline>
  document.querySelectorAll("form[data-mautic-source-form]").forEach((form) => {
    if (!(form instanceof HTMLFormElement)) return;

    const pageField = form.querySelector("[data-source-page]");
    if (pageField instanceof HTMLInputElement) {
      pageField.value = window.location.href;
    }

    const params = new URLSearchParams(window.location.search);
    form.querySelectorAll("[data-utm-field]").forEach((field) => {
      if (!(field instanceof HTMLInputElement)) return;
      const key = field.dataset.utmField;
      if (!key) return;
      field.value = params.get(key) || "";
    });
  });
</script>

<style>
  .email-signup-strip {
    border-radius: 0.75rem;
    padding: 2rem 1.5rem;
    margin: 2.5rem 0;
  }
  .email-signup-strip--light {
    background: var(--surface, #f9f9f7);
    border: 1px solid var(--line, #e8e5e0);
  }
  .email-signup-strip--dark {
    background: var(--ink, #1a1a18);
    color: #fff;
  }
  .email-signup-inner {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }
  .email-signup-copy { display: flex; flex-direction: column; gap: 0.25rem; }
  .email-signup-heading {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0;
    color: inherit;
  }
  .email-signup-sub {
    font-size: 0.9rem;
    margin: 0;
    color: var(--muted, #666);
  }
  .email-signup-strip--dark .email-signup-sub { color: #aaa; }

  .email-signup-form {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    width: 100%;
  }
  .email-signup-form input[type="email"] {
    flex: 1 1 220px;
    padding: 0.65rem 0.9rem;
    border: 1px solid var(--line, #e8e5e0);
    border-radius: 0.4rem;
    font-size: 0.95rem;
    background: #fff;
    color: var(--ink, #1a1a18);
    outline: none;
    min-width: 0;
  }
  .email-signup-strip--dark .email-signup-form input[type="email"] {
    background: #2a2a28;
    border-color: #444;
    color: #fff;
  }
  .email-signup-form input[type="email"]:focus {
    border-color: var(--accent, #f97316);
  }
  .email-signup-form .button {
    white-space: nowrap;
  }
  .email-signup-fine {
    font-size: 0.78rem;
    color: var(--muted, #888);
    margin: 0;
  }
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }
</style>
