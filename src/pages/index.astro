---
import { getCollection } from "astro:content";
import ProofLogos from "../components/ProofLogos.astro";
import SectionIntro from "../components/SectionIntro.astro";
import TestimonialsBlock from "../components/TestimonialsBlock.astro";
import VsAgencyBlock from "../components/VsAgencyBlock.astro";
import NotForBlock from "../components/NotForBlock.astro";
import DanielStory from "../components/DanielStory.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildFaqSchema } from "../lib/schema";
import { sortByOrder } from "../lib/utils";
import {
  buyerFaqs,
  headlineMetrics,
  leadMagnets,
  proofStandards,
  serviceSnapshots,
  siteConfig,
  testimonials
} from "../site";

const cases = sortByOrder(await getCollection("cases"));
const featuredCase = cases.find((item) => item.id === "diadia-health") ?? cases[0];
const otherCases = cases.filter((item) => item.id !== featuredCase?.id).slice(0, 4);
const systemSignals = [
  { label: "Constraint", value: "Founder-led pipeline", accent: "coral" },
  { label: "Build", value: "Acquisition operating system", accent: "violet" },
  { label: "Transfer", value: "Team-owned weekly cadence", accent: "teal" }
];
const rhythmSteps = [
  { label: "Monday", title: "Read the signal", body: "Pipeline, channel, conversion and sales notes become one decision view." },
  { label: "Midweek", title: "Ship the next move", body: "Campaigns, pages, outbound, content or offer tests move with a named owner." },
  { label: "Friday", title: "Scale, stop, fix", body: "Every week ends with a plain-English call on what deserves more attention." }
];
const heroProofStats = headlineMetrics.map((metric) => {
  const value = metric.value;

  if (value === "£10M+") return { ...metric, target: "10", prefix: "£", suffix: "M+", decimals: "0" };
  if (value === "4.93/5") return { ...metric, target: "4.93", prefix: "", suffix: "/5", decimals: "2" };

  return {
    ...metric,
    target: value.replace(/\D/g, "") || "0",
    prefix: "",
    suffix: value.includes("+") ? "+" : "",
    decimals: "0"
  };
});

function metricLead(result: string) {
  return result.match(/(?:[$£])?\d+(?:\.\d+)?%?\+?/)?.[0] ?? result.split(" ")[0];
}
---

<BaseLayout
  path="/"
  title="We Scale Startups | Growth Leadership for Predictable Acquisition"
  description="Growth leadership for startups that need predictable acquisition. Diagnose the bottleneck, build the growth system, and transfer it so revenue is not founder-dependent."
  schema={buildFaqSchema([...buyerFaqs])}
>
  <!-- HERO: interactive diagnosis and focused conversion path -->
  <section class="hero wss-hero-redesign" aria-label="We Scale Startups hero">
    <span class="brand-glyph" aria-hidden="true"><span>WSS</span></span>

    <div class="shell">
      <div class="hero-redesign-grid">
        <div>
          <p class="hero-rail" aria-label="Brand and positioning">
            <span class="mark">/&#47;&nbsp;WSS</span>
            <span class="pipe" aria-hidden="true">|</span>
            <span class="label">Fractional growth leadership</span>
            <span class="pipe" aria-hidden="true">|</span>
            <span class="label">Post-PMF startups</span>
          </p>

          <h1>
            <span class="beat">Name the bottleneck.</span>
            <span class="beat">Build the system.</span>
            <span class="beat"><span class="grad">Step out of the loop.</span></span>
          </h1>

          <p class="hero-thesis">
            Fractional growth leadership for post-PMF startups. We diagnose the constraint, build the operating system around it, and transfer the rhythm so revenue stops depending on founder heroics.
          </p>

          <ul class="hero-strikes" aria-label="Patterns we eliminate">
            <li><span class="lead">We end</span><span class="strike">founder-run pipeline</span></li>
            <li><span class="strike">pipeline that comes in waves</span></li>
            <li><span class="strike">spend without a scaling decision</span></li>
          </ul>

          <div class="hero-cta">
            <a class="btn btn-primary" href={siteConfig.bookingUrl} data-cta="hero-book">
              Book a 30-minute diagnostic <span class="arr" aria-hidden="true">→</span>
            </a>
            <a class="btn btn-ghost" href={siteConfig.scorecardUrl} data-cta="hero-scorecard">
              Take the 5-minute scorecard <span class="arrow" aria-hidden="true">→</span>
            </a>
          </div>
          <p class="hero-microcopy">Leave the call with your biggest growth bottleneck named in plain English.</p>

          <div class="founder-card" aria-label="Founder">
            <picture>
              <source srcset="/images/daniel-headshot-640.webp 640w, /images/daniel-headshot-960.webp 960w" sizes="54px" type="image/webp" />
              <img class="portrait" src="/images/daniel-headshot-960.webp" alt="Daniel Johnson" width="960" height="1003" loading="eager" decoding="async" fetchpriority="high" />
            </picture>
            <div class="who">
              <span class="top">Founder-led by <strong>Daniel Johnson</strong> · <span class="stars">★ 4.93 / 5</span></span>
              <span class="bottom">Speaker · Cambridge Judge · Imperial · Techstars · Google for Startups</span>
            </div>
          </div>
        </div>

        <aside class="diag" id="diag" aria-label="Sample growth diagnosis">
          <svg class="spark" viewBox="0 0 400 24" preserveAspectRatio="none" aria-hidden="true">
            <defs>
              <linearGradient id="sparkGrad" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#7b3eff" />
                <stop offset="55%" stop-color="#a445ff" />
                <stop offset="100%" stop-color="#c44dff" />
              </linearGradient>
            </defs>
            <text class="label" x="2" y="22">Pipeline (now)</text>
            <text class="label r" x="398" y="22">Pipeline (system)</text>
            <path class="wave" d="M0,12 L18,5 L36,17 L54,4 L72,16 L90,3 L108,18 L126,7 L144,19 L162,4 L180,17 L198,6 L216,18 L234,3 L252,16 L270,8 L288,19 L306,5 L324,17 L342,4 L360,15 L378,9 L400,12" />
            <path class="line" d="M0,18 C80,17 140,14 200,11 C260,8 320,6 400,3" />
          </svg>

          <header class="diag-head">
            <div>
              <p class="label"><span class="live" aria-hidden="true"></span> Constraint map</p>
              <h2 class="title">Growth Diagnosis</h2>
            </div>
            <span class="week">WK 01 / 12</span>
          </header>

          <div class="diag-prompt">
            <span class="tap"><span class="dot" aria-hidden="true"></span> Tap any constraint to diagnose yours</span>
            <button class="reset" type="button" data-reset>Reset</button>
          </div>

          <div class="diag-rows">
            <button class="row" type="button" data-key="positioning" aria-pressed="false">
              <span class="name">Positioning <span class="sub">Message-market fit</span></span>
              <span class="bar" style="--pct:32%;" aria-hidden="true"></span>
              <span class="verdict">Healthy</span>
            </button>
            <button class="row is-bottleneck" type="button" data-key="acquisition" aria-pressed="true">
              <span class="name">Acquisition <span class="sub">Channels &amp; pipeline</span></span>
              <span class="bar" style="--pct:88%;" aria-hidden="true"></span>
              <span class="verdict">Bottleneck</span>
            </button>
            <button class="row" type="button" data-key="conversion" aria-pressed="false">
              <span class="name">Conversion <span class="sub">Site &amp; offer</span></span>
              <span class="bar" style="--pct:54%;" aria-hidden="true"></span>
              <span class="verdict">Watch</span>
            </button>
            <button class="row" type="button" data-key="reporting" aria-pressed="false">
              <span class="name">Reporting <span class="sub">Decision view</span></span>
              <span class="bar" style="--pct:62%;" aria-hidden="true"></span>
              <span class="verdict">Watch</span>
            </button>
            <button class="row is-low" type="button" data-key="team" aria-pressed="false">
              <span class="name">Team ownership <span class="sub">Weekly cadence</span></span>
              <span class="bar" style="--pct:38%;" aria-hidden="true"></span>
              <span class="verdict">Healthy</span>
            </button>
          </div>

          <div class="diag-foot">
            <span class="ico" aria-hidden="true">!</span>
            <p class="copy-wrap" id="diagCopy">
              <span class="lbl">Diagnosed bottleneck</span>
              <strong>Acquisition channels operating in isolation.</strong>
              Paid, content and outbound are not reinforcing one another, so pipeline lands in waves.
            </p>
          </div>
        </aside>
      </div>

      <div class="proof-rail" aria-label="Selected proof">
        {heroProofStats.map((metric) => (
          <div class="stat">
            <strong data-target={metric.target} data-prefix={metric.prefix} data-suffix={metric.suffix} data-decimals={metric.decimals}>{metric.value}</strong>
            <span>{metric.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const hero = document.querySelector(".wss-hero-redesign");
      const diag = hero?.querySelector("#diag");
      if (!hero || !diag) return;

      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const spark = hero.querySelector(".spark");
      if (spark) requestAnimationFrame(() => spark.classList.add("is-animated"));

      const rows = [...diag.querySelectorAll(".row[data-key]")];
      const copyEl = diag.querySelector("#diagCopy");
      const resetBtn = diag.querySelector("[data-reset]");
      const scenarios = {
        positioning: {
          severity: { positioning: 88, acquisition: 46, conversion: 58, reporting: 42, team: 34 },
          head: "Message-market fit drift.",
          body: "Buyers do not pattern-match the offer to their actual problem, so acquisition gets harder upstream."
        },
        acquisition: {
          severity: { positioning: 32, acquisition: 88, conversion: 54, reporting: 62, team: 38 },
          head: "Acquisition channels operating in isolation.",
          body: "Paid, content and outbound are not reinforcing one another, so pipeline lands in waves."
        },
        conversion: {
          severity: { positioning: 38, acquisition: 48, conversion: 86, reporting: 55, team: 36 },
          head: "Site and offer leaking pipeline.",
          body: "The page asks for too much, too early. Qualified visitors do not become qualified conversations."
        },
        reporting: {
          severity: { positioning: 36, acquisition: 50, conversion: 48, reporting: 84, team: 42 },
          head: "No single decision view.",
          body: "Activity gets reported. What to scale, stop, or fix does not, so weeks pass without a sharp call."
        },
        team: {
          severity: { positioning: 40, acquisition: 52, conversion: 46, reporting: 48, team: 86 },
          head: "No internal owner running the rhythm.",
          body: "The system needs a hand on the wheel inside. Without one, founder hours fill the gap and growth stays personal."
        }
      };
      const verdict = (severity, isBottleneck) => isBottleneck ? "Bottleneck" : (severity < 42 ? "Healthy" : "Watch");

      function applyDiagnosis(key, fromUser = false) {
        const scenario = scenarios[key];
        if (!scenario || !copyEl) return;

        rows.forEach((row) => {
          const rowKey = row.dataset.key;
          const severity = scenario.severity[rowKey];
          const isBottleneck = rowKey === key;
          row.classList.toggle("is-bottleneck", isBottleneck);
          row.classList.toggle("is-low", !isBottleneck && severity < 42);
          row.setAttribute("aria-pressed", isBottleneck ? "true" : "false");
          row.querySelector(".bar")?.style.setProperty("--pct", `${severity}%`);
          const verdictEl = row.querySelector(".verdict");
          if (verdictEl) verdictEl.textContent = verdict(severity, isBottleneck);
        });

        copyEl.innerHTML = `<span class="lbl">Diagnosed bottleneck</span><strong>${scenario.head}</strong> ${scenario.body}`;
        if (fromUser) {
          diag.classList.add("is-touched", "is-pulsing");
          window.setTimeout(() => diag.classList.remove("is-pulsing"), 260);
        }
      }

      rows.forEach((row) => row.addEventListener("click", () => applyDiagnosis(row.dataset.key, true)));
      resetBtn?.addEventListener("click", () => {
        applyDiagnosis("acquisition", true);
        diag.classList.remove("is-touched");
      });

      const stats = hero.querySelectorAll(".proof-rail .stat strong[data-target]");
      const formatStat = (el) => {
        const target = Number.parseFloat(el.dataset.target || "0");
        const decimals = Number.parseInt(el.dataset.decimals || "0", 10);
        el.textContent = `${el.dataset.prefix || ""}${target.toFixed(decimals)}${el.dataset.suffix || ""}`;
      };
      const countUp = (el) => {
        const target = Number.parseFloat(el.dataset.target || "0");
        const decimals = Number.parseInt(el.dataset.decimals || "0", 10);
        const prefix = el.dataset.prefix || "";
        const suffix = el.dataset.suffix || "";
        const duration = 1300;
        const start = performance.now();

        function tick(now) {
          const progress = Math.min(1, (now - start) / duration);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = `${prefix}${(target * eased).toFixed(decimals)}${suffix}`;
          if (progress < 1) requestAnimationFrame(tick);
        }

        requestAnimationFrame(tick);
      };

      if (reduced || !("IntersectionObserver" in window)) {
        stats.forEach(formatStat);
      } else {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            countUp(entry.target);
            io.unobserve(entry.target);
          });
        }, { threshold: 0.4 });
        stats.forEach((stat) => io.observe(stat));
      }
    })();
  </script>

  <!-- HERO-LEVEL CREDIBILITY: logos + immediate proof -->
  <ProofLogos />

  <!-- TESTIMONIALS: hero-adjacent, before any nav-y content -->
  <TestimonialsBlock testimonials={testimonials} />

  <!-- CREATIVE SYSTEM VISUAL: shows the actual operating model, not decoration -->
  <section class="section creative-system-section">
    <div class="shell creative-system-grid">
      <div>
        <p class="eyebrow">What gets built</p>
        <h2>From founder-led effort to a visible growth machine.</h2>
        <p class="lead-copy">
          The work is tangible: a decision dashboard, sequenced experiments, weekly operating rhythm,
          and a transfer pack your team can run without Daniel in every loop.
        </p>
      </div>
      <div class="system-board" aria-label="Growth system visual showing diagnosis, build, and transfer">
        <div class="system-board-top">
          <span>Growth OS</span>
          <strong>Week 1 → Week 12</strong>
        </div>
        <div class="system-board-flow">
          {systemSignals.map((signal) => (
            <article class={`system-node system-node-${signal.accent}`}>
              <span>{signal.label}</span>
              <strong>{signal.value}</strong>
            </article>
          ))}
        </div>
        <div class="system-dashboard">
          <div>
            <span class="dashboard-label">Pipeline clarity</span>
            <strong>↑</strong>
          </div>
          <div>
            <span class="dashboard-label">Founder dependency</span>
            <strong>↓</strong>
          </div>
          <div>
            <span class="dashboard-label">Weekly decisions</span>
            <strong>live</strong>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES: stronger selector with commercial context -->
  <section class="section section-alt services-system-section" id="services">
    <div class="shell">
      <SectionIntro
        eyebrow="Services"
        title="Four ways to turn messy growth into a working system."
        body="Pick by constraint, not by menu. Each service has a clear role, timeline, and handoff."
      />

      <div class="service-selector">
        <aside class="service-selector-aside">
          <p class="eyebrow">How to choose</p>
          <h3>Start where the evidence is weakest.</h3>
          <p>
            If you cannot explain what is blocking acquisition, diagnose first. If the constraint is clear,
            move into a sprint, system build, or fractional leadership.
          </p>
          <a class="button button-dark" href="/services">Compare services</a>
        </aside>
        <div class="service-selector-list">
          {serviceSnapshots.map((service, idx) => (
            <a class:list={["service-selector-row", { "is-priority": idx === 0 }]} href={service.href}>
              <div class="service-selector-index">{String(idx + 1).padStart(2, "0")}</div>
              <div>
                <p class="card-kicker">{service.shortTitle}</p>
                <h3>{service.title}</h3>
                <p><strong>Best for:</strong> {service.bestFor}</p>
                <p><strong>What you get:</strong> {service.get}</p>
              </div>
              <div class="service-selector-meta">
                <span>{service.timeline}</span>
                <strong>{service.price}</strong>
                <em>{service.cta}</em>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- HIGH CONTRAST OPERATING RHYTHM -->
  <section class="section dark-rhythm-section">
    <div class="shell dark-rhythm-grid">
      <div>
        <p class="eyebrow">Operating rhythm</p>
        <h2>A weekly cadence for decisions, not another report nobody reads.</h2>
        <p>
          The system is simple on purpose: read signal, ship the next useful thing, then decide what to scale,
          stop, or fix. That is how growth becomes less founder-dependent.
        </p>
      </div>
      <div class="rhythm-flow" aria-label="Weekly growth operating rhythm">
        {rhythmSteps.map((step, idx) => (
          <article>
            <span>{step.label}</span>
            <strong>{step.title}</strong>
            <p>{step.body}</p>
            {idx < rhythmSteps.length - 1 && <b aria-hidden="true">→</b>}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- AI / SEARCH VISIBILITY VISUAL -->
  <section class="section ai-system-section">
    <div class="shell ai-system-grid">
      <div class="ai-system-map" aria-label="Search and AI visibility system">
        <div class="ai-system-node ai-system-node-main">
          <span>Entity</span>
          <strong>We Scale Startups</strong>
        </div>
        <div class="ai-system-lines">
          <span>Services</span>
          <span>Proof</span>
          <span>Industries</span>
          <span>Reports</span>
        </div>
        <div class="ai-system-output">
          <span>Readable by search and AI systems</span>
          <strong>Clear pages, internal links, schema, sitemap, FAQs</strong>
        </div>
      </div>
      <div>
        <p class="eyebrow">SEO and LLM retrieval</p>
        <h2>Make the growth expertise easy to crawl, quote, and trust.</h2>
        <p class="lead-copy">
          Search and AI systems need the same thing buyers need: clear pages, visible evidence,
          specific services, useful reports, and claims that are easy to verify.
        </p>
        <div class="hero-actions">
          <a class="button button-light" href="/reports">View reports</a>
          <a class="button button-light" href="/ai-growth-systems">AI growth systems</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CASE STUDY: P/A/R format, scannable in 5 seconds -->
  {featuredCase && (
    <section class="section" id="results">
      <div class="shell">
        <SectionIntro
          eyebrow="Case studies"
          title="Problem. Action. Result."
          body="Same format every time. Read the row. If it sounds like you, click through."
        />
        <div class="case-feature">
          <div class="case-visual" aria-hidden="true">
            <span>{featuredCase.data.client}</span>
            <span>{featuredCase.data.results[0]}</span>
            <strong>{featuredCase.data.client.slice(0, 1)}</strong>
          </div>
          <div class="case-copy">
            <p class="eyebrow">{featuredCase.data.sector}</p>
            <h3>{featuredCase.data.title}</h3>
            <div class="par-grid">
              <div class="par-row par-problem">
                <span class="par-label">Problem</span>
                <p>{featuredCase.data.challenge}</p>
              </div>
              <div class="par-row par-action">
                <span class="par-label">Action</span>
                <p>{featuredCase.data.work.slice(0, 3).join(". ")}.</p>
              </div>
              <div class="par-row par-result">
                <span class="par-label">Result</span>
                <p>{featuredCase.data.results.slice(0, 2).join("; ")}.</p>
              </div>
            </div>
            <div class="case-metrics">
              {featuredCase.data.results.slice(0, 3).map((result) => (
                <div>
                  <span class="stat-number">{metricLead(result)}</span>
                  <span class="stat-label">{result}</span>
                </div>
              ))}
            </div>
            <div class="hero-actions">
              <a class="button button-brand" href={`/case-studies/${featuredCase.id}`}>Read the full case</a>
              <a class="button button-light" href="/proof">All proof</a>
            </div>
          </div>
        </div>

        <!-- More cases, each in P/A/R micro-format -->
        <div class="grid-3 mt-8">
          {otherCases.map((item) => (
            <article class="case-mini">
              <p class="card-kicker">{item.data.sector}</p>
              <h4>{item.data.title}</h4>
              <dl class="par-mini">
                <dt>Problem</dt>
                <dd>{item.data.challenge}</dd>
                <dt>Action</dt>
                <dd>{item.data.work[0]}.</dd>
                <dt>Result</dt>
                <dd>{item.data.results[0]}{item.data.results[1] ? "; " + item.data.results[1] : ""}.</dd>
              </dl>
              <a class="card-link" href={`/case-studies/${item.id}`}>Read the case →</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- WSS vs AGENCY: explicit positioning -->
  <VsAgencyBlock />

  <!-- DANIEL: founder-led, why I built this -->
  <DanielStory />

  <!-- WHO THIS IS NOT FOR: filters bad-fit leads -->
  <NotForBlock />

  <section class="section section-alt">
    <div class="shell">
      <SectionIntro
        eyebrow="FAQ"
        title="What founders usually ask first."
        body="Short answers for teams deciding whether they need more execution, sharper diagnosis, or senior growth ownership."
      />
      <div class="grid-4">
        {buyerFaqs.map((faq) => (
          <article class="feature-card">
            <h3>{faq.question}</h3>
            <p>{faq.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- RESOURCES as lead capture (kept simple) -->
  <section class="section section-alt">
    <div class="shell">
      <SectionIntro
        eyebrow="Resources"
        title="Useful before you spend more."
        body="Lightweight, free, no demo required. Score yourself first — book a call when the bottleneck is visible."
      />
      <div class="grid-3">
        {leadMagnets.map((item) => (
          <a class:list={["feature-card", "lead-magnet-card", { "is-primary-lead": item.primary }]} href={item.href}>
            {item.primary && <span class="recommended-badge">Start here</span>}
            <p class="card-kicker">{item.audience}</p>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <span class="card-link">Get it →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PROOF STANDARDS -->
  <section class="section">
    <div class="shell">
      <SectionIntro
        eyebrow="How we present proof"
        title="No miracle claims, no anonymous wins."
      />
      <div class="grid-3">
        {proofStandards.map((item) => (
          <article class="feature-card compact-card">
            <p>{item}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA: single primary -->
  <section class="cta-band" id="cta">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Next step</p>
        <h2>Find the bottleneck first.</h2>
        <p>Bring the current growth picture. In 30 minutes you'll leave with a plain-English view of what's blocking pipeline — and which of the four engagements actually fits.</p>
      </div>
      <div class="hero-actions">
        <a class="button button-brand button-with-subcopy" href={siteConfig.bookingUrl} data-cta="final-book">
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
