---
import { getCollection } from "astro:content";
import ProofLogos from "../components/ProofLogos.astro";
import SectionIntro from "../components/SectionIntro.astro";
import TestimonialsBlock from "../components/TestimonialsBlock.astro";
import VsAgencyBlock from "../components/VsAgencyBlock.astro";
import NotForBlock from "../components/NotForBlock.astro";
import DanielStory from "../components/DanielStory.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { sortByOrder } from "../lib/utils";
import {
  headlineMetrics,
  leadMagnets,
  painSignals,
  proofStandards,
  serviceDecision,
  siteConfig,
  testimonials
} from "../site";

const services = sortByOrder(await getCollection("services"));
const cases = sortByOrder(await getCollection("cases"));
const featuredCase = cases[0];
const otherCases = cases.slice(1, 4);
const systemSignals = [
  { label: "Constraint", value: "Founder-led pipeline", accent: "coral" },
  { label: "Build", value: "Acquisition operating system", accent: "violet" },
  { label: "Transfer", value: "Team-owned weekly cadence", accent: "teal" }
];

function metricLead(result: string) {
  return result.match(/(?:[$£])?\d+(?:\.\d+)?%?\+?/)?.[0] ?? result.split(" ")[0];
}
---

<BaseLayout
  path="/"
  title="We Scale Startups | Predictable Acquisition for Post-PMF Startups"
  description="Predictable acquisition for post-PMF startups. We build the repeatable growth system so founders are no longer the bottleneck — clearer positioning, sharper acquisition, pipeline that runs without you."
>
  <!-- HERO: pain-led, single primary CTA -->
  <section class="hero hero-with-portrait">
    <div class="shell hero-grid">
      <div>
        <div class="hero-meta">
          <span>Fractional CMO · Growth diagnosis · Acquisition systems</span>
          <span>Post-PMF startups</span>
        </div>

        <h1>Your growth shouldn't depend on you.</h1>

        <p class="hero-copy">
          Predictable acquisition for post-PMF startups where:
        </p>

        <ul class="hero-pain-list">
          {painSignals.map((signal) => (
            <li>{signal}</li>
          ))}
        </ul>

        <p class="hero-fix">
          We build the repeatable growth system that fixes all three — so revenue keeps moving when you're not in every meeting.
        </p>

        <div class="hero-actions">
          <a class="button button-brand button-with-subcopy" href={siteConfig.bookingUrl} data-cta="hero-book">
            <span class="button-label">{siteConfig.bookingLabel}</span>
            <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
          </a>
        </div>

        <a class="hero-secondary" href={siteConfig.scorecardUrl} data-cta="hero-scorecard">
          <span>or take the 5-minute Growth Bottleneck Scorecard →</span>
        </a>

        <div class="hero-proof">
          {headlineMetrics.map((metric) => (
            <div>
              <strong>{metric.value}</strong>
              <span>{metric.label}</span>
            </div>
          ))}
        </div>
      </div>

      <aside class="hero-portrait-card" aria-label="Daniel Johnson, founder of We Scale Startups">
        <div class="founder-image">
          <picture>
            <source
              srcset="/images/daniel-headshot-640.webp 640w, /images/daniel-headshot-960.webp 960w"
              sizes="(max-width: 640px) 100vw, 38vw"
              type="image/webp"
            />
            <img src="/images/daniel-headshot-960.webp" alt="Daniel Johnson, founder of We Scale Startups" width="960" height="1003" loading="eager" decoding="async" fetchpriority="high" />
          </picture>
        </div>
        <div class="hero-offer">
          <p class="eyebrow">Founder-led</p>
          <p class="hero-offer-name"><strong>Daniel Johnson</strong></p>
          <p class="hero-offer-role">Two operator-side exits. £10M+ acquisition spend managed. Mentor to hundreds of founders through Google for Startups, Techstars, GrowthMentor.</p>
          <p class="hero-offer-rating">⭐ 5.0/5 MentorCruise · 4.93/5 across 219 founder reviews</p>
        </div>
      </aside>
    </div>
  </section>

  <!-- HERO-LEVEL CREDIBILITY: logos + immediate proof -->
  <ProofLogos />

  <!-- TESTIMONIALS: hero-adjacent, before any nav-y content -->
  <TestimonialsBlock testimonials={testimonials} />

  <!-- CREATIVE SYSTEM VISUAL: shows the actual operating model, not decoration -->
  <section class="section creative-system-section">
    <div class="shell creative-system-grid">
      <div>
        <p class="eyebrow">What gets built</p>
        <h2>From founder-led effort to a visible growth machine.</h2>
        <p class="lead-copy">
          The work is tangible: a decision dashboard, sequenced experiments, weekly operating rhythm,
          and a transfer pack your team can run without Daniel in every loop.
        </p>
      </div>
      <div class="system-board" aria-label="Growth system visual showing diagnosis, build, and transfer">
        <div class="system-board-top">
          <span>Growth OS</span>
          <strong>Week 1 → Week 12</strong>
        </div>
        <div class="system-board-flow">
          {systemSignals.map((signal) => (
            <article class={`system-node system-node-${signal.accent}`}>
              <span>{signal.label}</span>
              <strong>{signal.value}</strong>
            </article>
          ))}
        </div>
        <div class="system-dashboard">
          <div>
            <span class="dashboard-label">Pipeline clarity</span>
            <strong>↑</strong>
          </div>
          <div>
            <span class="dashboard-label">Founder dependency</span>
            <strong>↓</strong>
          </div>
          <div>
            <span class="dashboard-label">Weekly decisions</span>
            <strong>live</strong>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES: now with explicit decision layer -->
  <section class="section section-alt" id="services">
    <div class="shell">
      <SectionIntro
        eyebrow="Services"
        title="Pick the door that matches where you are."
        body="Four ways to work together. The decision layer below is not marketing — it's literally how we'd route you on a first call."
      />

      <!-- Decision routing — replaces the equal-weight 4-card grid -->
      <div class="decision-grid">
        {serviceDecision.map((item, idx) => (
          <a class="decision-row" href={item.href}>
            <div class="decision-condition">
              <p class="card-kicker">If</p>
              <p class="decision-text">{item.condition}</p>
            </div>
            <div class="decision-arrow" aria-hidden="true">→</div>
            <div class="decision-recommendation">
              <p class="card-kicker">Start with</p>
              <p class="decision-recommend-name">{item.recommendation}</p>
              <p class="decision-duration">{item.duration}</p>
            </div>
          </a>
        ))}
      </div>

      <!-- Detailed service cards: one is highlighted as primary recommendation -->
      <div class="grid-4 services-detailed">
        {services.map((service, idx) => (
          <a class:list={["service-card", "service-card-strong", { "is-recommended": idx === 0 }]} href={`/services/${service.id}`}>
            {idx === 0 && <span class="recommended-badge">Most founders start here</span>}
            <p class="card-kicker">{service.data.shortTitle}</p>
            <h3>{service.data.title}</h3>
            <p><strong>Who for:</strong> {service.data.audience}</p>
            <p><strong>What changes:</strong> {service.data.promise}</p>
            <span class="card-link">{service.data.cta}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CASE STUDY: P/A/R format, scannable in 5 seconds -->
  {featuredCase && (
    <section class="section" id="results">
      <div class="shell">
        <SectionIntro
          eyebrow="Case studies"
          title="Problem. Action. Result."
          body="Same format every time. Read the row. If it sounds like you, click through."
        />
        <div class="case-feature">
          <div class="case-visual" aria-hidden="true">
            <span>{featuredCase.data.client}</span>
            <span>{featuredCase.data.results[0]}</span>
            <strong>{featuredCase.data.client.slice(0, 1)}</strong>
          </div>
          <div class="case-copy">
            <p class="eyebrow">{featuredCase.data.sector}</p>
            <h3>{featuredCase.data.title}</h3>
            <div class="par-grid">
              <div class="par-row par-problem">
                <span class="par-label">Problem</span>
                <p>{featuredCase.data.challenge}</p>
              </div>
              <div class="par-row par-action">
                <span class="par-label">Action</span>
                <p>{featuredCase.data.work.slice(0, 3).join(". ")}.</p>
              </div>
              <div class="par-row par-result">
                <span class="par-label">Result</span>
                <p>{featuredCase.data.results.slice(0, 2).join("; ")}.</p>
              </div>
            </div>
            <div class="case-metrics">
              {featuredCase.data.results.slice(0, 3).map((result) => (
                <div>
                  <span class="stat-number">{metricLead(result)}</span>
                  <span class="stat-label">{result}</span>
                </div>
              ))}
            </div>
            <div class="hero-actions">
              <a class="button button-brand" href={`/case-studies/${featuredCase.id}`}>Read the full case</a>
              <a class="button button-light" href="/proof">All proof</a>
            </div>
          </div>
        </div>

        <!-- More cases, each in P/A/R micro-format -->
        <div class="grid-3 mt-8">
          {otherCases.map((item) => (
            <article class="case-mini">
              <p class="card-kicker">{item.data.sector}</p>
              <h4>{item.data.title}</h4>
              <dl class="par-mini">
                <dt>Problem</dt>
                <dd>{item.data.challenge}</dd>
                <dt>Action</dt>
                <dd>{item.data.work[0]}.</dd>
                <dt>Result</dt>
                <dd>{item.data.results[0]}{item.data.results[1] ? "; " + item.data.results[1] : ""}.</dd>
              </dl>
              <a class="card-link" href={`/case-studies/${item.id}`}>Read the case →</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- WSS vs AGENCY: explicit positioning -->
  <VsAgencyBlock />

  <!-- DANIEL: founder-led, why I built this -->
  <DanielStory />

  <!-- WHO THIS IS NOT FOR: filters bad-fit leads -->
  <NotForBlock />

  <!-- RESOURCES as lead capture (kept simple) -->
  <section class="section section-alt">
    <div class="shell">
      <SectionIntro
        eyebrow="Resources"
        title="Useful before you spend more."
        body="Lightweight, free, no demo required. Score yourself first — book a call when the bottleneck is visible."
      />
      <div class="grid-3">
        {leadMagnets.map((item) => (
          <a class:list={["feature-card", "lead-magnet-card", { "is-primary-lead": item.primary }]} href={item.href}>
            {item.primary && <span class="recommended-badge">Start here</span>}
            <p class="card-kicker">{item.audience}</p>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <span class="card-link">Get it →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PROOF STANDARDS -->
  <section class="section">
    <div class="shell">
      <SectionIntro
        eyebrow="How we present proof"
        title="No miracle claims, no anonymous wins."
      />
      <div class="grid-3">
        {proofStandards.map((item) => (
          <article class="feature-card compact-card">
            <p>{item}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA: single primary -->
  <section class="cta-band" id="cta">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Next step</p>
        <h2>Find the bottleneck first.</h2>
        <p>Bring the current growth picture. In 30 minutes you'll leave with a plain-English view of what's blocking pipeline — and which of the four engagements actually fits.</p>
      </div>
      <div class="hero-actions">
        <a class="button button-brand button-with-subcopy" href={siteConfig.bookingUrl} data-cta="final-book">
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
