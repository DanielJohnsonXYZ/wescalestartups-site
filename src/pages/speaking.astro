---
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema } from "../lib/schema";
import { siteConfig } from "../site";

const path = "/speaking";
const schema = [
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Speaking", path }
  ])
];
---

<BaseLayout
  path={path}
  title="Speaking | We Scale Startups"
  description="Daniel Johnson speaks on post-PMF GTM, acquisition systems, and founder-led growth — Cambridge Judge, Imperial, and Techstars."
  schema={schema}
  breadcrumbItems={[
    { name: "Home", path: "/" },
    { name: "Speaking", path }
  ]}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Speaking</p>
      <h1>Talks on growth systems, not growth hacks.</h1>
      <p class="lede">
        Practical sessions for founders and operators: naming the bottleneck, building an acquisition rhythm, and handing the system back to the team. For detailed topics and media assets, see Daniel&apos;s{" "}
        <a href={`${siteConfig.danielSite}/media-kit/`} rel="noopener noreferrer" target="_blank">media kit</a>.
      </p>
      <div class="hero-actions">
        <a class="button button-brand" href={`mailto:${siteConfig.email}?subject=Speaking%20enquiry`}>Email a speaking enquiry →</a>
        <a class="button button-light" href="/press">Company press kit →</a>
      </div>
    </div>
  </section>
</BaseLayout>
