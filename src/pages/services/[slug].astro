        </p>
        <a class="card-link" href={siteConfig.scorecardUrl} data-cta={`${service.id}-scorecard-followup`}>
          {siteConfig.scorecardLabel} →
        </a>
      </article>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Decision point</p>
        <h2>Bring the current bottleneck.</h2>
        <p>
          {siteConfig.bookingCallDurationPhrase}. We'll decide whether this is the right shape of help, what the first 30 days should focus on, and what should not be touched yet.
        </p>
      </div>
      <div class="hero-actions">
        <a
          class="button button-brand button-with-subcopy"
          href={siteConfig.bookingUrl}
