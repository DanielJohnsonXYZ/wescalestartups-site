---
import { navigation, siteConfig } from "../site";

const secondaryLinks = [
  { href: "/case-studies", label: "Case studies" },
  { href: "/fractional-cmo-vs-agency", label: "WSS vs agency" },
  { href: "/about", label: "About" },
  { href: "/industries", label: "Industries" },
  { href: "/resources", label: "Resources" },
  { href: "/press", label: "Company press kit" },
  { href: "/privacy", label: "Privacy" },
  { href: "/terms", label: "Terms" }
];
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <div>
      <img class="footer-logo" src="/images/logos/wss-logo.webp" alt="We Scale Startups" width="128" height="72" loading="lazy" decoding="async" />
      <p class="footer-summary">Predictable acquisition for post-PMF startups. We build the repeatable growth system so founders are no longer the bottleneck.</p>
      <a class="button button-brand" href={siteConfig.bookingUrl} data-cta="footer-book">{siteConfig.bookingLabel}</a>
    </div>
    <div>
      <h2>Explore</h2>
      <nav class="footer-links" aria-label="Footer navigation">
        {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
        {secondaryLinks.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </div>
    <div>
      <h2>Contact</h2>
      <div class="footer-links">
        <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
        <a href={`tel:${siteConfig.phone.replaceAll(" ", "")}`}>{siteConfig.phone}</a>
        <a href={siteConfig.bookingUrl} data-cta="footer-contact-book">Book a call</a>
        <a href={siteConfig.linkedin} rel="noopener" target="_blank">LinkedIn</a>
      </div>
    </div>
  </div>
  <div class="shell footer-bottom">
    <p>© 2026 We Scale Startups. All rights reserved.</p>
    <p>{siteConfig.address}</p>
  </div>
</footer>
