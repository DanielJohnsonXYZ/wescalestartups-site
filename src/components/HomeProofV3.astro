---
import { siteConfig } from "../site";
---

<section class="h3-proof" aria-label="Client work and programmes">
  <div class="h3-container">
    <div class="h3-frame">
      <div class="h3-proof-head">
        <div>
          <span class="h3-eyebrow-row">Current &amp; recent client work</span>
          <h2 class="h3-serif">
            Real engagements,<br /><em>not borrowed logo theatre.</em>
          </h2>
        </div>
        <div>
          <p class="desc">
            Each mark below is labelled — <strong>paid client work</strong> (case study) versus
            <strong>programmes &amp; lecturing</strong>, so nothing reads like an implied client when it isn't.
          </p>
          <div class="h3-legend-row">
            <span class="pip paid"><span class="sw"></span> Paid client engagement</span>
            <span class="pip prog"><span class="sw"></span> Programme · lecturing · review</span>
          </div>
        </div>
      </div>

      <div class="h3-clients">
        <a class="h3-ccard" href="/case-studies/ned" data-cta="proof-v3-ned">
          <span class="h3-badge paid">Paid</span>
          <div class="logo">
            <svg width="92" height="32" viewBox="0 0 92 32" aria-hidden="true">
              <text x="0" y="24" font-family="Fraunces Variable, Georgia, serif" font-size="26" font-weight="600" fill="#15140f" letter-spacing="-0.5">NED</text>
              <circle cx="64" cy="15" r="5" fill="#5e2bff"></circle>
              <circle cx="64" cy="15" r="2.2" fill="#fff"></circle>
            </svg>
          </div>
          <div class="name">Ned</div>
          <div class="tag">Fintech · Fractional CMO</div>
          <div class="outcome"><strong>500+ sign-ups</strong> from paid search in a single campaign.</div>
          <div class="read">Read the case study →</div>
        </a>

        <a class="h3-ccard" href="/case-studies/diadia-health" data-cta="proof-v3-diadia">
          <span class="h3-badge paid">Paid</span>
          <div class="logo">
            <svg width="120" height="32" viewBox="0 0 120 32" aria-hidden="true">
              <text x="0" y="23" font-family="Fraunces Variable, Georgia, serif" font-size="22" font-weight="500" fill="#15140f" letter-spacing="-0.3">Diadia</text>
              <text x="64" y="23" font-family="Fraunces Variable, Georgia, serif" font-size="22" font-weight="500" fill="#0f7a6c" letter-spacing="-0.3">Health</text>
            </svg>
          </div>
          <div class="name">Diadia Health</div>
          <div class="tag">AI · Precision medicine · Sprint</div>
          <div class="outcome">Marketing function <strong>built from zero</strong> in a 90-day sprint.</div>
          <div class="read">Read the case study →</div>
        </a>

        <a class="h3-ccard" href="/case-studies/equoo" data-cta="proof-v3-equoo">
          <span class="h3-badge paid">Paid</span>
          <div class="logo">
            <svg width="92" height="32" viewBox="0 0 92 32" aria-hidden="true">
              <text
                x="0"
                y="24"
                font-family="Fraunces Variable, Georgia, serif"
                font-style="italic"
                font-size="26"
                font-weight="500"
                fill="#15140f"
                letter-spacing="-0.4">eQuoo</text>
              <circle cx="68" cy="11" r="2.6" fill="#ff6a1a"></circle>
            </svg>
          </div>
          <div class="name">eQuoo</div>
          <div class="tag">Healthtech · Fractional CMO</div>
          <div class="outcome">Clearer <strong>acquisition narrative</strong> &amp; channel hierarchy.</div>
          <div class="read">Read the case study →</div>
        </a>

        <a class="h3-ccard" href="/case-studies/lessonsup" data-cta="proof-v3-lessonsup">
          <span class="h3-badge paid">Paid</span>
          <div class="logo">
            <svg width="118" height="32" viewBox="0 0 118 32" aria-hidden="true">
              <text x="0" y="23" font-family="Fraunces Variable, Georgia, serif" font-size="22" font-weight="500" fill="#15140f" letter-spacing="-0.2">Lessons</text>
              <text x="74" y="23" font-family="Fraunces Variable, Georgia, serif" font-size="22" font-weight="500" fill="#5e2bff" letter-spacing="-0.2">Up</text>
              <line x1="74" y1="27" x2="106" y2="27" stroke="#5e2bff" stroke-width="2" stroke-linecap="round"></line>
            </svg>
          </div>
          <div class="name">LessonsUp</div>
          <div class="tag">Edtech · Acquisition system build</div>
          <div class="outcome">Sharper <strong>message-market fit</strong> for new audience.</div>
          <div class="read">Read the case study →</div>
        </a>

        <a class="h3-ccard" href="/case-studies/nevly" data-cta="proof-v3-nevly">
          <span class="h3-badge paid">Paid</span>
          <div class="logo">
            <svg width="100" height="32" viewBox="0 0 100 32" aria-hidden="true">
              <text x="0" y="24" font-family="Geist, system-ui, sans-serif" font-size="22" font-weight="700" fill="#15140f" letter-spacing="3">N</text>
              <text x="20" y="24" font-family="Geist, system-ui, sans-serif" font-size="22" font-weight="700" fill="#0f7a6c" letter-spacing="3">EVLY</text>
            </svg>
          </div>
          <div class="name">Nevly</div>
          <div class="tag">Financial wellness · Sprint + CMO</div>
          <div class="outcome"><strong>Trust-led GTM</strong> foundations &amp; positioning.</div>
          <div class="read">Read the case study →</div>
        </a>
      </div>

      <div class="h3-divide"><span class="label">Programmes, lecturing &amp; reviews — context, not clients</span></div>

      <div class="h3-programmes">
        <a class="h3-pcard" href="https://startup.google.com/" rel="noopener noreferrer" target="_blank" data-cta="proof-v3-google">
          <span class="pico" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 48 48">
              <path fill="#EA4335" d="M24 9.5c3.4 0 6.4 1.2 8.8 3.5l6.5-6.5C35.5 2.8 30.1.5 24 .5 14.6.5 6.5 5.9 2.6 13.8l7.6 5.9C12.1 13.6 17.5 9.5 24 9.5z"></path>
              <path fill="#4285F4" d="M46.5 24.5c0-1.6-.1-3.1-.4-4.5H24v9h12.7c-.6 3-2.3 5.5-4.9 7.2l7.6 5.9c4.4-4.1 7.1-10.1 7.1-17.6z"></path>
              <path fill="#FBBC05" d="M10.2 28.6c-.5-1.3-.7-2.7-.7-4.1s.3-2.8.7-4.1l-7.6-5.9C.9 17.4 0 20.6 0 24s.9 6.6 2.6 9.4l7.6-4.8z"></path>
              <path fill="#34A853" d="M24 47.5c6.1 0 11.3-2 15-5.5l-7.6-5.9c-2.1 1.4-4.8 2.2-7.4 2.2-6.5 0-12-4.3-13.8-10.2l-7.6 5.9C6.5 42.1 14.6 47.5 24 47.5z"></path>
            </svg>
          </span>
          <div>
            <div class="pname">Google for Startups</div>
            <div class="psub">Mentor · startup programmes</div>
          </div>
          <span class="stat">Mentor</span>
        </a>

        <a class="h3-pcard" href="https://www.jbs.cam.ac.uk/" rel="noopener noreferrer" target="_blank" data-cta="proof-v3-cambridge">
          <span class="pico" aria-hidden="true">
            <svg width="22" height="26" viewBox="0 0 22 26">
              <path d="M11 1l9 4v8c0 6-4 10-9 12-5-2-9-6-9-12V5l9-4z" fill="#a3142e"></path>
              <path d="M11 6c2 1 4 1 6 1v6c0 4-3 7-6 8-3-1-6-4-6-8V7c2 0 4 0 6-1z" fill="#fff"></path>
              <circle cx="11" cy="11" r="2" fill="#a3142e"></circle>
            </svg>
          </span>
          <div>
            <div class="pname">Cambridge Judge</div>
            <div class="psub">Guest lecturing · entrepreneurship</div>
          </div>
          <span class="stat">Lecturer</span>
        </a>

        <a class="h3-pcard" href={siteConfig.growthMentor} rel="noopener noreferrer" target="_blank" data-cta="proof-v3-growthmentor">
          <span class="pico" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 22 22">
              <path d="M11 21V10" stroke="#5e2bff" stroke-width="2.4" stroke-linecap="round"></path>
              <path d="M11 11C7 11 4 8 4 4c4 0 7 3 7 7z" fill="#5e2bff"></path>
              <path d="M11 11c4 0 7-3 7-7-4 0-7 3-7 7z" fill="#9b3dff"></path>
            </svg>
          </span>
          <div>
            <div class="pname">GrowthMentor</div>
            <div class="psub">External reviews · 479+ founder sessions</div>
          </div>
          <span class="stat"><span class="star">★</span> 4.93</span>
        </a>
      </div>

      <div class="h3-quote">
        <div class="h3-qbox">
          <div class="h3-qav" aria-hidden="true">DJ</div>
          <p class="h3-qtxt">
            “Pipeline that compounds isn't a tactic — <em>it's a system the team owns</em>. My job is to name the bottleneck, install the system, and hand back the keys.”
          </p>
          <div class="h3-qmeta">
            <strong>{siteConfig.founderName}</strong>
            Founder · We Scale Startups
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
