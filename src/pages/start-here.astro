---
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema, buildFaqSchema } from "../lib/schema";
import { methodologyBrand, siteConfig } from "../site";

const startHereFaqs = [
  {
    question: "How long does the guided path take?",
    answer:
      "About 35 minutes if you follow the three-step path: scorecard, one proof read, then the diagnostic call. You can stop after step one or two if you are not ready to talk yet."
  },
  {
    question: "Do I have to book a call?",
    answer:
      "No. The scorecard, written diagnostic framework, and case studies are there so you can self-qualify. Book when the bottleneck is sharp enough that a conversation saves you a quarter of guessing."
  },
  {
    question: "Is We Scale Startups a marketing agency?",
    answer:
      "No. WSS works at diagnosis and system level: bottleneck, acquisition design, reporting cadence, and transfer. Agencies often execute inside that system once the constraint is clear — many teams use both."
  },
  {
    question: "Should I use this site or Daniel Johnson's personal site?",
    answer:
      "Start here on wescalestartups.com when you want the WSS engagement ladder: Growth Diagnosis, 90-Day Sprint, Acquisition System Build, or fractional CMO through the firm. Use danieljohnson.xyz when you are explicitly exploring a fractional CMO relationship with Daniel as the principal — the positioning overlaps, but the commercial path and contracts differ."
  }
];

const startHereSchema = [
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Start here", path: "/start-here" }
  ]),
  buildFaqSchema(startHereFaqs)
];
---

<BaseLayout
  path="/start-here"
  title="Start here · We Scale Startups"
  description="Entry path for post-PMF B2B SaaS and AI founders: match your stage to the WSS offer ladder (diagnosis → sprint → system → fractional), or self-qualify with the scorecard, quiz, and proof before booking a diagnostic."
  keywords="We Scale Startups onboarding, post-PMF founder guide, growth consultancy fit, which engagement first, startup growth decision tree"
  schema={startHereSchema}
  lastUpdated={siteConfig.lastUpdated}
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Start here</p>
      <h1>Pick your door. Same methodology: {methodologyBrand.tagline}</h1>
      <p class="lede">
        WSS works with <strong>post-PMF B2B SaaS and AI</strong> teams where growth still runs through the founder. If you are not sure
        which offer fits — scorecard, sprint, system build, or fractional bench — use this page as the router. No demos; book only when
        step three makes sense.
      </p>
      <p class="lede lede-tight">
        <strong>Company vs personal path:</strong> Engagements on this site run through We Scale Startups. If you are comparing a{' '}
        <strong>solo fractional CMO</strong> relationship with Daniel as principal, his parallel orientation is at{' '}
        <a href={`${siteConfig.danielSite}/start-here/`}>danieljohnson.xyz/start-here</a> — overlap in positioning, different contract path.
      </p>
    </div>
  </section>

  <!-- Route by commercial intent (Growth Hub: Start here as guided router) -->
  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">Which engagement?</p>
      <h2 class="route-section-h2">Pick the path that matches what you need right now.</h2>
      <p class="route-section-lede">
        Different founders arrive with different clarity. Self-route here, then confirm fit on the diagnostic. See the full ladder on{' '}
        <a href="/pricing">Pricing</a> and how delivery works on <a href="/how-it-works">How it works</a>.
      </p>
      <ul class="engagement-route-grid">
        <li>
          <a class="engagement-route-card" href={siteConfig.scorecardUrl}>
            <span class="engagement-route-label">I don't know what's blocking growth</span>
            <span class="engagement-route-action">{siteConfig.scorecardLabel} →</span>
          </a>
        </li>
        <li>
          <a class="engagement-route-card" href="/services/growth-diagnosis">
            <span class="engagement-route-label">I need a senior diagnosis first</span>
            <span class="engagement-route-action">Growth Diagnosis →</span>
          </a>
        </li>
        <li>
          <a class="engagement-route-card" href="/services/90-day-growth-sprint">
            <span class="engagement-route-label">I need execution this quarter</span>
            <span class="engagement-route-action">90-Day Growth Sprint →</span>
          </a>
        </li>
        <li>
          <a class="engagement-route-card" href="/services/acquisition-system-build">
            <span class="engagement-route-label">I need a connected acquisition system</span>
            <span class="engagement-route-action">Acquisition System Build →</span>
          </a>
        </li>
        <li>
          <a class="engagement-route-card" href="/services/fractional-cmo">
            <span class="engagement-route-label">I need ongoing senior leadership</span>
            <span class="engagement-route-action">Fractional CMO →</span>
          </a>
        </li>
      </ul>
    </div>
  </section>

  <!-- DECISION TREE -->
  <section class="section">
    <div class="shell">
      <p class="eyebrow">Decision tree</p>
      <h2>Pick the smallest commitment that answers your question right now.</h2>
      <p class="lede" style="max-width: 60ch; margin-top: 0.75rem;">
        Three honest reads — including one where we tell you not to hire us yet.
      </p>

      <div class="decision-grid">
        <article class="decision-card">
          <span class="decision-num">01</span>
          <h3>Unsure what's broken?</h3>
          <p>You suspect growth is stuck but the team can't agree what's blocking pipeline.</p>
          <p class="decision-action">Take the scorecard. 5 minutes. Score yourself across the 5 layers (positioning, acquisition, conversion, reporting, team).</p>
          <a class="button button-brand" href={siteConfig.scorecardUrl}>
            {siteConfig.scorecardLabel} →
          </a>
        </article>

        <article class="decision-card decision-card-primary">
          <span class="decision-num">02</span>
          <h3>Know the bottleneck but need senior judgement?</h3>
          <p>You can name the constraint but want a second opinion before spending more or hiring.</p>
          <p class="decision-action">
            {siteConfig.bookingLabel}. Bring the picture, leave with a plain-English read on what to do next.
          </p>
          <a
            class="button button-brand"
            href={siteConfig.bookingUrl}
            title={siteConfig.bookingCallReassurance}
          >
            {siteConfig.bookingLabel} →
          </a>
        </article>

        <article class="decision-card">
          <span class="decision-num">03</span>
          <h3>Need proof first?</h3>
          <p>You want to see how we work before talking to us.</p>
          <p class="decision-action">Read one case study that looks like your situation. Same Problem / Action / Result format every time.</p>
          <a class="button button-brand" href="/proof">See proof →</a>
        </article>
      </div>
    </div>
  </section>

  <!-- READING PATHS BY STAGE -->
  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">Reading paths by stage</p>
      <h2>The honest version: WSS isn't right for everyone.</h2>

      <div class="stage-grid">
        <article class="stage-card">
          <p class="card-kicker">Pre-PMF</p>
          <h3>You're still searching for the problem.</h3>
          <p>Some signal, no repeatable customer. Growth marketing won't fix it.</p>
          <p class="stage-action">
            <strong>Don't hire us yet.</strong> Spend the time on customer research and product. Come back when there's repeatable revenue and the constraint is acquisition, not the offer.
          </p>
          <a class="card-link" href="/insights">Read why pre-PMF teams shouldn't hire a fractional CMO →</a>
        </article>

        <article class="stage-card stage-card-fit">
          <p class="card-kicker">Post-PMF, founder still selling</p>
          <h3>Paying customers, real demand, but pipeline arrives in bursts.</h3>
          <p>Founder owns every revenue call. The team is running but nobody can confidently say what's working.</p>
          <p class="stage-action">
            <strong>Best fit.</strong> Start with a {siteConfig.bookingCallShort}. We'll diagnose the bottleneck and decide together whether a Sprint or Fractional CMO engagement makes sense.
          </p>
          <a class="card-link" href="/founder-led-growth">Read: founder-led growth constraint →</a>
          <a class="card-link" href={siteConfig.bookingUrl} title={siteConfig.bookingCallReassurance}>
            {siteConfig.bookingLabel} →
          </a>
        </article>

        <article class="stage-card">
          <p class="card-kicker">Post-PMF, scaling, plateau</p>
          <h3>£1m–£10m ARR, team in place, growth slowing or stalled.</h3>
          <p>Founder is the bottleneck on growth decisions. Channels are running but disconnected.</p>
          <p class="stage-action">
            <strong>Core fit.</strong> Read the Fractional CMO scope, then book the diagnostic. Most teams in this band start with the system build and add fractional leadership.
          </p>
          <a class="card-link" href="/services/fractional-cmo">See Fractional CMO scope →</a>
        </article>
      </div>
    </div>
  </section>

  <!-- 3-STEP PATH (kept from old version, refined) -->
  <section class="section">
    <div class="shell">
      <p class="eyebrow">If you want the short version</p>
      <h2>Three steps. No demos.</h2>

      <article class="start-step">
        <span class="start-step-num">01</span>
        <div>
          <h3>Score yourself in 5 minutes</h3>
          <p>
            The Growth Bottleneck Scorecard maps which of five constraints is blocking pipeline before you add another channel, hire, or agency.
          </p>
        </div>
        <a class="button button-brand" href={siteConfig.scorecardUrl}>{siteConfig.scorecardLabel}</a>
      </article>

      <article class="start-step">
        <span class="start-step-num">02</span>
        <div>
          <h3>Read one case study</h3>
          <p>Find the case that looks most like your situation. Same Problem / Action / Result format every time, readable in 60 seconds.</p>
        </div>
        <a class="button button-brand" href="/proof">See proof</a>
      </article>

      <article class="start-step">
        <span class="start-step-num">03</span>
        <div>
          <h3>{siteConfig.bookingLabel}</h3>
          <p>Bring the scorecard result and your current growth picture. You'll leave with a plain-English view of the bottleneck and which engagement (if any) actually fits.</p>
        </div>
        <a
          class="button button-brand button-with-subcopy"
          href={siteConfig.bookingUrl}
          title={siteConfig.bookingCallReassurance}
          data-cta="start-here-step3-book"
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
      </article>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">FAQ</p>
      <h2>Before you commit time.</h2>
      <div class="grid-3">
        {startHereFaqs.map((item) => (
          <article class="feature-card">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Already done step one?</p>
        <h2>Skip ahead and book the call.</h2>
        <p>Bring your scorecard result. We'll spend the {siteConfig.bookingCallDurationPhrase} on the bottleneck, not on intros.</p>
      </div>
      <div class="hero-actions">
        <a
          class="button button-brand button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="start-here-final"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="start-here-final-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .route-section-h2 {
    font-family: "Fraunces Variable", Georgia, serif;
    font-size: clamp(1.85rem, 3vw, 2.35rem);
    font-weight: 380;
    line-height: 1.1;
    margin: 0.35rem 0 0.75rem;
    color: var(--ink);
  }
  .route-section-lede {
    margin: 0 0 1.5rem;
    max-width: 60ch;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.55;
  }
  .lede-tight {
    max-width: 68ch;
    font-size: 0.92rem;
    margin-top: 1rem !important;
  }
  .lede-tight a {
    color: var(--accent);
    font-weight: 600;
  }
  .engagement-route-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .engagement-route-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1100px) {
    .engagement-route-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (min-width: 1400px) {
    .engagement-route-grid {
      grid-template-columns: repeat(6, 1fr);
    }
  }
  .engagement-route-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    height: 100%;
    padding: 1rem 1.05rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 0.85rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .engagement-route-card:hover {
    border-color: var(--accent);
    box-shadow: 0 8px 24px rgba(16, 13, 24, 0.06);
  }
  .engagement-route-label {
    font-size: 0.88rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--ink);
  }
  .engagement-route-action {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
  }

  .decision-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
    margin-top: 2rem;
  }
  @media (min-width: 880px) {
    .decision-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .decision-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 1.25rem;
    padding: 1.5rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .decision-card-primary {
    border-color: var(--accent);
    box-shadow: 0 14px 32px -18px color-mix(in srgb, var(--accent) 40%, transparent);
  }
  .decision-num {
    font-family: ui-monospace, "SF Mono", Menlo, monospace;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.1em;
  }
  .decision-card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--ink);
  }
  .decision-card p {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
  }
  .decision-action {
    color: var(--ink) !important;
    border-top: 1px solid var(--line);
    padding-top: 0.85rem;
    margin-top: 0.4rem !important;
  }
  .decision-card .button {
    margin-top: auto;
    align-self: start;
  }

  .stage-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
    margin-top: 2rem;
  }
  @media (min-width: 720px) { .stage-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1080px) { .stage-grid { grid-template-columns: repeat(3, 1fr); } }

  .stage-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 1rem;
    padding: 1.4rem 1.4rem;
  }
  .stage-card-fit { border-color: var(--accent); }
  .stage-card h3 {
    margin-top: 0.5rem;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: -0.02em;
  }
  .stage-card p {
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.55;
    margin-top: 0.5rem;
  }
  .stage-action {
    background: var(--surface-dim);
    border-radius: 0.6rem;
    padding: 0.7rem 0.85rem;
    margin-top: 0.85rem !important;
    color: var(--ink) !important;
  }
  .stage-action strong { color: var(--accent); }
</style>
