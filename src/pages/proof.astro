---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import TestimonialsBlock from "../components/TestimonialsBlock.astro";
import ProofLogos from "../components/ProofLogos.astro";
import { sortByOrder } from "../lib/utils";
import { buildBreadcrumbSchema, buildFaqSchema } from "../lib/schema";
import {
  canonicalProofMetrics,
  proofHubRelatedReading,
  proofResultsByType,
  proofStandards,
  revenueInfluencedNote,
  siteConfig,
  testimonials
} from "../site";

const proofFaqs = [
  {
    question: "How is proof structured on this page?",
    answer:
      "Cases use a consistent Problem / Action / Result format. Testimonials are grouped by engagement type where possible. Metrics are anchor signals, not vanity charts."
  },
  {
    question: "Can I verify outcomes independently?",
    answer:
      "Read the linked case studies, external review profiles, and press kit proof points. For media fact-checking, use the company press page or book a short clarification call."
  },
  {
    question: "Does proof guarantee future results?",
    answer:
      "No. Proof shows how diagnosis, system design, and transfer showed up in specific contexts. Your constraint map and team capacity still determine what is realistic."
  }
];

const proofSchema = [
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Proof", path: "/proof" }
  ]),
  buildFaqSchema(proofFaqs)
];

const cases = sortByOrder(await getCollection("cases"));
const caseById = Object.fromEntries(cases.map((c) => [c.id, c]));

const deliverableGallery = [
  {
    href: "/services/growth-diagnosis",
    title: "Diagnosis",
    caption: "Constraint map, evidence notes, 90-day memo",
    src: "/images/deliverables/diagnosis-preview.svg"
  },
  {
    href: "/services/90-day-growth-sprint",
    title: "Sprint",
    caption: "Experiment cards, weekly decisions, transfer checklist",
    src: "/images/deliverables/sprint-preview.svg"
  },
  {
    href: "/services/acquisition-system-build",
    title: "System build",
    caption: "Channel map, briefs, reporting view",
    src: "/images/deliverables/system-preview.svg"
  },
  {
    href: "/services/fractional-cmo",
    title: "Fractional CMO",
    caption: "Cadence, dashboard, decision log",
    src: "/images/deliverables/fcmo-preview.svg"
  }
] as const;
---

<BaseLayout
  path="/proof"
  title="Proof · We Scale Startups"
  description="Aggregated proof: case studies, testimonials, logos, and engagement metrics. One page so you can see everything in one scroll."
  keywords="We Scale Startups proof, B2B SaaS case studies, growth consultancy testimonials, fractional CMO results, startup acquisition outcomes"
  schema={proofSchema}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Proof</p>
      <h1>Real outcomes from post-PMF startups, not just strategy decks.</h1>
      <p class="lede">
        Cases, testimonials, logos, and metrics — all on one page.
        Same Problem / Action / Result format for every case. Same standard of evidence for every claim.
      </p>
    </div>
  </section>

  <!-- Hero metrics block -->
  <section class="section">
    <div class="shell">
      <div class="hero-proof" style="grid-template-columns: repeat(4, minmax(0, 1fr)); border-top: none; padding-top: 0;">
        {canonicalProofMetrics.map((metric) => (
          <div>
            <strong>{metric.value}</strong>
            <span>{metric.label}</span>
          </div>
        ))}
      </div>
      <p class="proof-metrics-footnote" style="margin-top: 1rem; max-width: 52ch; color: var(--muted); font-size: 0.88rem;">
        <strong>£18M+ revenue influenced:</strong> {revenueInfluencedNote}
      </p>
    </div>
  </section>

  <ProofLogos />

  <section class="section proof-creative-section">
    <div class="shell proof-creative-grid">
      <div>
        <p class="eyebrow">Proof map</p>
        <h2>Not a wall of claims. A trail of evidence.</h2>
        <p class="lead-copy">
          Each proof point is tied to where it lives in the system: diagnosis, channel build,
          test cadence, or transfer. That makes it easier to see whether the same work fits your team.
        </p>
      </div>
      <div class="proof-map" aria-label="Evidence map across the growth system">
        <article>
          <span>01</span>
          <strong>Problem</strong>
          <p>Founder dependency, weak channel clarity, or no clean reporting.</p>
        </article>
        <article>
          <span>02</span>
          <strong>Action</strong>
          <p>Diagnosis, channel rebuild, experiments, and operating cadence.</p>
        </article>
        <article>
          <span>03</span>
          <strong>Result</strong>
          <p>Pipeline conversations, better decisions, and a system the team owns.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Results by type</p>
      <h2 style="font-family:'Fraunces Variable',Georgia,serif;font-size:clamp(2rem,3.4vw,2.75rem);line-height:1.05;font-weight:380;margin:0.35rem 0 0.75rem;">
        Proof grouped by the kind of change founders look for.
      </h2>
      <p class="lede" style="max-width: 60ch; margin-bottom: 1.75rem;">
        Same case studies as below — organised so you can jump to the outcome that matches your constraint.
      </p>
      <div class="grid-2 proof-by-type-grid">
        {
          proofResultsByType.map((row) => {
            const c = caseById[row.caseId];
            if (!c) return null;
            return (
              <article class="feature-card proof-by-type-card">
                <p class="card-kicker">{row.label}</p>
                <p style="margin:0.5rem 0 0;color:var(--ink-2);line-height:1.55;font-size:0.95rem;">{row.summary}</p>
                <a class="card-link" href={`/case-studies/${row.caseId}`} data-cta={`proof-by-type-${row.caseId}`}>
                  Read: {c.data.client} →
                </a>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>

  <TestimonialsBlock testimonials={testimonials} title="What founders say." eyebrow="Testimonials" />

  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">Third-party validation</p>
      <h2 style="font-family:'Fraunces Variable',Georgia,serif;font-size:clamp(2.2rem,3.6vw,3rem);line-height:1.05;font-weight:380;margin:0.4rem 0 1.4rem;">Reviews that live off-site.</h2>
      <div class="validation-primary">
        <a class="feature-card validation-card" href={siteConfig.growthMentorReviews} rel="noreferrer" target="_blank">
          <p class="card-kicker">GrowthMentor</p>
          <h3>Read Daniel's founder mentoring reviews.</h3>
          <p>External review profile with founder feedback from GTM, positioning, paid acquisition, and growth sessions.</p>
          <span class="card-link">View GrowthMentor reviews →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Case grid in P/A/R format -->
  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">Case studies</p>
      <h2 style="font-family:'Fraunces Variable',Georgia,serif;font-size:clamp(2.4rem,4vw,3.6rem);line-height:1.05;font-weight:380;margin:0.4rem 0 2.2rem;">Same format, every time.</h2>
      <div class="grid-3">
        {cases.map((c) => (
          <article class="case-mini">
            <div class="case-scan-strip" aria-label="Case at a glance">
              <p class="case-scan-meta">
                <strong>{c.data.client}</strong>
                <span class="case-scan-sep" aria-hidden="true">·</span>
                <span>{c.data.sector}</span>
              </p>
              <p class="case-scan-narrative">
                <span class="case-scan-bit">{c.data.challenge}</span>
                <span class="case-scan-sep" aria-hidden="true">→</span>
                <span class="case-scan-bit">{c.data.work[0]}</span>
                <span class="case-scan-sep" aria-hidden="true">→</span>
                <span class="case-scan-bit">{c.data.results[0]}</span>
              </p>
            </div>
            <h4>{c.data.title}</h4>
            <dl class="par-mini">
              <dt>Problem</dt>
              <dd>{c.data.challenge}</dd>
              <dt>Action</dt>
              <dd>{c.data.work[0]}.</dd>
              <dt>Result</dt>
              <dd>{c.data.results[0]}{c.data.results[1] ? "; " + c.data.results[1] : ""}.</dd>
            </dl>
            <a class="card-link" href={`/case-studies/${c.id}`}>Read the case →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">Deliverable patterns</p>
      <h2>What the work looks like on the table — before it is tailored to you.</h2>
      <p class="lede" style="max-width: 62ch;">
        These are illustrative wireframes, not client screenshots. They show the shape of outputs: maps, memos, backlogs, and cadence — then we match your stack and bottleneck.
      </p>
      <div class="grid-2 proof-deliverable-gallery" style="margin-top: 1.5rem;">
        {deliverableGallery.map((item) => (
          <a class="proof-deliverable-card" href={item.href} data-cta={`proof-gallery-${item.href.split("/").pop()}`}>
            <img src={item.src} alt="" width="800" height="420" loading="lazy" decoding="async" />
            <div class="proof-deliverable-copy">
              <h3>{item.title}</h3>
              <p>{item.caption}</p>
              <span class="card-link">See the engagement →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">How we measure the work</p>
      <h2 style="font-family:'Fraunces Variable',Georgia,serif;font-size:clamp(2.2rem,3.6vw,3rem);line-height:1.05;font-weight:380;margin:0.4rem 0 2rem;">How we show proof.</h2>
      <div class="grid-3">
        {proofStandards.map((item) => (
          <article class="feature-card compact-card">
            <p>{item}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Related reading</p>
      <h2>More ways to verify and engage.</h2>
      <ul class="related-insights-list">
        {proofHubRelatedReading.map((item) => (
          <li>
            <a class="card-link" href={item.href}>
              {item.label} →
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">FAQ</p>
      <h2>How to read this proof page.</h2>
      <div class="grid-3">
        {proofFaqs.map((item) => (
          <article class="feature-card">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Ready to talk?</p>
        <h2>Find the bottleneck before you spend more.</h2>
        <p>
          Bring the current growth picture. In {siteConfig.bookingCallDurationPhrase} you'll leave with a plain-English view of what's blocking pipeline — and which engagement actually fits.
        </p>
      </div>
      <div class="hero-actions">
        <a class="button button-brand button-with-subcopy" href={siteConfig.bookingUrl} data-cta="proof-cta">
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="proof-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .validation-primary {
    max-width: 36rem;
  }
  .proof-deliverable-gallery {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) {
    .proof-deliverable-gallery {
      grid-template-columns: 1fr 1fr;
    }
  }
  .proof-deliverable-card {
    display: grid;
    gap: 0.85rem;
    padding: 1rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 1rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .proof-deliverable-card:hover {
    border-color: color-mix(in srgb, var(--accent) 35%, var(--line));
    box-shadow: 0 8px 28px -12px color-mix(in srgb, var(--accent) 25%, transparent);
  }
  .proof-deliverable-card img {
    width: 100%;
    height: auto;
    border-radius: 0.65rem;
    border: 1px solid var(--line);
    background: var(--paper);
  }
  .proof-deliverable-copy h3 {
    margin: 0 0 0.35rem;
    font-size: 1.05rem;
    letter-spacing: -0.02em;
  }
  .proof-deliverable-copy p {
    margin: 0 0 0.5rem;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }
</style>
