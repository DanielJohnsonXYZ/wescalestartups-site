---
import { getCollection } from "astro:content";
import SectionIntro from "../../components/SectionIntro.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sortByOrder } from "../../lib/utils";
import { siteConfig } from "../../site";

const allowedIndustries = ["saas-growth", "fintech", "healthtech", "edtech"];
const industries = sortByOrder(await getCollection("industries")).filter((industry) => allowedIndustries.includes(industry.id));
---

<BaseLayout
  title="Industries | We Scale Startups"
  description="Growth systems for SaaS, fintech, healthtech, and EdTech teams where trust and clarity matter."
  keywords="SaaS growth consultancy, fintech GTM, healthtech marketing, EdTech acquisition, B2B startup industries"
  path="/industries"
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Industries</p>
      <h1>Four markets where proof, trust, and timing matter.</h1>
      <p>The system adapts to the buyer, proof required, channel economics, and internal team capacity.</p>
      <div class="hero-actions">
        <a
          class="button button-dark button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="industries-index-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="industries-index-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
        <a class="button button-light" href="/services" data-cta="industries-index-services">Compare services</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionIntro eyebrow="Markets" title="Where the work fits best." />
      <div class="grid-3">
        {industries.map((industry) => (
          <a class="industry-card" href={`/industries/${industry.id}`}>
            <p class="card-kicker">Market</p>
            <h3>{industry.data.title}</h3>
            <p>{industry.data.description}</p>
            <span class="card-link">Explore {industry.data.title}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Market-specific diagnosis</p>
        <h2>Name the constraint before you scale spend.</h2>
        <p>
          In {siteConfig.bookingCallDurationPhrase}, we connect buyer problem, proof bar, channel economics, and team capacity into a practical next step.
        </p>
      </div>
      <div class="hero-actions">
        <a
          class="button button-brand button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="industries-index-final-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="industries-index-final-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
