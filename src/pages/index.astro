---
import { getCollection } from "astro:content";
import BrandLogoSlot from "../components/BrandLogoSlot.astro";
import ClientWorkStrip from "../components/ClientWorkStrip.astro";
import ProofLogos from "../components/ProofLogos.astro";
import SectionIntro from "../components/SectionIntro.astro";
import TestimonialsBlock from "../components/TestimonialsBlock.astro";
import VsAgencyBlock from "../components/VsAgencyBlock.astro";
import NotForBlock from "../components/NotForBlock.astro";
import DanielStory from "../components/DanielStory.astro";
import WhenToHireUs from "../components/WhenToHireUs.astro";
import GrowthScopeBar from "../components/GrowthScopeBar.astro";
import WssOperatingSystemDiagram from "../components/WssOperatingSystemDiagram.astro";
import HomeScorecardHook from "../components/HomeScorecardHook.astro";
import TldrCallout from "../components/TldrCallout.astro";
import WhoThisIsForIcp from "../components/WhoThisIsForIcp.astro";
import ServiceComparisonTable from "../components/ServiceComparisonTable.astro";
import CtaLadder from "../components/CtaLadder.astro";
import EmailSignup from "../components/EmailSignup.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildFaqSchema } from "../lib/schema";
import { sortByOrder } from "../lib/utils";
import {
  buyerFaqs,
  headlineMetrics,
  homeRelatedReading,
  methodologyBrand,
  proofStandards,
  siteConfig,
  testimonials
} from "../site";

const cases = sortByOrder(await getCollection("cases"));
const featuredCase = cases.find((item) => item.id === "diadia-health") ?? cases[0];
const otherCases = cases.filter((item) => item.id !== featuredCase?.id).slice(0, 4);

const heroProofStats = headlineMetrics.map((metric) => {
  const value = metric.value;
  if (value === "£6M+") return { ...metric, target: "6", prefix: "£", suffix: "M+", decimals: "0" };
  if (value === "479+") return { ...metric, target: "479", prefix: "", suffix: "+", decimals: "0" };
  if (value === "500+") return { ...metric, target: "500", prefix: "", suffix: "+", decimals: "0" };
  return {
    ...metric,
    target: value.replace(/\D/g, "") || "0",
    prefix: "",
    suffix: value.includes("+") ? "+" : "",
    decimals: "0"
  };
});

const featuredCaseLabel = featuredCase?.data.client ?? "";

const concreteDeliverables = [
  { label: "ICP & positioning", note: "One-line offer + segment map", href: "/gtm-strategy" },
  { label: "Landing & offer", note: "Tested headline + proof stack", href: "/services/acquisition-system-build" },
  { label: "Channel plan", note: "Where pipeline actually comes from", href: "/services/acquisition-system-build" },
  { label: "Experiment backlog", note: "ICE-scored, weekly cadence", href: "/services/90-day-growth-sprint" },
  { label: "Growth dashboard", note: "Pipeline → activity → decisions", href: "/how-it-works" },
  { label: "Decision cadence", note: "Mon read · Wed ship · Fri decide", href: "/how-it-works" },
  { label: "Team handover pack", note: "What to run after we leave", href: "/how-it-works" }
];

const homeTestimonials = testimonials.filter((t) => !/mentorcruise/i.test(t.company));

function metricLead(result: string) {
  return result.match(/(?:[$£])?\d+(?:\.\d+)?%?\+?/)?.[0] ?? result.split(" ")[0];
}
---

<BaseLayout path="/" title={siteConfig.title} description={siteConfig.description} schema={buildFaqSchema([...buyerFaqs])}>
  <!-- HERO -->
  <section class="hero wss-hero-redesign" aria-label="We Scale Startups hero">
    <span class="brand-glyph" aria-hidden="true"><span>WSS</span></span>

    <div class="shell">
      <div class="hero-redesign-grid">
        <div>
          <p class="hero-rail" aria-label="Brand and positioning">
            <span class="mark">/&#47;&nbsp;WSS</span>
            <span class="pipe" aria-hidden="true">|</span>
            <span class="label">Fractional CMO · Fractional growth leadership</span>
            <span class="pipe" aria-hidden="true">|</span>
            <span class="label">Post-PMF B2B SaaS &amp; AI startups</span>
          </p>

          <h1>
            <span class="beat">Predictable B2B SaaS pipeline.</span>
            <span class="beat"><span class="grad">Without a £150k CMO hire.</span></span>
          </h1>

          <p class="hero-firstperson">
            I'm <strong>Daniel Johnson</strong>, fractional CMO. I help post-PMF B2B SaaS and AI founders build GTM systems that compound — commercially on{" "}
            <a href={siteConfig.siteUrl}>{siteConfig.canonicalHost}</a>, and as a personal brand on{" "}
            <a href={siteConfig.danielSite} rel="me">{siteConfig.danielSite.replace(/^https:\/\//, "")}</a>.
          </p>

          <TldrCallout
            text="We Scale Startups helps post-PMF B2B SaaS and AI founders name the growth bottleneck, build a coherent acquisition system, and transfer the weekly rhythm — so pipeline compounds without every decision routing through the founder. Fractional CMO judgement plus delivery: diagnosis, sprints, system builds, and embedded leadership when the fit is right."
          />

          <p class="hero-plain">
            Senior fractional growth leadership for post-PMF AI and B2B SaaS founders. We diagnose the constraint, build the acquisition system around it, and transfer the weekly rhythm to your team.
            {" "}This work is organised as the <strong>{methodologyBrand.shortName}</strong>: {methodologyBrand.tagline}
          </p>

          <div class="hero-cta">
            <a
              class="btn btn-primary"
              href={siteConfig.bookingUrl}
              data-cta="hero-book"
              title={siteConfig.bookingCallReassurance}
            >
              {siteConfig.bookingLabel}
              <span class="arr" aria-hidden="true">→</span>
            </a>
            <a class="btn btn-ghost" href={siteConfig.scorecardUrl} data-cta="hero-scorecard">
              {siteConfig.scorecardLabel}
              <span class="arrow" aria-hidden="true">→</span>
            </a>
          </div>
          <p class="hero-microcopy">
            Leave the call with your biggest growth bottleneck named in plain English. No pitch — just a clear view of what's blocking pipeline.{" "}
            <a href="/contact" data-cta="hero-contact">Contact</a> if you prefer a written enquiry first.
          </p>

          <HomeScorecardHook />

          <div class="founder-card" aria-label="Founder">
            <picture>
              <source
                srcset="/images/daniel-headshot-640.webp 640w, /images/daniel-headshot-960.webp 960w"
                sizes="(min-width: 900px) 200px, (min-width: 640px) 120px, 88px"
                type="image/webp"
              />
              <img class="portrait" src="/images/daniel-headshot-960.webp" alt="Daniel Johnson" width="960" height="1003" loading="eager" decoding="async" fetchpriority="high" />
            </picture>
            <div class="who">
              <span class="top">Founder-led by <strong>Daniel Johnson</strong> · <span class="stars">★ 4.93 / 5</span></span>
              <span class="founder-track"
                >Former Head of Growth at Shoprocket. Operator-side exit with eQuoo (acquired). Now helping B2B SaaS and AI startups do the same.</span
              >
              <span class="bottom credential-logos" aria-label="Selected speaking and mentor affiliations">
                <a class="credential-logo" href="https://www.jbs.cam.ac.uk/" rel="noreferrer" target="_blank" aria-label="Cambridge Judge Business School">
                  <img src="/images/logos/cambridge.webp" alt="Cambridge Judge Business School" width="60" height="20" loading="lazy" decoding="async" />
                </a>
                <BrandLogoSlot
                  class="credential-logo"
                  label="Imperial College"
                  href="https://www.imperial.ac.uk/"
                />
                <BrandLogoSlot class="credential-logo" label="Techstars" href="https://www.techstars.com/" />
                <a class="credential-logo" href="https://startup.google.com/" rel="noreferrer" target="_blank" aria-label="Google for Startups Mentor">
                  <img src="/images/logos/google.webp" alt="Google for Startups Mentor" width="60" height="20" loading="lazy" decoding="async" />
                </a>
                <a class="credential-logo" href="https://app.growthmentor.com/mentors/daniel-johnson" rel="noreferrer" target="_blank" aria-label="GrowthMentor Top-rated Mentor">
                  <img src="/images/logos/growthmentor.png" alt="GrowthMentor Top-rated Mentor" width="60" height="20" loading="lazy" decoding="async" />
                </a>
              </span>
            </div>
          </div>
        </div>

  <!-- Interactive diagnosis element — reduced visual prominence -->
      <aside class="diag diag--compact" id="diag" aria-label="Sample growth diagnosis">
        <svg class="spark spark--small" viewBox="0 0 400 24" preserveAspectRatio="none" aria-hidden="true">
          <!-- Reduced size SVG -->
          <defs>
            <linearGradient id="sparkGrad" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="#7b3eff" />
              <stop offset="55%" stop-color="#a445ff" />
              <stop offset="100%" stop-color="#c44dff" />
            </linearGradient>
          </defs>
          <text class="label" x="2" y="22">Pipeline (now)</text>
          <text class="label r" x="398" y="22">Pipeline (system)</text>
          <path class="wave" d="M0,12 L18,5 L36,17 L54,4 L72,16 L90,3 L108,18 L126,7 L144,19 L162,4 L180,17 L198,6 L216,18 L234,3 L252,16 L270,8 L288,19 L306,5 L324,17 L342,4 L360,15 L378,9 L400,12" />
          <path class="line" d="M0,18 C80,17 140,14 200,11 C260,8 320,6 400,3" />
        </svg>

        <header class="diag-head diag-head--compact">
          <div>
            <p class="label"><span class="live" aria-hidden="true"></span> Constraint map</p>
            <h2 class="title title--small">Growth Diagnosis</h2>
          </div>
          <span class="week">WK 01 / 12</span>
        </header>

        <div class="diag-prompt diag-prompt--compact">
          <span class="tap"><span class="dot" aria-hidden="true"></span> Tap any constraint to diagnose yours</span>
          <button class="reset reset--small" type="button" data-reset>Reset</button>
        </div>

        <div class="diag-rows diag-rows--compact">
          <button class="row" type="button" data-key="positioning" aria-pressed="false">
            <span class="name">Positioning <span class="sub">Message-market fit</span></span>
            <span class="bar" style="--pct:32%;" aria-hidden="true"></span>
            <span class="verdict">Healthy</span>
          </button>
          <button class="row is-bottleneck" type="button" data-key="acquisition" aria-pressed="true">
            <span class="name">Acquisition <span class="sub">Channels &amp; pipeline</span></span>
            <span class="bar" style="--pct:88%;" aria-hidden="true"></span>
            <span class="verdict">Bottleneck</span>
          </button>
          <button class="row" type="button" data-key="conversion" aria-pressed="false">
            <span class="name">Conversion <span class="sub">Site &amp; offer</span></span>
            <span class="bar" style="--pct:54%;" aria-hidden="true"></span>
            <span class="verdict">Watch</span>
          </button>
          <button class="row" type="button" data-key="reporting" aria-pressed="false">
            <span class="name">Reporting <span class="sub">Decision view</span></span>
            <span class="bar" style="--pct:62%;" aria-hidden="true"></span>
            <span class="verdict">Watch</span>
          </button>
          <button class="row is-low" type="button" data-key="team" aria-pressed="false">
            <span class="name">Team ownership <span class="sub">Weekly cadence</span></span>
            <span class="bar" style="--pct:38%;" aria-hidden="true"></span>
            <span class="verdict">Healthy</span>
          </button>
        </div>

        <div class="diag-foot diag-foot--compact">
          <span class="ico" aria-hidden="true">!</span>
          <p class="copy-wrap" id="diagCopy">
            <span class="lbl">Diagnosed bottleneck</span>
            <strong>Acquisition channels operating in isolation.</strong>
            Paid, content and outbound are not reinforcing one another, so pipeline lands in waves.
          </p>
        </div>
      </aside>
      </div>

      <!-- Proof rail -->
      <div class="proof-rail" aria-label="Selected proof">
        {heroProofStats.map((metric) => (
          <div class="stat">
            <strong data-target={metric.target} data-prefix={metric.prefix} data-suffix={metric.suffix} data-decimals={metric.decimals}>{metric.value}</strong>
            <span>{metric.label}</span>
          </div>
        ))}
      </div>
      <p class="proof-rail-verify">
        <a href="https://app.growthmentor.com/mentors/daniel-johnson" rel="noreferrer" target="_blank" data-cta="hero-verify-growthmentor">
          Verify on GrowthMentor →
        </a>
      </p>
    </div>
  </section>

  <!-- Diagnostic interactivity script -->
  <script is:inline>
    (() => {
      const hero = document.querySelector(".wss-hero-redesign");
      const diag = hero?.querySelector("#diag");
      if (!hero || !diag) return;
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const spark = hero.querySelector(".spark");
      if (spark) requestAnimationFrame(() => spark.classList.add("is-animated"));
      const rows = [...diag.querySelectorAll(".row[data-key]")];
      const copyEl = diag.querySelector("#diagCopy");
      const resetBtn = diag.querySelector("[data-reset]");
      const scenarios = {
        positioning:{severity:{positioning:88,acquisition:46,conversion:58,reporting:42,team:34},head:"Message-market fit drift.",body:"Buyers do not pattern-match the offer to their actual problem, so acquisition gets harder upstream."},
        acquisition:{severity:{positioning:32,acquisition:88,conversion:54,reporting:62,team:38},head:"Acquisition channels operating in isolation.",body:"Paid, content and outbound are not reinforcing one another, so pipeline lands in waves."},
        conversion:{severity:{positioning:38,acquisition:48,conversion:86,reporting:55,team:36},head:"Site and offer leaking pipeline.",body:"The page asks for too much, too early. Qualified visitors do not become qualified conversations."},
        reporting:{severity:{positioning:36,acquisition:50,conversion:48,reporting:84,team:42},head:"No single decision view.",body:"Activity gets reported. What to scale, stop, or fix does not, so weeks pass without a sharp call."},
        team:{severity:{positioning:40,acquisition:52,conversion:46,reporting:48,team:86},head:"No internal owner running the rhythm.",body:"The system needs a hand on the wheel inside. Without one, founder hours fill the gap and growth stays personal."}
      };
      const verdict = (s, isB) => isB ? "Bottleneck" : (s < 42 ? "Healthy" : "Watch");
      function applyDiagnosis(key, fromUser=false) {
        const s = scenarios[key]; if (!s || !copyEl) return;
        rows.forEach((row) => {
          const k = row.dataset.key, sev = s.severity[k], isB = k === key;
          row.classList.toggle("is-bottleneck", isB);
          row.classList.toggle("is-low", !isB && sev < 42);
          row.setAttribute("aria-pressed", isB ? "true" : "false");
          row.querySelector(".bar")?.style.setProperty("--pct", `${sev}%`);
          const v = row.querySelector(".verdict"); if (v) v.textContent = verdict(sev, isB);
        });
        copyEl.innerHTML = `<span class="lbl">Diagnosed bottleneck</span><strong>${s.head}</strong> ${s.body}`;
        if (fromUser) { diag.classList.add("is-touched","is-pulsing"); window.setTimeout(()=>diag.classList.remove("is-pulsing"),260); }
      }
      rows.forEach((row) => row.addEventListener("click", () => applyDiagnosis(row.dataset.key, true)));
      resetBtn?.addEventListener("click", () => { applyDiagnosis("acquisition", true); diag.classList.remove("is-touched"); });
      const stats = hero.querySelectorAll(".proof-rail .stat strong[data-target]");
      const fmt = (el) => { const t = +el.dataset.target||0, d = +el.dataset.decimals||0; el.textContent = `${el.dataset.prefix||""}${t.toFixed(d)}${el.dataset.suffix||""}`; };
      const up = (el) => {
        const t = +el.dataset.target||0, d = +el.dataset.decimals||0, p = el.dataset.prefix||"", s = el.dataset.suffix||"", dur = 1300, start = performance.now();
        function tick(now) { const pr = Math.min(1, (now-start)/dur), e = 1-Math.pow(1-pr,3); el.textContent = `${p}${(t*e).toFixed(d)}${s}`; if (pr<1) requestAnimationFrame(tick); }
        requestAnimationFrame(tick);
      };
      if (reduced || !("IntersectionObserver" in window)) { stats.forEach(fmt); }
      else { const io = new IntersectionObserver((entries)=>{entries.forEach((en)=>{if(!en.isIntersecting)return;up(en.target);io.unobserve(en.target);});}, { threshold: 0.4 }); stats.forEach((s)=>io.observe(s)); }
    })();
  </script>

  <ClientWorkStrip />

  <ProofLogos />

  <!-- Credential logos — Google, Cambridge, etc. -->
  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">Credentials</p>
      <h2>Where Daniel is recognised and invited.</h2>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-6">
        <img src="/images/logos/google.webp" alt="Google for Startups — Mentor" class="h-10 w-auto" />
        <img src="/images/logos/cambridge.webp" alt="University of Cambridge — Visiting Lecturer" class="h-10 w-auto" />
        <BrandLogoSlot class="credential-strip-slot" label="Imperial College" href="https://www.imperial.ac.uk/" />
        <BrandLogoSlot class="credential-strip-slot" label="Techstars" href="https://www.techstars.com/" />
        <img src="/images/logos/growthmentor.png" alt="GrowthMentor — Top-rated Mentor" class="h-10 w-auto" />
      </div>
    </div>
  </section>

  <CtaLadder />

  <WhoThisIsForIcp />

  <WhenToHireUs />

  <NotForBlock />

  <!-- WHY NOW — traction hides weak systems -->
  <section class="section why-now-section">
    <div class="shell">
      <SectionIntro
        eyebrow="Why now"
        title="Early traction hides the cracks. Systems find them."
        body="Most post-PMF founders hit the same wall: growth worked when the founder ran it personally. Channels were tested. Some deals closed. Then the pattern broke — and no one could explain why."
      />
      <div class="why-now-grid">
        <article class="why-now-card">
          <span class="why-now-num">01</span>
          <h3>Founder-led growth stops scaling</h3>
          <p>What got you to £1M ARR was personal: your network, your pitch, your energy. That's not a system — it's a bottleneck wearing founder clothes.</p>
        </article>
        <article class="why-now-card">
          <span class="why-now-num">02</span>
          <h3>Channels work in isolation, not together</h3>
          <p>Paid tests ran. SEO was tried. Outbound happened. But none of it reinforced the others, so pipeline comes in waves instead of a rhythm.</p>
        </article>
        <article class="why-now-card">
          <span class="why-now-num">03</span>
          <h3>The team waits for direction</h3>
          <p>Without a clear constraint map and decision cadence, good people optimise locally. Spend goes up. Pipeline doesn't.</p>
        </article>
        <article class="why-now-card">
          <span class="why-now-num">04</span>
          <h3>The longer you wait, the harder it gets</h3>
          <p>Bad reporting habits compound. Positioning drifts. A weak system disguised as a growth problem gets more expensive to fix every quarter.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- EMAIL SIGNUP -->
  <section class="section section--tight">
    <div class="shell">
      <EmailSignup
        heading="Get the weekly growth note."
        subtext="One insight a week for post-PMF founders. What's blocking growth, what fixes it, and why."
        formId="homepage-mid"
      />
    </div>
  </section>

  <!-- PODCAST — compact trust asset (does not compete with primary book CTA) -->
  <section class="section section--tight section-alt" aria-labelledby="home-podcast-heading">
    <div class="shell home-podcast-compact">
      <p class="eyebrow">Podcast</p>
      <h2 id="home-podcast-heading">How Startups Win With AI</h2>
      <p class="home-podcast-lede">
        Smart conversations with founders and operators on how startups use AI to grow faster, save time, and build sharper companies. No tool hype. No generic founder chat — practical examples of what is working.
      </p>
      <div class="hero-actions home-podcast-actions">
        <a class="button button-brand" href="/podcast" data-cta="home-podcast-hub">
          Open the podcast hub →
        </a>
        <a class="button button-light" href="/podcast-guest-application" data-cta="home-podcast-guest">
          Suggest a guest →
        </a>
      </div>
    </div>
  </section>

  <!-- WHAT GETS BUILT -->
  <section class="section creative-system-section">
    <div class="shell">
      <SectionIntro
        eyebrow="What actually gets built"
        title="Turn scattered marketing into a weekly operating system."
        body="The work is tangible. By the end of the engagement, your team owns these artefacts and runs them every week without us in the loop."
      />
      <div class="deliverables-grid">
        {concreteDeliverables.map((d, i) => (
          <a class="deliverable-card deliverable-card-link" href={d.href} data-cta={`deliverable-${d.label.replace(/[^a-z0-9]+/gi, "-").toLowerCase()}`}>
            <span class="deliverable-num" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
            <h3>{d.label}</h3>
            <p>{d.note}</p>
            <span class="deliverable-more">Where this shows up →</span>
          </a>
        ))}
      </div>
      <p class="creative-system-foot">
        <a class="link-arrow" href="/how-it-works">See how the system gets built →</a>
      </p>
    </div>
  </section>

  <WssOperatingSystemDiagram />

  <GrowthScopeBar />

  <ServiceComparisonTable />

  <!-- OPERATING RHYTHM -->
  <section class="section dark-rhythm-section">
    <div class="shell dark-rhythm-grid">
      <div>
        <p class="eyebrow">Operating rhythm</p>
        <h2>Give your team a weekly cadence they can run without you.</h2>
        <p>
          Read the signal on Monday. Ship the next move midweek. Friday: scale, stop, or fix.
          That is how growth becomes less founder-dependent.
        </p>
      </div>
      <div class="rhythm-flow" aria-label="Weekly growth operating rhythm">
        <article><span>Monday</span><strong>Read the signal</strong><p>Pipeline, channel, conversion and sales notes become one decision view.</p><b aria-hidden="true">→</b></article>
        <article><span>Midweek</span><strong>Ship the next move</strong><p>Campaigns, pages, outbound, content or offer tests move with a named owner.</p><b aria-hidden="true">→</b></article>
        <article><span>Friday</span><strong>Scale, stop, fix</strong><p>Every week ends with a plain-English call on what deserves more attention.</p></article>
      </div>
    </div>
  </section>

  {featuredCase && (
    <section class="section" id="results">
      <div class="shell">
        <SectionIntro
          eyebrow="Case studies"
          title="Real engagements. Same Problem / Action / Result format every time."
          body="Read the row. If it sounds like you, click through."
        />
        <div class="case-feature">
          <div class="case-visual" aria-hidden="true">
            <span>{featuredCaseLabel}</span>
            <span>{featuredCase.data.results[0]}</span>
            <strong>{featuredCaseLabel.slice(0, 1)}</strong>
          </div>
          <div class="case-copy">
            <p class="eyebrow">{featuredCase.data.sector}</p>
            <h3>{featuredCaseLabel}: {featuredCase.data.title.replace(/^.*?:\s*/, '')}</h3>
            <div class="par-grid">
              <div class="par-row par-problem"><span class="par-label">Problem</span><p>{featuredCase.data.challenge}</p></div>
              <div class="par-row par-action"><span class="par-label">What we changed</span><p>{featuredCase.data.work.slice(0, 3).join(". ")}.</p></div>
              <div class="par-row par-result"><span class="par-label">Commercial result</span><p>{featuredCase.data.results.slice(0, 2).join("; ")}.</p></div>
            </div>
            <div class="case-metrics">
              {featuredCase.data.results.slice(0, 3).map((r) => (
                <div><span class="stat-number">{metricLead(r)}</span><span class="stat-label">{r}</span></div>
              ))}
            </div>
            <div class="hero-actions">
              <a class="button button-brand" href={`/case-studies/${featuredCase.id}`}>Read the full case</a>
              <a class="button button-light" href="/proof">All proof</a>
            </div>
          </div>
        </div>

        <div class="grid-3 mt-8">
          {otherCases.map((item) => (
            <article class="case-mini">
              <div class="case-scan-strip" aria-label="Case at a glance">
                <p class="case-scan-meta">
                  <strong>{item.data.client}</strong>
                  <span class="case-scan-sep" aria-hidden="true">·</span>
                  <span>{item.data.sector}</span>
                </p>
                <p class="case-scan-narrative">
                  <span class="case-scan-bit">{item.data.challenge}</span>
                  <span class="case-scan-sep" aria-hidden="true">→</span>
                  <span class="case-scan-bit">{item.data.work[0]}</span>
                  <span class="case-scan-sep" aria-hidden="true">→</span>
                  <span class="case-scan-bit">{item.data.results[0]}</span>
                </p>
              </div>
              <h4>{item.data.title}</h4>
              <dl class="par-mini">
                <dt>Problem</dt><dd>{item.data.challenge}</dd>
                <dt>What we changed</dt><dd>{item.data.work[0]}.</dd>
                <dt>Commercial result</dt><dd>{item.data.results[0]}{item.data.results[1] ? "; " + item.data.results[1] : ""}.</dd>
              </dl>
              <a class="card-link" href={`/case-studies/${item.id}`}>Read the case →</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <TestimonialsBlock testimonials={homeTestimonials} />

  <VsAgencyBlock />

  <DanielStory />

  <!-- FAQ -->
  <section class="section section-alt">
    <div class="shell">
      <SectionIntro
        eyebrow="FAQ"
        title="Know what to fix before you spend more."
        body="Short answers for teams deciding whether they need more execution, sharper diagnosis, or senior growth ownership."
      />
      <div class="home-faq-stack">
        {buyerFaqs.map((faq, index) => (
          <details class="home-faq-item" open={index === 0}>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- PROOF STANDARDS -->
  <section class="section">
    <div class="shell">
      <SectionIntro eyebrow="How we show proof" title="No miracle claims. No anonymous wins." />
      <div class="grid-3">
        {proofStandards.map((item) => (<article class="feature-card compact-card"><p>{item}</p></article>))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">Explore the site</p>
      <h2>Structured paths for buyers and search.</h2>
      <ul class="related-insights-list">
        {homeRelatedReading.map((item) => (
          <li>
            <a class="card-link" href={item.href}>
              {item.label} →
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="cta-band" id="cta">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Next step</p>
        <h2>Find the bottleneck before you spend more.</h2>
        <p>
          Bring the current growth picture. In {siteConfig.bookingCallDurationPhrase} you'll leave with a plain-English view of what's blocking pipeline — and which of the four engagements actually fits.
        </p>
      </div>
      <div class="hero-actions">
        <a
          class="button button-brand button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="final-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="final-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

