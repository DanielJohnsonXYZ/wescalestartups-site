---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema } from "../../lib/schema";
import { siteConfig, termsPageRelatedLinks } from "../../site";

const termsSchema = buildBreadcrumbSchema([
  { name: "Home", path: "/" },
  { name: "Terms", path: "/terms" }
]);
---

<BaseLayout
  title="Terms | We Scale Startups"
  description="Terms of use for wescalestartups.com: website access, intellectual property, enquiries, liability limits, and how to contact We Scale Startups. Aligned with our booking and scorecard flows."
  keywords="We Scale Startups terms of use, website terms"
  path="/terms"
  schema={termsSchema}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Terms</p>
      <h1>Useful boundaries for using this site.</h1>
      <p>The site exists to explain our growth strategy, research, acquisition, and operating-system work. It is not a substitute for tailored professional advice.</p>
    </div>
  </section>

  <section class="section">
    <div class="shell legal-grid">
      <aside class="detail-aside">
        <p><strong>Contact</strong></p>
        <p>{siteConfig.name}</p>
        <p>
          <!--email_off-->
          <a class="card-link" href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
          <!--/email_off-->
        </p>
      </aside>

      <div class="detail-body legal-body">
        <article class="content-block">
          <h2>Website content</h2>
          <p>The material on this site is provided for general information. Commercial outcomes depend on context, implementation quality, market conditions, and the underlying product or offer.</p>
        </article>

        <article class="content-block">
          <h2>Intellectual property</h2>
          <p>Site content, copy, design, frameworks, and visual assets belong to We Scale Startups or their respective owners unless otherwise stated. Do not copy or republish material without permission.</p>
        </article>

        <article class="content-block">
          <h2>External links</h2>
          <p>This site links to external services such as Calendly, LinkedIn, and client or ecosystem websites. We are not responsible for the content or privacy practices of third-party sites.</p>
        </article>

        <article class="content-block">
          <h2>Engagements</h2>
          <p>Any client work is governed by a separate proposal, statement of work, or agreement. Website language does not create a client relationship on its own.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">Site links</p>
      <h2>Related pages.</h2>
      <ul class="related-insights-list">
        {termsPageRelatedLinks.map((item) => (
          <li>
            <a class="card-link" href={item.href}>
              {item.label} →
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
