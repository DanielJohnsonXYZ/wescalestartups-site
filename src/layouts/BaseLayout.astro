---
import EasterEgg from "../components/EasterEgg.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { buildOrganizationSchema, buildPersonSchema, buildWebSiteSchema } from "../lib/schema";
import { absoluteUrl, normalizePath } from "../lib/utils";
import { siteConfig } from "../site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  /** Optional extra discoverability meta for hub pages (insights, resources, etc.). */
  keywords?: string;
  path?: string;
  ogImage?: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  lastUpdated?: string | false;
  /** Override default robots meta (e.g. noindex for utility pages). */
  metaRobots?: string;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  keywords,
  path = Astro.url.pathname,
  ogImage = siteConfig.ogImage,
  schema = [],
  lastUpdated = siteConfig.lastUpdated,
  metaRobots = "index,follow,max-image-preview:large"
} = Astro.props;

const currentPath = normalizePath(path);
const canonical = absoluteUrl(currentPath);
const imageUrl = absoluteUrl(ogImage);
const pageSchemas = Array.isArray(schema) ? schema : [schema];
const allSchemas = [buildPersonSchema(), buildOrganizationSchema(), buildWebSiteSchema(), ...pageSchemas].filter(Boolean);
const serializedSchemas = allSchemas.map((item) => JSON.stringify(item).replace(/</g, "\\u003c"));
// Standard GTM bootstrap (immediate) — same pattern as Tag Manager install instructions.
const gtmScript = `(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','${siteConfig.gtmId}');`;
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Google Tag Manager — high in <head> per install instructions (GTM loads before other head assets). -->
    <script is:inline set:html={gtmScript} />
    <!-- End Google Tag Manager -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="robots" content={metaRobots} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {currentPath === "/" && (
      <>
        <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM / agent summary (plain text)" />
        <link rel="alternate" type="text/markdown" href="/llms-full.txt" title="Extended context (markdown)" />
        <link rel="alternate" type="text/markdown" href="/markdown/home.md" title="Homepage as markdown" />
        <link rel="api-catalog" href="/.well-known/api-catalog" />
        <link rel="alternate" type="application/json" href="/.well-known/agent-skills/index.json" title="Agent skills index" />
      </>
    )}

    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={siteConfig.twitterHandle} />
    <meta name="twitter:creator" content={siteConfig.twitterHandle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    <meta name="ai:summary" content={description} />
    <meta name="ai:role" content="Growth consultancy and fractional CMO support for post-PMF startups" />
    <meta name="ai:serves" content="Post-PMF SaaS, AI, fintech, healthtech, ecommerce, and education startups" />
    <meta name="ai:contact" content={`${siteConfig.siteUrl}${siteConfig.bookingUrl}`} />

    {serializedSchemas.map((json) => <script is:inline type="application/ld+json" set:html={json} />)}
    <script is:inline>
      document.addEventListener("click", (event) => {
        const target = event.target;
        const link = target instanceof Element ? target.closest("a") : null;
        if (!link) return;

        const label = link.dataset.cta || link.textContent?.trim();
        if (!label) return;

        const href = link.href || "";
        const isCalendly = href.includes("calendly.com");
        const isScorecard = href.includes("growth-bottleneck-scorecard");
        const isPricing = href.includes("/pricing") || link.closest("[data-pricing-link]");
        const isResource = href.includes("/resources") || link.closest("[data-resource-link]");
        const isOutbound = href.startsWith("http") && !href.includes(window.location.hostname);

        let eventName = "cta_click";
        if (isCalendly) eventName = "calendly_click";
        else if (isScorecard) eventName = "scorecard_start";
        else if (isPricing) eventName = "pricing_click";
        else if (isResource) eventName = "resource_click";
        else if (isOutbound) eventName = "outbound_link_click";

        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: eventName,
          cta_label: label,
          cta_href: href,
          page_path: window.location.pathname
        });
      });

      document.addEventListener("submit", (event) => {
        const form = event.target;
        if (!(form instanceof HTMLFormElement)) return;
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: "form_submit",
          form_id: form.id || form.name || "unknown",
          form_action: form.action || "unknown",
          page_path: window.location.pathname
        });
      });

      // Track resource downloads (PDF, CSV, etc.)
      document.addEventListener("click", (event) => {
        const target = event.target;
        const link = target instanceof Element ? target.closest("a[download]") : null;
        if (!link) return;
        const href = link.href || "";
        const label = link.dataset.cta || link.textContent?.trim() || "resource_download";
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: "resource_download",
          download_url: href,
          download_label: label,
          page_path: window.location.pathname
        });
      });
    </script>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) — immediately after <body> per GTM install instructions. -->
    <noscript>
      <iframe
        height="0"
        src={`https://www.googletagmanager.com/ns.html?id=${siteConfig.gtmId}`}
        style="display:none;visibility:hidden"
        width="0"
      />
    </noscript>
    <!-- End Google Tag Manager (noscript) -->
    <a class="skip-link" href="#main-content">Skip to content</a>
    <SiteHeader currentPath={currentPath} />
    <main id="main-content">
      <slot />
      {lastUpdated && (
        <section class="last-updated-band" aria-label="Page freshness">
          <div class="shell">
            <p>Last updated: {lastUpdated}</p>
          </div>
        </section>
      )}
    </main>
    <SiteFooter />
    <EasterEgg />
  </body>
</html>
