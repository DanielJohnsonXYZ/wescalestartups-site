---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../site";

const target = siteConfig.scorecardUrl;
---

<BaseLayout
  title={`${siteConfig.scorecardName} | We Scale Startups`}
  description={siteConfig.scorecardTagline}
  path="/quiz"
  metaRobots="noindex,follow"
>
  <script is:inline define:vars={{ target }}>
    window.location.replace(target);
  </script>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Redirecting</p>
      <h1>{siteConfig.scorecardName}</h1>
      <p>{siteConfig.scorecardTagline}</p>
      <div class="hero-actions">
        <a class="button button-brand" href={target}>{siteConfig.scorecardLabel} →</a>
      </div>
    </div>
  </section>
</BaseLayout>
