---
import { getCollection } from "astro:content";
import HomeProofV3 from "../components/HomeProofV3.astro";
import SectionIntro from "../components/SectionIntro.astro";
import TestimonialsBlock from "../components/TestimonialsBlock.astro";
import VsAgencyBlock from "../components/VsAgencyBlock.astro";
import NotForBlock from "../components/NotForBlock.astro";
import DanielStory from "../components/DanielStory.astro";
import WhoThisIsForIcp from "../components/WhoThisIsForIcp.astro";
import ServiceComparisonTable from "../components/ServiceComparisonTable.astro";
import CtaLadder from "../components/CtaLadder.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/home-hero-v3.css";
import "../styles/home-v6.css";
import "../styles/home-refresh.css";
import { buildFaqSchema } from "../lib/schema";
import { sortByOrder } from "../lib/utils";
import {
  buyerFaqs,
  canonicalProofMetrics,
  first30Days,
  proofStandards,
  siteConfig,
  testimonials
} from "../site";

const cases = sortByOrder(await getCollection("cases"));
const featuredCase = cases.find((item) => item.id === "ned") ?? cases[0];
const otherCases = cases.filter((item) => item.id !== featuredCase?.id).slice(0, 4);

const featuredCaseLabel = featuredCase?.data.client ?? "";

const homeTestimonials = [
  ...testimonials.filter((t) => t.category === "paid-client"),
  ...testimonials.filter((t) => t.category === "advisory")
].slice(0, 8);

function metricLead(result: string) {
  return result.match(/(?:[$£])?\d+(?:\.\d+)?%?\+?/)?.[0] ?? result.split(" ")[0];
}

// "Not a founder?" routing — investors / corporate / operators
const subAudiences = [
  {
    title: "Investors & funds.",
    body: "Diagnose growth across a portfolio in two weeks. Same framework, applied across companies.",
    href: "/resources/vc-portfolio-growth-diagnosis",
    label: "VC Portfolio Diagnosis"
  },
  {
    title: "Corporate & accelerator partners.",
    body: "Workshops, keynote talks, and programme advisory for cohorts and innovation teams.",
    href: "/speaking",
    label: "Speaking & workshops"
  },
  {
    title: "Operators, advisors & referrers.",
    body: "Refer a founder, come on the podcast, or partner on a deal. Drop a line.",
    href: "/contact",
    label: "Get in touch"
  }
];

// What you'll leave with after the 20-min call
const leaveWith = [
  {
    n: "01",
    h: "The constraint, named.",
    p: "Positioning, acquisition, conversion, reporting, or team ownership — which one is binding pipeline right now."
  },
  {
    n: "02",
    h: "The next move.",
    p: "What you'd test, build, or stop in the next 30 days to move that constraint."
  },
  {
    n: "03",
    h: "An honest read on fit.",
    p: "Whether WSS is the right call, or whether an agency, a hire, or no-one is the better answer."
  },
  {
    n: "04",
    h: "The plain-English version.",
    p: "No frameworks, no jargon, no slides. A direct conversation."
  }
];
---

<BaseLayout
  path="/"
  title={siteConfig.title}
  description={siteConfig.description}
  schema={buildFaqSchema([...buyerFaqs])}
  showSiteHeader={true}
  bodyClass="page-home-v3"
  announcementVariant="brand"
  announcementText={`New resource: ${siteConfig.scorecardName}. ${siteConfig.scorecardTagline}`}
  announcementHref={siteConfig.scorecardUrl}
  announcementLinkText={`${siteConfig.scorecardLabel} →`}
>
  <!-- Utility bar — live operator status -->
  <div class="hv6-util">
    <div class="hv6-util-inner">
      <span class="hv6-status"><span class="hv6-pulse" aria-hidden="true"></span> 2 client slots open · Q3 2026</span>
      <span class="hv6-util-sep" aria-hidden="true">·</span>
      <span>Operating from London — UK / EU / US hours</span>
      <span class="hv6-util-right">
        <a href="/podcast">Podcast</a>
        <a href="/insights">Insights</a>
        <a href="/newsletter">Newsletter</a>
      </span>
    </div>
  </div>

  <section class="hv6-hero" aria-label="We Scale Startups hero">
    <div class="hv6-aurora-2" aria-hidden="true"></div>
    <div class="h3-container">

      <div class="hv6-grid">

        <div class="hv6-col-main">
          <div class="hv6-eyebrow">
            <span class="dot" aria-hidden="true"></span> Fractional CMO · Post-PMF B2B SaaS &amp; AI
          </div>

          <h1 class="hv6-h1">
            Your pipeline shouldn't depend on <span class="grad">you running</span> it.
          </h1>

          <div class="hv6-byline">
            <span class="av" aria-hidden="true">DJ</span>
            <span class="who">{siteConfig.founderName}</span>
            <span class="sep" aria-hidden="true"></span>
            <span>Fractional CMO</span>
            <span class="sep" aria-hidden="true"></span>
            <a href={siteConfig.growthMentor} rel="noopener noreferrer" target="_blank"
              ><span class="star">★</span>4.93 · GrowthMentor</a
            >
            <span class="sep" aria-hidden="true"></span>
            <span>479+ founder sessions</span>
          </div>

          <p class="hv6-lede">
            We install the acquisition system your team can run <strong>without the founder in every decision</strong> — in 90 days, for the cost of a senior hire's first quarter.
          </p>

          <nav class="hv6-ladder" aria-label="Engagement ladder">
            <a href="/services/growth-diagnosis" data-cta="hero-shape-diagnose"><span class="n">01</span> Diagnose</a>
            <a href="/services/90-day-growth-sprint" data-cta="hero-shape-sprint"><span class="n">02</span> Sprint</a>
            <a href="/services/acquisition-system-build" data-cta="hero-shape-build"><span class="n">03</span> Build</a>
            <a href="/services/fractional-cmo" data-cta="hero-shape-embed"><span class="n">04</span> Embed</a>
          </nav>

          <div class="hv6-cta-row">
            <a class="hv6-btn hv6-btn-primary" href={siteConfig.bookingUrl} data-cta="hero-book" title={siteConfig.bookingCallReassurance}>
              {siteConfig.bookingLabel} <span class="arrow" aria-hidden="true">→</span>
            </a>
            <a class="hv6-btn hv6-btn-ghost" href={siteConfig.scorecardUrl} data-cta="hero-scorecard">
              Take the 5-min scorecard <span class="arrow" aria-hidden="true">→</span>
            </a>
          </div>
        </div>

        <aside class="hv6-dash" aria-label="Live growth diagnostic sample">
          <div class="hv6-dash-head">
            <div class="hv6-dash-title"><span class="live-dot" aria-hidden="true"></span> Growth Diagnostic — Live Sample</div>
            <div class="hv6-dash-meta">WK 01 / 12</div>
          </div>

          <div class="hv6-dash-intro">
            <h3 class="hv6-dash-h">What 20 minutes looks like.</h3>
            <p class="hv6-dash-p">A real diagnosis from a recent call. Yours follows the same shape, with your numbers.</p>
          </div>

          <div class="hv6-kpis">
            <div class="hv6-kpi">
              <div class="l">Pipeline today</div>
              <div class="v">£42k<span class="unit">/wk</span></div>
              <div class="d flat">— flat 6 wks</div>
            </div>
            <div class="hv6-kpi">
              <div class="l">12-wk projection</div>
              <div class="v">£128k<span class="unit">/wk</span></div>
              <div class="d up">▲ 3.0× compounding</div>
            </div>
            <div class="hv6-kpi">
              <div class="l">Bottleneck</div>
              <div class="v" style="color:var(--h3-violet-deep)">Acquisition</div>
              <div class="d acc">88% confidence</div>
            </div>
          </div>

          <div class="hv6-chart-wrap">
            <div class="hv6-chart-legend">
              <span class="k flat">Pipeline · now</span>
              <span class="k live">Pipeline · system</span>
            </div>
            <svg class="hv6-spark" id="hv6-hero-spark" viewBox="0 0 600 150" preserveAspectRatio="none" aria-hidden="true">
              <defs>
                <linearGradient id="hv6-g1" x1="0" x2="1" y1="0" y2="0">
                  <stop offset="0%"   stop-color="#a78bfa"></stop>
                  <stop offset="50%"  stop-color="#7c3aed"></stop>
                  <stop offset="100%" stop-color="#6d28d9"></stop>
                </linearGradient>
                <linearGradient id="hv6-g1f" x1="0" x2="0" y1="0" y2="1">
                  <stop offset="0%" stop-color="#7c3aed" stop-opacity=".25"></stop>
                  <stop offset="100%" stop-color="#7c3aed" stop-opacity="0"></stop>
                </linearGradient>
                <filter id="hv6-glow" x="-20%" y="-50%" width="140%" height="200%">
                  <feGaussianBlur stdDeviation="3" result="blur"></feGaussianBlur>
                  <feMerge><feMergeNode in="blur"></feMergeNode><feMergeNode in="SourceGraphic"></feMergeNode></feMerge>
                </filter>
              </defs>
              <g stroke="#e7e5e0" stroke-width="1">
                <line x1="0" x2="600" y1="36" y2="36"></line>
                <line x1="0" x2="600" y1="75" y2="75"></line>
                <line x1="0" x2="600" y1="114" y2="114"></line>
              </g>
              <path d="M0,116 C40,112 80,120 120,116 C160,110 200,118 240,114 C280,109 320,118 360,112 C400,107 440,116 480,110 C520,105 560,113 600,109"
                    fill="none" stroke="#cdc7bd" stroke-width="2" stroke-dasharray="4 5"></path>
              <path class="area"
                    d="M0,120 C60,114 120,108 180,96 C240,84 300,68 360,50 C420,34 480,22 540,15 L600,10 L600,150 L0,150 Z"
                    fill="url(#hv6-g1f)"></path>
              <path class="draw"
                    d="M0,120 C60,114 120,108 180,96 C240,84 300,68 360,50 C420,34 480,22 540,15 L600,10"
                    fill="none" stroke="url(#hv6-g1)" stroke-width="3" stroke-linecap="round"
                    filter="url(#hv6-glow)"></path>
              <g class="endnode">
                <circle cx="600" cy="10" r="14" fill="#7c3aed" fill-opacity=".15"></circle>
                <circle cx="600" cy="10" r="5" fill="#7c3aed"></circle>
              </g>
            </svg>
          </div>

          <div class="hv6-rows">
            <div class="hv6-row">
              <span class="n">01</span>
              <span class="what">Positioning<small>ICP clear · category owned</small></span>
              <span class="tag ok">Healthy</span>
            </div>
            <div class="hv6-row">
              <span class="n">02</span>
              <span class="what">Acquisition<small>Channel concentration · single-source</small></span>
              <span class="tag bad">Bottleneck</span>
            </div>
            <div class="hv6-row">
              <span class="n">03</span>
              <span class="what">Conversion<small>Demo → SQL leak · no playbook</small></span>
              <span class="tag watch">Watch</span>
            </div>
            <div class="hv6-row">
              <span class="n">04</span>
              <span class="what">Reporting<small>Weekly cadence · founder-trusted</small></span>
              <span class="tag ok">Healthy</span>
            </div>
            <div class="hv6-row">
              <span class="n">05</span>
              <span class="what">Team ownership<small>Founder-dependent on most decisions</small></span>
              <span class="tag watch">Watch</span>
            </div>
          </div>

          <div class="hv6-dash-foot">
            <div class="verdict"><strong>Verdict.</strong> Run a 90-day sprint against <em>acquisition</em>.</div>
            <a href={siteConfig.scorecardUrl} data-cta="diag-take-yours">Take yours →</a>
          </div>
        </aside>

      </div>
    </div>
  </section>

  <!-- PROOF BAR — editorial proof strip with brand-violet gradient numerals -->
  <section class="hv6-proof-bar" aria-label="Growth proof metrics">
    <div class="h3-container">
      <div class="hv6-proof-grid">
        {canonicalProofMetrics.slice(0, 4).map((m) => (
          <div class="hv6-stat">
            <span class="hv6-stat-value">{m.value}</span>
            <span class="hv6-stat-label">{m.label}</span>
          </div>
        ))}
        <div class="hv6-trust">
          <span class="lbl">Constraints diagnosed across</span>
          <div class="names">
            <span>Positioning</span>
            <span>Acquisition</span>
            <span>Conversion</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SUB-AUDIENCE ROUTING — solves the "we serve more than founders" problem -->
  <section class="section wr-sub-audience" aria-label="Other audiences">
    <div class="shell">
      <div class="wr-sub-label">Not a founder?</div>
      <div class="wr-sub-grid">
        {subAudiences.map((a) => (
          <div class="wr-sub-item">
            <h4>{a.title}</h4>
            <p>{a.body}</p>
            <a href={a.href}>{a.label} →</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <HomeProofV3 />

  <!-- WHAT YOU'LL LEAVE WITH — concrete promise for the first call -->
  <section class="section wr-leave-with" aria-labelledby="leave-with-h2">
    <div class="shell">
      <SectionIntro
        eyebrow="The first call"
        title="In 20 minutes, you'll leave with this."
        body="Bring your current numbers. No pitch unless there's a clear fit."
        titleId="leave-with-h2"
      />
      <div class="wr-lw-grid">
        {leaveWith.map((b) => (
          <article class="wr-lw-card">
            <span class="wr-lw-num">{b.n}</span>
            <h4>{b.h}</h4>
            <p>{b.p}</p>
          </article>
        ))}
      </div>
      <div class="wr-lw-cta">
        <a class="button button-brand" href={siteConfig.bookingUrl} data-cta="leave-with-book">
          {siteConfig.bookingLabel} →
        </a>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const spark = document.getElementById("hv6-hero-spark");
      if (!spark) return;
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (reduced) {
        spark.classList.add("is-animated");
        return;
      }
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((en) => {
            if (!en.isIntersecting) return;
            spark.classList.add("is-animated");
            io.disconnect();
          });
        },
        { threshold: 0.2 }
      );
      io.observe(spark);
    })();
  </script>

  <CtaLadder />

  <WhoThisIsForIcp />

  <NotForBlock />

  <!-- BEFORE / AFTER — core problem in concrete terms -->
  <section class="section before-after-section">
    <div class="shell">
      <p class="eyebrow">The core problem</p>
      <h2>Early traction hides weak systems — here's what changes when the rhythm is in.</h2>
      <div class="ba-grid">
        <article class="ba-card">
          <div class="ba-before">
            <span class="ba-label">Before</span>
            <p>Founder approves every campaign — the team executes, but every decision routes through you.</p>
          </div>
          <div class="ba-arrow" aria-hidden="true">→</div>
          <div class="ba-after">
            <span class="ba-label">After</span>
            <p>Team runs a weekly decision cadence. Scale, stop, or fix calls happen without the founder in the room.</p>
          </div>
        </article>
        <article class="ba-card">
          <div class="ba-before">
            <span class="ba-label">Before</span>
            <p>Channels report in isolation — paid, SEO, and outbound each have their own numbers, none connected to pipeline.</p>
          </div>
          <div class="ba-arrow" aria-hidden="true">→</div>
          <div class="ba-after">
            <span class="ba-label">After</span>
            <p>One dashboard. One view. Each week you see exactly what to scale, what to stop, and what to fix.</p>
          </div>
        </article>
        <article class="ba-card">
          <div class="ba-before">
            <span class="ba-label">Before</span>
            <p>Agency owns the channel logic — you get reports, invoices, and reasons why it didn't work.</p>
          </div>
          <div class="ba-arrow" aria-hidden="true">→</div>
          <div class="ba-after">
            <span class="ba-label">After</span>
            <p>Company owns the system. The agency executes inside a brief your team controls — and the IP stays with you.</p>
          </div>
        </article>
      </div>
      <!-- Proof callout — grounds abstract claims with specific evidence -->
      <div class="why-now-proof">
        <p class="wnp-label">These aren't theoretical — here's what it looks like in practice:</p>
        <ul class="wnp-list">
          <li><strong>Founder-led growth replaced:</strong> Healthtech (anonymous) — CEO moved from doing all marketing to weekly review within the first 30 days.</li>
          <li><strong>Channels unified:</strong> FinTech — paid, organic, and outbound connected to one decision view; 8.6% CTR and 500+ sign-ups in two months.</li>
          <li><strong>Team given direction:</strong> EdTech — acquisition focus narrowed from five channels to one ICP and one channel with a clear experiment backlog.</li>
        </ul>
        <a class="wnp-link" href="/case-studies">See all case studies →</a>
      </div>
    </div>
  </section>

  <ServiceComparisonTable />

  {featuredCase && (
    <section class="section" id="results">
      <div class="shell">
        <SectionIntro
          eyebrow="Case studies"
          title="Results, named."
          body="Read the row. If it sounds like you, click through. Every engagement labelled — paid client work vs programme or lecturing — so nothing reads like an implied client when it isn't."
        />
        <div class="case-feature">
          <div class="case-visual" aria-hidden="true">
            <span>{featuredCaseLabel}</span>
            <span>{featuredCase.data.results[0]}</span>
            <strong>{featuredCaseLabel.slice(0, 1)}</strong>
          </div>
          <div class="case-copy">
            <p class="eyebrow">{featuredCase.data.sector}</p>
            <h3>{featuredCaseLabel}: {featuredCase.data.title.replace(/^.*?:\s*/, '')}</h3>
            <div class="par-grid">
              <div class="par-row par-problem"><span class="par-label">Problem</span><p>{featuredCase.data.challenge}</p></div>
              <div class="par-row par-action"><span class="par-label">What we changed</span><p>{featuredCase.data.work.slice(0, 3).join(". ")}.</p></div>
              <div class="par-row par-result"><span class="par-label">Commercial result</span><p>{featuredCase.data.results.slice(0, 2).join("; ")}.</p></div>
            </div>
            <div class="case-metrics">
              {featuredCase.data.results.slice(0, 3).map((r) => (
                <div><span class="stat-number">{metricLead(r)}</span><span class="stat-label">{r}</span></div>
              ))}
            </div>
            <div class="hero-actions">
              <a class="button button-brand" href={`/case-studies/${featuredCase.id}`}>Read the full case</a>
              <a class="button button-light" href="/proof">All proof</a>
            </div>
          </div>
        </div>

        <div class="grid-3 mt-8">
          {otherCases.map((item) => (
            <article class="case-mini">
              <div class="case-scan-strip" aria-label="Case at a glance">
                <p class="case-scan-meta">
                  <strong>{item.data.client}</strong>
                  <span class="case-scan-sep" aria-hidden="true">·</span>
                  <span>{item.data.sector}</span>
                </p>
                <p class="case-scan-narrative">
                  <span class="case-scan-bit">{item.data.challenge}</span>
                  <span class="case-scan-sep" aria-hidden="true">→</span>
                  <span class="case-scan-bit">{item.data.work[0]}</span>
                  <span class="case-scan-sep" aria-hidden="true">→</span>
                  <span class="case-scan-bit">{item.data.results[0]}</span>
                </p>
              </div>
              <h4>{item.data.title}</h4>
              <dl class="par-mini">
                <dt>Problem</dt><dd>{item.data.challenge}</dd>
                <dt>What we changed</dt><dd>{item.data.work[0]}.</dd>
                <dt>Commercial result</dt><dd>{item.data.results[0]}{item.data.results[1] ? "; " + item.data.results[1] : ""}.</dd>
              </dl>
              <a class="card-link" href={`/case-studies/${item.id}`}>Read the case →</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <VsAgencyBlock />

  <section class="section section-alt" aria-labelledby="first30-home-heading">
    <div class="shell">
      <SectionIntro
        eyebrow="First 30 days"
        title="What happens in month one."
        body="Same sequence on most engagements — emphasis shifts based on whether the constraint is positioning, acquisition, conversion, or reporting."
        titleId="first30-home-heading"
      />
      <div class="timeline home-first30-timeline">
        {first30Days.map((item) => (
          <article class="timeline-row">
            <span class="timeline-week">{item.week}</span>
            <div>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </div>
          </article>
        ))}
      </div>
      <p class="home-first30-more">
        <a class="link-arrow" href="/first-30-days">Full first 30 days detail →</a>
        {" · "}
        <a class="link-arrow" href="/how-it-works">How it works →</a>
      </p>
    </div>
  </section>

  <TestimonialsBlock testimonials={homeTestimonials} />

  <DanielStory />

  <!-- FAQ -->
  <section class="section section-alt">
    <div class="shell">
      <SectionIntro
        eyebrow="Before you book"
        title="Questions you'll ask before you book."
        body="Short answers for teams deciding whether they need more execution, sharper diagnosis, or senior growth ownership."
      />
      <div class="home-faq-stack">
        {buyerFaqs.map((faq, index) => (
          <details class="home-faq-item" open={index < 2}>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="cta-band" id="cta">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Next step</p>
        <h2>The next step is a 20-minute call.</h2>
        <p>
          Bring your current growth picture. You'll leave with your bottleneck named in plain English, and an honest read on whether we're the right call.
        </p>
      </div>
      <div class="hero-actions">
        <a
          class="button button-brand button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="final-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="final-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Before / After section */
  .before-after-section { padding-block: 4rem; }
  .ba-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
    margin-top: 2rem;
  }
  @media (min-width: 900px) { .ba-grid { grid-template-columns: repeat(3, 1fr); } }
  .ba-card {
    display: grid;
    grid-template-rows: 1fr auto 1fr;
    gap: 0;
    border: 1px solid var(--line);
    border-radius: 1.25rem;
    overflow: hidden;
    background: var(--surface);
  }
  .ba-before, .ba-after { padding: 1.4rem 1.4rem 1.6rem; }
  .ba-before {
    background: color-mix(in srgb, #ff4444 5%, var(--surface));
    border-bottom: 1px solid var(--line);
  }
  .ba-after {
    background: color-mix(in srgb, var(--accent) 6%, var(--surface));
    border-top: 1px solid var(--line);
  }
  .ba-label {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.65rem;
  }
  .ba-before .ba-label { color: #c03030; }
