---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema, buildCaseStudyArticleSchema, buildFaqSchema } from "../../lib/schema";
import { siteConfig } from "../../site";

export async function getStaticPaths() {
  const cases = await getCollection("cases");
  return cases.map((caseStudy) => ({
    params: { slug: caseStudy.id },
    props: { caseStudy }
  }));
}

const { caseStudy } = Astro.props;
const path = `/case-studies/${caseStudy.id}`;
const caseFaqs = [
  {
    question: `What work did WSS do for ${caseStudy.data.client}?`,
    answer: caseStudy.data.work.slice(0, 3).join("; ") + "."
  },
  {
    question: `What changed for ${caseStudy.data.client}?`,
    answer: caseStudy.data.results.slice(0, 3).join("; ") + "."
  },
  {
    question: "What proof format does WSS use?",
    answer: "WSS presents case studies in a Before, Work Done, Result format so buyers can separate the starting problem, the operating work, and the commercial signal."
  }
];
---

<BaseLayout
  title={`${caseStudy.data.title} | We Scale Startups`}
  description={caseStudy.data.summary}
  path={path}
  schema={[
    buildCaseStudyArticleSchema({
      name: caseStudy.data.title,
      description: caseStudy.data.summary,
      path,
      publishedAt: caseStudy.data.publishedAt,
      updatedAt: caseStudy.data.updatedAt,
      keywords: caseStudy.data.services
    }),
    buildFaqSchema(caseFaqs),
    buildBreadcrumbSchema([
      { name: "Home", path: "/" },
      { name: "Proof", path: "/proof" },
      { name: caseStudy.data.title, path }
    ])
  ]}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">{caseStudy.data.sector}</p>
      <h1>{caseStudy.data.title}</h1>
      <p>{caseStudy.data.summary}</p>
      <div class="hero-actions">
        <a class="button button-dark" href={siteConfig.bookingUrl} data-cta="case-book">{siteConfig.bookingLabel}</a>
        <a class="button button-light" href="/proof">All proof</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell detail-grid">
      <aside class="detail-aside">
        <p class="eyebrow">Client</p>
        <p>{caseStudy.data.client}</p>
        <p><strong>Sector:</strong> {caseStudy.data.sector}</p>
        <p><strong>Services:</strong> {caseStudy.data.services.join(", ")}</p>
        <p><strong>Proof format:</strong> Before, work done, result.</p>
      </aside>
      <div class="detail-body">
        <article class="content-block">
          <h2>Before, work done, result</h2>
          <div class="proof-steps">
            <div><span>Before</span><p>{caseStudy.data.challenge}</p></div>
            <div><span>Work done</span><p>{caseStudy.data.work.slice(0, 3).join(", ")}.</p></div>
            <div><span>Result</span><p>{caseStudy.data.results.slice(0, 3).join("; ")}.</p></div>
          </div>
        </article>
        <article class="content-block">
          <h2>Challenge</h2>
          <p>{caseStudy.data.challenge}</p>
        </article>
        <article class="content-block">
          <h2>Work</h2>
          <ul>
            {caseStudy.data.work.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article class="content-block">
          <h2>Results</h2>
          <ul>
            {caseStudy.data.results.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">Case FAQ</p>
      <div class="grid-3">
        {caseFaqs.map((faq) => (
          <article class="feature-card">
            <h2>{faq.question}</h2>
            <p>{faq.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Similar constraint?</p>
        <h2>Diagnose the bottleneck before you brief more work.</h2>
        <p>Bring the current funnel, positioning, and reporting problem. We will decide the most useful next move.</p>
      </div>
      <a class="button button-brand" href={siteConfig.bookingUrl} data-cta="case-final-book">{siteConfig.bookingLabel}</a>
    </div>
  </section>
</BaseLayout>
