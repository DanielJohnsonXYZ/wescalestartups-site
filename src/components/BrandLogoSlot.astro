---
/**
 * Accessible placeholder when an official partner logo file is not yet approved in-repo.
 * Does not reproduce trademark artwork — label + “pending” treatment only.
 */
interface Props {
  label: string;
  href?: string;
  class?: string;
}
const { label, href, class: className = "" } = Astro.props;
const aria = `${label} logo — official brand asset not yet in press kit`;
---

{
  href ? (
    <a
      class:list={["brand-logo-slot", className]}
      href={href}
      rel="noreferrer"
      target="_blank"
      aria-label={aria}
    >
      <span class="brand-logo-slot__text">{label}</span>
      <span class="brand-logo-slot__pending">Asset pending</span>
    </a>
  ) : (
    <span class:list={["brand-logo-slot", className]} role="img" aria-label={aria}>
      <span class="brand-logo-slot__text">{label}</span>
      <span class="brand-logo-slot__pending">Asset pending</span>
    </span>
  )
}

<style>
  .brand-logo-slot {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 4.5rem;
    min-height: 2.25rem;
    padding: 0.2rem 0.45rem;
    border: 1px dashed var(--line, #c4bfb7);
    border-radius: 0.35rem;
    background: var(--surface, #faf9f7);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease;
  }
  a.brand-logo-slot:hover {
    border-color: var(--accent, #6657ff);
  }
  .brand-logo-slot__text {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1.2;
    text-align: center;
    color: var(--ink, #1a1a18);
  }
  .brand-logo-slot__pending {
    font-size: 0.52rem;
    color: var(--muted, #666);
    margin-top: 0.1rem;
  }
</style>
