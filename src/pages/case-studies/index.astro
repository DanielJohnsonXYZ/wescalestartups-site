---
import { getCollection } from "astro:content";
import CaseCard from "../../components/CaseCard.astro";
import SectionIntro from "../../components/SectionIntro.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sortByOrder } from "../../lib/utils";
import { buildBreadcrumbSchema, buildFaqSchema } from "../../lib/schema";
import { caseStudiesIndexRelatedReading, siteConfig } from "../../site";

const cases = sortByOrder(await getCollection("cases"));

const caseStudiesHubFaqs = [
  {
    question: "Why is every case written in the same format?",
    answer:
      "Problem / Action / Result keeps the proof scannable and comparable. The format is deliberate — it means the work is repeatable, not a one-off creative project."
  },
  {
    question: "Can I get a reference from a case company?",
    answer:
      "Sometimes, when timing and confidentiality allow — usually after a diagnostic call and when there is a serious fit."
  },
  {
    question: "Do these results guarantee similar outcomes for us?",
    answer:
      "No. Cases show how diagnosis and system work showed up in specific contexts. Your constraint map, team capacity, and market timing still determine what is realistic."
  }
];

const caseStudiesSchema = [
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Case studies", path: "/case-studies" }
  ]),
  buildFaqSchema(caseStudiesHubFaqs)
];
---

<BaseLayout
  title="Case Studies | We Scale Startups"
  description="Selected growth strategy, acquisition, positioning, and go-to-market work from We Scale Startups."
  keywords="startup case studies, B2B SaaS growth results, fintech acquisition, healthtech marketing, fractional CMO outcomes"
  path="/case-studies"
  schema={caseStudiesSchema}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Proof</p>
      <h1>Useful results from practical growth work.</h1>
      <p>These are not decorative portfolio tiles. They are examples of constraints identified, systems improved, and clearer growth motion created.</p>
      <div class="hero-actions">
        <a
          class="button button-dark button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="case-studies-index-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="case-studies-index-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
        <a class="button button-light" href="/proof" data-cta="case-studies-index-proof">All proof</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionIntro eyebrow="Selected work" title="Case studies worth keeping." />
      <div class="grid-3">
        {cases.map((item) => (
          <CaseCard
            href={`/case-studies/${item.id}`}
            title={item.data.title}
            sector={item.data.sector}
            summary={item.data.summary}
            results={item.data.results}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Related reading</p>
      <h2>Proof, voices, and how to work together.</h2>
      <ul class="related-insights-list">
        {caseStudiesIndexRelatedReading.map((item) => (
          <li>
            <a class="card-link" href={item.href}>
              {item.label} →
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">FAQ</p>
      <h2>How to read these cases.</h2>
      <div class="grid-3">
        {caseStudiesHubFaqs.map((item) => (
          <article class="feature-card">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">After a case</p>
        <h2>Bring your situation into a live read.</h2>
        <p>
          In {siteConfig.bookingCallDurationPhrase}, we can usually tell whether your constraint looks like one of these patterns — and which engagement (if any) would actually help.
        </p>
      </div>
      <div class="hero-actions">
        <a
          class="button button-brand button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="case-studies-index-final-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="case-studies-index-final-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
