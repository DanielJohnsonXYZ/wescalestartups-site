---
import { getCollection } from "astro:content";
import SectionIntro from "../../components/SectionIntro.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema, buildFaqSchema } from "../../lib/schema";
import { sortByOrder } from "../../lib/utils";
import { industriesHubRelatedReading, siteConfig } from "../../site";

const industriesHubFaqs = [
  {
    question: "Why are some industries listed under \"Also serve\"?",
    answer:
      "Core markets have the densest published proof and repeat buyer patterns. Other sectors use the same methodology with market-specific proof and compliance context on each page."
  },
  {
    question: "Do you only work in these industries?",
    answer:
      "No. If your motion is B2B, trust-heavy, and post-PMF, the diagnostic still applies — the industry page is a shortcut for common proof and channel economics."
  }
];

const industriesSchema = [
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Industries", path: "/industries" }
  ]),
  buildFaqSchema(industriesHubFaqs)
];

const coreIndustryIds = new Set(["saas-growth", "fintech", "healthtech", "edtech"]);
const allIndustries = sortByOrder(await getCollection("industries"));
const coreIndustries = allIndustries.filter((industry) => coreIndustryIds.has(industry.id));
const moreIndustries = allIndustries.filter((industry) => !coreIndustryIds.has(industry.id));
---

<BaseLayout
  title="Industries | We Scale Startups"
  description="Industry growth pages for SaaS, AI, FinTech, HealthTech, EdTech, and VC portfolios — post-PMF context and service fit per vertical."
  keywords="SaaS growth consultancy, fintech GTM, healthtech marketing, EdTech acquisition, B2B startup industries"
  path="/industries"
  schema={industriesSchema}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Industries</p>
      <h1>Markets where proof, trust, and timing matter.</h1>
      <p>The system adapts to the buyer, proof required, channel economics, and internal team capacity.</p>
      <div class="hero-actions">
        <a
          class="button button-dark button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="industries-index-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="industries-index-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
        <a class="button button-light" href="/services" data-cta="industries-index-services">Compare services</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <SectionIntro eyebrow="Core markets" title="Where we publish the most proof." />
      <div class="grid-3">
        {coreIndustries.map((industry) => (
          <a class="industry-card" href={`/industries/${industry.id}`}>
            <p class="card-kicker">Market</p>
            <h3>{industry.data.title}</h3>
            <p>{industry.data.description}</p>
            <span class="card-link">Explore {industry.data.title}</span>
          </a>
        ))}
      </div>
      {moreIndustries.length > 0 && (
        <>
          <div class="industries-more-intro">
            <SectionIntro
              eyebrow="Also serve"
              title="Additional sectors and founder contexts."
              body="Same diagnostic and system-building approach — market pages vary by proof requirements and buyer motion."
            />
          </div>
          <div class="grid-3">
            {moreIndustries.map((industry) => (
              <a class="industry-card" href={`/industries/${industry.id}`}>
                <p class="card-kicker">Market</p>
                <h3>{industry.data.title}</h3>
                <p>{industry.data.description}</p>
                <span class="card-link">Explore {industry.data.title}</span>
              </a>
            ))}
          </div>
        </>
      )}
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Related reading</p>
      <h2>Proof and services across markets.</h2>
      <ul class="related-insights-list">
        {industriesHubRelatedReading.map((item) => (
          <li>
            <a class="card-link" href={item.href}>
              {item.label} →
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">FAQ</p>
      <h2>How industry pages work.</h2>
      <div class="grid-2">
        {industriesHubFaqs.map((item) => (
          <article class="feature-card">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Market-specific diagnosis</p>
        <h2>Name the constraint before you scale spend.</h2>
        <p>
          In {siteConfig.bookingCallDurationPhrase}, we connect buyer problem, proof bar, channel economics, and team capacity into a practical next step.
        </p>
      </div>
      <div class="hero-actions">
        <a
          class="button button-brand button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="industries-index-final-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="industries-index-final-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .industries-more-intro {
    margin-top: 2.75rem;
  }
</style>
