---
import { proofClients, proofEcosystemLogos } from "../site";
---

<section class="proof-strip" aria-label="Selected client work and startup growth engagements">
  <div class="shell proof-inner">
    <div>
      <p class="eyebrow">Current &amp; recent client work</p>
      <h2>Real engagements, not borrowed logo theatre.</h2>
      <p class="proof-strip-lede">
        Each mark below is labelled: <strong>paid client work</strong> (case study) vs <strong>programmes &amp; lecturing</strong> so nothing reads like an implied client when it is not.
      </p>
    </div>
    <div class="proof-clients-stack">
      <div class="proof-client-row">
        {proofClients.map((client) => (
          <article class="proof-client-tile">
            <div class="proof-client-logo-row">
              <img
                class="proof-client-logo"
                src={client.logoSrc}
                alt=""
                width="140"
                height="40"
                loading="lazy"
                decoding="async"
              />
              <span class="proof-client-relationship">{client.relationship}</span>
            </div>
            <strong>
              <a href={`/case-studies/${client.caseSlug}`} data-cta={`proof-client-${client.caseSlug}`}>
                {client.label}
              </a>
            </strong>
            <span class="proof-client-context">{client.context}</span>
            <p>{client.proof}</p>
          </article>
        ))}
      </div>

      <div class="proof-ecosystem">
        <p class="eyebrow">Programmes, lecturing &amp; reviews</p>
        <p class="proof-ecosystem-lede">
          These are <strong>not</strong> client logos — context for how the operator shows up before you hire WSS.
        </p>
        <ul class="proof-eco-grid">
          {proofEcosystemLogos.map((item) => (
            <li class="proof-eco-tile">
              <img src={item.src} alt="" width="120" height="36" loading="lazy" decoding="async" class="proof-eco-logo" />
              <span class="proof-eco-name">{item.name}</span>
              <span class="proof-eco-rel">{item.relationship}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="proof-speaking-row" aria-label="Selected speaking proof">
        <article>
          <img src="/images/speaking/daniel-speaking-nomad-960.webp" alt="Daniel Johnson speaking at Nomad Summit" width="960" height="960" loading="lazy" decoding="async" />
          <div>
            <strong>Founder rooms, not generic theory.</strong>
            <span>Teaching growth systems to international startup operators.</span>
          </div>
        </article>
        <article>
          <img src="/images/speaking/daniel-speaking-shenzhen-960.webp" alt="Daniel Johnson at a Shenzhen SaaS and AI SEO event" width="960" height="960" loading="lazy" decoding="async" />
          <div>
            <strong>SaaS and AI growth in public.</strong>
            <span>Positioning, acquisition, and founder-led growth sessions.</span>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>
