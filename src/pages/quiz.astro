---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig, strategicPageRelatedInsights } from "../site";
import { buildBreadcrumbSchema, buildFaqSchema } from "../lib/schema";

const quizCalendlyUrl = siteConfig.calendlyUrl;
const quizBookingLabel = siteConfig.bookingLabel;
const quizDiagnosticCallQuestion = `Is this the same as the ${siteConfig.bookingCallShort}?`;

const quizRelated = strategicPageRelatedInsights["/quiz"] ?? [];

const faqSchema = buildFaqSchema([
  {
    question: "How long does the growth bottleneck quiz take?",
    answer: "About 3 minutes. 10 questions, scored instantly. No email required to see your result."
  },
  {
    question: "What do I get at the end?",
    answer: "Your primary growth constraint identified across 5 layers — positioning, acquisition, conversion, reporting, and team ownership — plus a specific recommended next step."
  },
  {
    question: quizDiagnosticCallQuestion,
    answer: "The quiz is a self-serve starting point. The diagnostic call goes deeper: we review your current stack, pipeline data, and team context to give you a prioritised action plan."
  }
]);

const quizSchema = [
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Growth bottleneck quiz", path: "/quiz" }
  ]),
  faqSchema
];
---

<BaseLayout
  title="Growth Bottleneck Quiz | We Scale Startups"
  description="3-minute quiz that identifies your primary growth bottleneck across positioning, acquisition, conversion, reporting, and team ownership. Free, instant results, no email required."
  path="/quiz"
  schema={quizSchema}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Quiz · 3 minutes · Free</p>
      <h1>Find your growth bottleneck in 3 minutes.</h1>
      <p class="lede">
        10 questions across the 5 layers that determine whether a post-PMF startup scales or stalls.
        Instant result. No email required to see it.
      </p>
      <div class="hero-actions">
        <a class="button button-brand" href="/diagnose" data-cta="quiz-hero-diagnose">
          Prefer the written framework →
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="quiz-hero-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
        <a
          class="button button-light"
          href={siteConfig.bookingUrl}
          data-cta="quiz-hero-book"
          title={siteConfig.bookingCallReassurance}
        >
          {siteConfig.bookingLabel} →
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div id="quiz-app">
        <!-- Rendered by JS below -->
        <noscript>
          <p>This quiz requires JavaScript. You can <a href="/diagnose">use the manual diagnostic framework instead →</a></p>
        </noscript>
      </div>
    </div>
  </section>

  {
    quizRelated.length > 0 && (
      <section class="section">
        <div class="shell">
          <p class="eyebrow">Go deeper</p>
          <h2>After the quiz, read this next.</h2>
          <ul class="related-insights-list">
            {quizRelated.map((item) => (
              <li>
                <a class="card-link" href={item.href}>
                  {item.label} →
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <!-- FAQ -->
  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">Questions</p>
      <h2>About the quiz.</h2>
      <dl class="faq-list">
        <div class="faq-item">
          <dt>How long does it take?</dt>
          <dd>About 3 minutes. 10 questions, scored instantly. No email required to see your result.</dd>
        </div>
        <div class="faq-item">
          <dt>What do I get at the end?</dt>
          <dd>Your primary growth constraint identified across 5 layers — positioning, acquisition, conversion, reporting, and team ownership — plus a specific recommended next step.</dd>
        </div>
        <div class="faq-item">
          <dt>{quizDiagnosticCallQuestion}</dt>
          <dd>The quiz is a self-serve starting point. The diagnostic call goes deeper: we review your current stack, pipeline data, and team context to give you a prioritised action plan.</dd>
        </div>
      </dl>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ quizCalendlyUrl, quizBookingLabel }}>
const QUESTIONS = [
  {
    layer: "positioning",
    text: "When you ask a recent customer what problem you solve, do they describe it the way your website does?",
    options: [
      { label: "Yes, almost word for word", score: 0 },
      { label: "Roughly, but not exactly", score: 1 },
      { label: "No, it's usually quite different", score: 2 },
      { label: "We haven't asked recently", score: 2 }
    ]
  },
  {
    layer: "positioning",
    text: "How often do sales calls feel like educating the buyer about the problem before talking about your solution?",
    options: [
      { label: "Rarely — buyers come in understanding the problem", score: 0 },
      { label: "Sometimes on first calls", score: 1 },
      { label: "Almost always", score: 2 },
      { label: "Every call starts this way", score: 2 }
    ]
  },
  {
    layer: "acquisition",
    text: "How would you describe your current acquisition pattern?",
    options: [
      { label: "Multiple channels contributing consistently", score: 0 },
      { label: "One channel working, others untested", score: 1 },
      { label: "Pipeline arrives in unpredictable waves", score: 2 },
      { label: "Mostly referrals and founder network", score: 2 }
    ]
  },
  {
    layer: "acquisition",
    text: "When you test a new channel, what usually happens?",
    options: [
      { label: "We run structured experiments and learn fast", score: 0 },
      { label: "We try it, get mixed results, move on", score: 1 },
      { label: "Tests don't connect to each other or the core offer", score: 2 },
      { label: "We rarely test new channels systematically", score: 2 }
    ]
  },
  {
    layer: "conversion",
    text: "Do you know your visitor-to-qualified-conversation conversion rate?",
    options: [
      { label: "Yes, and we review it weekly", score: 0 },
      { label: "Roughly, but we don't track it formally", score: 1 },
      { label: "No, we don't have visibility on it", score: 2 },
      { label: "We track clicks but not qualified conversations", score: 1 }
    ]
  },
  {
    layer: "conversion",
    text: "How does your website's main CTA perform?",
    options: [
      { label: "We've tested it and it converts well", score: 0 },
      { label: "Seems fine but we've never tested alternatives", score: 1 },
      { label: "We suspect it's underperforming but aren't sure why", score: 2 },
      { label: "We haven't looked at CTA performance", score: 2 }
    ]
  },
  {
    layer: "reporting",
    text: "After your last weekly growth review, what decision did it help you make?",
    options: [
      { label: "A clear scale/stop/fix call on at least one channel", score: 0 },
      { label: "Noted some things to watch, no hard decisions", score: 1 },
      { label: "We reported activity but didn't make calls", score: 2 },
      { label: "We don't have a weekly growth review", score: 2 }
    ]
  },
  {
    layer: "reporting",
    text: "How long would it take you to answer: which channel drove the most qualified pipeline last quarter?",
    options: [
      { label: "Instantly — it's in our dashboard", score: 0 },
      { label: "An hour of pulling data together", score: 1 },
      { label: "Half a day and some guesswork", score: 2 },
      { label: "We don't have that visibility", score: 2 }
    ]
  },
  {
    layer: "team",
    text: "Who owns the weekly growth cadence — running the review, making calls, updating the experiment backlog?",
    options: [
      { label: "A dedicated growth lead or CMO", score: 0 },
      { label: "The founder, but it runs consistently", score: 1 },
      { label: "The founder, but it's sporadic", score: 2 },
      { label: "No single owner — it's shared informally", score: 2 }
    ]
  },
  {
    layer: "team",
    text: "If the founder stepped back from growth decisions for 4 weeks, what would happen?",
    options: [
      { label: "The system would run itself — the team owns it", score: 0 },
      { label: "Some slowdown, but it would mostly continue", score: 1 },
      { label: "Growth activity would pause or become reactive", score: 2 },
      { label: "Everything would effectively stop", score: 2 }
    ]
  }
];

const LAYER_META = {
  positioning: {
    label: "Positioning",
    description: "Buyers don't see the problem the way you do. Sales calls start with education instead of qualification. The offer message shifts from call to call.",
    fix: "Start with Growth Diagnosis — reframe the offer before adding spend or channels.",
    href: "/services/growth-diagnosis"
  },
  acquisition: {
    label: "Acquisition",
    description: "Channels run in isolation rather than reinforcing each other. Pipeline arrives in waves. CAC is unstable and hard to forecast.",
    fix: "Acquisition System Build — connect the channels into one operating system.",
    href: "/services/acquisition-system-build"
  },
  conversion: {
    label: "Conversion",
    description: "Qualified visitors don't become qualified conversations. The offer asks for too much too early or the funnel has an invisible drop-off.",
    fix: "90-Day Growth Sprint — test landing page, copy, and offer iterations at pace.",
    href: "/services/90-day-growth-sprint"
  },
  reporting: {
    label: "Reporting",
    description: "Activity is tracked but decisions aren't made. The team knows what happened but not what to do next.",
    fix: "Fractional CMO — senior owner running a weekly decision cadence.",
    href: "/services/fractional-cmo"
  },
  team: {
    label: "Team ownership",
    description: "Founder hours are filling the growth gap. Without an internal owner running the rhythm, growth stays personal and doesn't scale.",
    fix: "Fractional CMO — transfer the operating system to someone inside the team.",
    href: "/services/fractional-cmo"
  }
};

// ── State ──────────────────────────────────────────────────────
let current = 0;
let scores = { positioning: 0, acquisition: 0, conversion: 0, reporting: 0, team: 0 };
let answers = new Array(QUESTIONS.length).fill(null);

// ── Render helpers ─────────────────────────────────────────────
function getResult() {
  const sorted = Object.entries(scores).sort((a, b) => b[1] - a[1]);
  return sorted[0][0];
}

function renderProgress() {
  const step = Math.min(current + 1, QUESTIONS.length);
  const pct = Math.round((step / QUESTIONS.length) * 100);
  return `
    <div class="quiz-progress" role="progressbar" aria-valuenow="${step}" aria-valuemin="1" aria-valuemax="${QUESTIONS.length}" aria-label="Question ${step} of ${QUESTIONS.length}">
      <div class="quiz-progress-bar" style="width:${pct}%"></div>
    </div>
    <p class="quiz-counter">Question ${step} of ${QUESTIONS.length}</p>`;
}

function renderQuestion(idx) {
  const q = QUESTIONS[idx];
  const layerNum = { positioning: 1, acquisition: 2, conversion: 3, reporting: 4, team: 5 }[q.layer];
  return `
    ${renderProgress()}
    <div class="quiz-question-wrap">
      <p class="quiz-layer-label">Layer ${layerNum}: ${LAYER_META[q.layer].label}</p>
      <h2 class="quiz-q-text">${q.text}</h2>
      <div class="quiz-options" role="list">
        ${q.options.map((opt, i) => `
          <button
            class="quiz-option${answers[idx] === i ? ' is-selected' : ''}"
            data-idx="${i}"
            role="listitem"
            aria-pressed="${answers[idx] === i}"
          >${opt.label}</button>
        `).join('')}
      </div>
      <div class="quiz-nav">
        ${idx > 0 ? `<button class="button button-light quiz-back">← Back</button>` : '<span></span>'}
        <button class="button button-brand quiz-next" ${answers[idx] === null ? 'disabled' : ''}>
          ${idx === QUESTIONS.length - 1 ? 'See my result →' : 'Next →'}
        </button>
      </div>
    </div>`;
}

function renderResult() {
  const topLayer = getResult();
  const meta = LAYER_META[topLayer];
  const allScores = Object.entries(scores)
    .map(([k, v]) => ({ key: k, label: LAYER_META[k].label, score: v, max: 4 }))
    .sort((a, b) => b.score - a.score);

  return `
    <div class="quiz-result">
      <p class="eyebrow">Your result</p>
      <h2>Your primary bottleneck is <span class="result-highlight">${meta.label}</span>.</h2>
      <p class="quiz-result-desc">${meta.description}</p>

      <div class="result-scores">
        ${allScores.map(s => `
          <div class="result-score-row">
            <span class="result-score-label">${s.label}</span>
            <div class="result-score-bar-wrap">
              <div class="result-score-bar" style="width:${Math.round((s.score / s.max) * 100)}%" data-severity="${s.score >= 3 ? 'high' : s.score >= 2 ? 'medium' : 'low'}"></div>
            </div>
            <span class="result-score-num">${s.score}/${s.max}</span>
          </div>`).join('')}
      </div>

      <div class="result-next">
        <p class="result-fix-label">Recommended next step:</p>
        <p class="result-fix">${meta.fix}</p>
        <div class="hero-actions" style="margin-top:1.25rem">
          <a class="button button-brand" href="${meta.href}">See the engagement →</a>
          <a class="button button-light" href="${quizCalendlyUrl}" target="_blank" rel="noopener">${quizBookingLabel} →</a>
        </div>
      </div>

      <button class="quiz-restart button button-light" style="margin-top:2rem">Retake the quiz</button>
    </div>`;
}

function mount() {
  const app = document.getElementById('quiz-app');
  if (!app) return;

  function render() {
    if (current < QUESTIONS.length) {
      app.innerHTML = renderQuestion(current);
    } else {
      app.innerHTML = renderResult();
    }
    bindEvents();
  }

  function bindEvents() {
    // Option selection
    app.querySelectorAll('.quiz-option').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = parseInt(btn.dataset.idx, 10);
        const q = QUESTIONS[current];
        const prev = answers[current];
        if (prev !== null) {
          scores[q.layer] -= q.options[prev].score;
        }
        answers[current] = idx;
        scores[q.layer] += q.options[idx].score;
        render();
      });
    });

    // Next
    app.querySelector('.quiz-next')?.addEventListener('click', () => {
      if (answers[current] === null) return;
      current++;
      render();
    });

    // Back — drop in-progress answer on this step, then go to previous question
    app.querySelector('.quiz-back')?.addEventListener('click', () => {
      if (current <= 0) return;
      if (answers[current] !== null) {
        const q = QUESTIONS[current];
        scores[q.layer] -= q.options[answers[current]].score;
        answers[current] = null;
      }
      current--;
      render();
    });

    // Restart
    app.querySelector('.quiz-restart')?.addEventListener('click', () => {
      current = 0;
      scores = { positioning: 0, acquisition: 0, conversion: 0, reporting: 0, team: 0 };
      answers = new Array(QUESTIONS.length).fill(null);
      render();
    });
  }

  render();
}

document.addEventListener('DOMContentLoaded', mount);
</script>

<style>
  /* ── Progress ── */
  .quiz-progress {
    height: 4px;
    background: var(--line, #e8e5e0);
    border-radius: 2px;
    margin-bottom: 0.5rem;
    overflow: hidden;
  }
  .quiz-progress-bar {
    height: 100%;
    background: var(--accent, #f97316);
    border-radius: 2px;
    transition: width 250ms ease;
  }
  .quiz-counter {
    font-size: 0.78rem;
    color: var(--muted);
    text-align: right;
    margin: 0 0 2rem;
  }

  /* ── Question ── */
  .quiz-question-wrap { max-width: 680px; }
  .quiz-layer-label {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent, #f97316);
    margin: 0 0 0.75rem;
  }
  .quiz-q-text {
    font-size: clamp(1.2rem, 2.5vw, 1.5rem);
    line-height: 1.4;
    letter-spacing: -0.02em;
    margin: 0 0 1.5rem;
  }

  /* ── Options ── */
  .quiz-options {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 2rem;
  }
  .quiz-option {
    text-align: left;
    background: var(--surface, #f9f9f7);
    border: 1.5px solid var(--line, #e8e5e0);
    border-radius: 0.6rem;
    padding: 0.9rem 1.1rem;
    font-size: 0.95rem;
    color: var(--ink, #1a1a18);
    cursor: pointer;
    transition: border-color 140ms ease, background 140ms ease;
    line-height: 1.4;
  }
  .quiz-option:hover { border-color: var(--accent, #f97316); }
  .quiz-option.is-selected {
    border-color: var(--accent, #f97316);
    background: #fff7f2;
    font-weight: 600;
  }

  /* ── Nav ── */
  .quiz-nav {
    display: flex;
    gap: 0.75rem;
    justify-content: space-between;
    align-items: center;
  }
  .quiz-next:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  /* ── Result ── */
  .quiz-result { max-width: 640px; }
  .result-highlight { color: var(--accent, #f97316); }
  .quiz-result-desc {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--muted, #666);
    margin: 0.75rem 0 2rem;
    max-width: 52ch;
  }

  .result-scores {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 2rem;
  }
  .result-score-row {
    display: grid;
    grid-template-columns: 9rem 1fr 3rem;
    gap: 0.75rem;
    align-items: center;
  }
  .result-score-label { font-size: 0.85rem; font-weight: 600; color: var(--ink); }
  .result-score-bar-wrap {
    height: 8px;
    background: var(--line);
    border-radius: 4px;
    overflow: hidden;
  }
  .result-score-bar {
    height: 100%;
    border-radius: 4px;
    transition: width 600ms ease;
  }
  .result-score-bar[data-severity="high"]   { background: #ef4444; }
  .result-score-bar[data-severity="medium"] { background: var(--accent, #f97316); }
  .result-score-bar[data-severity="low"]    { background: #22c55e; }
  .result-score-num { font-size: 0.78rem; color: var(--muted); text-align: right; }

  .result-next {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }
  .result-fix-label {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin: 0 0 0.4rem;
  }
  .result-fix {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--ink);
    margin: 0;
  }
</style>
