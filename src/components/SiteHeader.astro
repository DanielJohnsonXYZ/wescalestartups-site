---
import { navigation, siteConfig } from "../site";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const isActive = (href: string) => href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<header class="site-header">
  <div class="shell header-inner">
    <a class="brand" href="/" aria-label="We Scale Startups home">
      <img
        src="/images/logos/wss-logo.webp"
        alt="We Scale Startups"
        width="120"
        height="68"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </a>
    <nav class="nav-links" aria-label="Primary navigation">
      {navigation.map((item) => (
        <a class:list={["nav-link", { "is-active": isActive(item.href) }]} href={item.href}>{item.label}</a>
      ))}
    </nav>
    <a
      class="button button-brand header-cta header-cta--stacked button-with-subcopy"
      href={siteConfig.bookingUrl}
      data-cta="header-book"
      title={siteConfig.bookingCallReassurance}
    >
      <span class="button-label">{siteConfig.bookingLabel}</span>
      <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
    </a>
    <details class="mobile-menu">
      <summary class="button button-light">Menu</summary>
      <nav aria-label="Mobile navigation">
        {navigation.map((item) => (
          <a class:list={["nav-link", { "is-active": isActive(item.href) }]} href={item.href}>{item.label}</a>
        ))}
        <a
          class="button button-brand button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="mobile-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
      </nav>
    </details>
  </div>
</header>
