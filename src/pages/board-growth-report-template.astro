---
import CfEmailOff from "../components/CfEmailOff.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema } from "../lib/schema";
import { siteConfig } from "../site";

const path = "/board-growth-report-template";
const title = "Board Growth Report Template";
const schema = [
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Resources", path: "/resources" },
    { name: title, path }
  ])
];

function requestMailto() {
  const subject = `Send me the ${title}`;
  const body = `Please send the ${title}.\n\nFound on: ${siteConfig.siteUrl}${path}`;
  return `mailto:${siteConfig.email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
}
---

<BaseLayout
  path={path}
  title="Board Growth Report Template | We Scale Startups"
  description="Board-ready growth report template: what changed, what shipped, what to scale or stop — request by email."
  schema={schema}
  breadcrumbItems={[
    { name: "Home", path: "/" },
    { name: "Resources", path: "/resources" },
    { name: title, path }
  ]}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Template</p>
      <h1>{title}</h1>
      <p class="lede">
        Structure for monthly or quarterly board updates — commercial outcomes, experiment learnings, and explicit scale/stop/fix recommendations (not activity totals).
      </p>
      <div class="hero-actions">
        <CfEmailOff>
          <a class="button button-brand" href={requestMailto()} data-cta="board-report-request">
            Request the template →
          </a>
        </CfEmailOff>
        <a class="button button-light" href={siteConfig.bookingUrl}>{siteConfig.bookingLabel} →</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="grid-3">
        <article class="feature-card">
          <h2>Inside the template</h2>
          <p>Three sections per month: what changed (pipeline, revenue, CAC trend), what shipped (experiments and outcomes), and what's next (scale / stop / fix decisions with owners).</p>
        </article>
        <article class="feature-card">
          <h2>Who it's for</h2>
          <p>Founders reporting growth to a board or investors who want the marketing slide to answer questions instead of raising them — without building a new deck every month.</p>
        </article>
        <article class="feature-card">
          <h2>How to use it</h2>
          <p>Copy the structure into your board deck. If a metric doesn't drive a decision, cut it — the template is deliberately one page so the conversation stays on the constraint.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Next step</p>
        <h2>Want board reporting handled?</h2>
        <p>Fractional CMO engagements include board-ready growth reporting every month.</p>
      </div>
      <div class="hero-actions">
        <a class="button button-brand" href={siteConfig.bookingUrl} data-cta="board-report-final-book">{siteConfig.bookingLabel} →</a>
      </div>
    </div>
  </section>

</BaseLayout>
