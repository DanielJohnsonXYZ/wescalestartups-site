---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildBreadcrumbSchema, buildFaqSchema } from "../../lib/schema";
import { contactRelatedReading, siteConfig } from "../../site";

const contactFaqs = [
  {
    question: "What should I include in an enquiry?",
    answer:
      "Stage, ARR band, active channels, the bottleneck in plain language, budget range, timeline, and what needs to change in the next 90 days. Specificity beats a generic intro."
  },
  {
    question: "Is email or the diagnostic call better?",
    answer: `Use email when you are assembling context asynchronously. Book ${siteConfig.bookingCallShort} when the problem is urgent, politically messy, or faster to show live.`
  },
  {
    question: "How fast do you respond?",
    answer:
      "Enquiries are read by the operator, not a gatekeeper. If there is a fit, you will get a clear next step — or an honest no / referral."
  }
];

const contactSchema = [
  buildBreadcrumbSchema([
    { name: "Home", path: "/" },
    { name: "Contact", path: "/contact" }
  ]),
  buildFaqSchema(contactFaqs)
];
---

<BaseLayout
  title="Contact | We Scale Startups"
  description="Contact We Scale Startups: growth enquiry, email, and booking links for a 20-minute diagnostic with Daniel Johnson."
  keywords="contact We Scale Startups, growth enquiry, book growth diagnostic, Daniel Johnson WSS"
  path="/contact"
  schema={contactSchema}
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow">Contact</p>
      <h1>Send the growth context.</h1>
      <p>The best enquiry is specific: stage, ARR, channels, bottleneck, budget, timeline, and what needs to change in the next 90 days.</p>
      <div class="hero-actions">
        <a
          class="button button-brand button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="contact-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="contact-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
        <!--email_off-->
        <a class="button button-light" href={`mailto:${siteConfig.email}`} data-cta="contact-email">{siteConfig.email}</a>
        <!--/email_off-->
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell contact-grid contact-grid-form">
      <form class="contact-option contact-form" id="growth-enquiry" name="growth-enquiry">
        <p class="card-kicker">Structured enquiry</p>
        <h2>Tell us what is happening now.</h2>
        <label>Name<input name="name" autocomplete="name" required /></label>
        <label>Email<input name="email" type="email" autocomplete="email" required /></label>
        <label>Company<input name="company" autocomplete="organization" required /></label>
        <label>Company stage
          <select name="stage" required>
            <option value="">Choose one</option>
            <option>Pre-seed / seed</option>
            <option>Series A</option>
            <option>Series B+</option>
            <option>Bootstrapped / profitable</option>
          </select>
        </label>
        <label>ARR range
          <select name="arr" required>
            <option value="">Choose one</option>
            <option>Under £500k</option>
            <option>£500k to £1m</option>
            <option>£1m to £5m</option>
            <option>£5m to £10m</option>
            <option>£10m+</option>
          </select>
        </label>
        <label>Current channels<input name="channels" placeholder="Paid, outbound, SEO, partners, content, sales-led..." /></label>
        <label>Current bottleneck<textarea name="bottleneck" rows="4" required></textarea></label>
        <label>Budget
          <select name="budget" required>
            <option value="">Choose one</option>
            <option>Exploring</option>
            <option>£3k to £8k</option>
            <option>£8k to £15k</option>
            <option>£15k+</option>
          </select>
        </label>
        <label>Timeline<input name="timeline" placeholder="Now, this quarter, next quarter..." /></label>
        <label>What do you need help with?<textarea name="help" rows="4"></textarea></label>
        <button class="button button-brand" type="submit">Send enquiry</button>
      </form>
      <aside class="contact-option">
        <p class="card-kicker">Prefer a call?</p>
        <h2>{siteConfig.bookingLabel}</h2>
        <p>A short diagnostic call is best when the problem is urgent or hard to explain in a form.</p>
        <a
          class="card-link"
          href={siteConfig.bookingUrl}
          data-cta="contact-side-book"
          title={siteConfig.bookingCallReassurance}
        >
          {siteConfig.bookingLabel} →
        </a>
        <p>
          Prefer async?{" "}
          <a href={siteConfig.scorecardUrl} data-cta="contact-side-scorecard">{siteConfig.scorecardLabel}</a>.
        </p>
        <p><strong>Address:</strong><br />81 Curtain Road,<br />London,<br />EC2A 3AG,<br />UK</p>
      </aside>
    </div>
  </section>

  <!-- Route by enquiry type — speaking, podcast, partnership, press all -->
  <!-- have specific better destinations than the generic enquiry form.    -->
  <!-- Source: Notion 354f99a79fdb81eebd81df3dfa282659                      -->
  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">Routing by enquiry type</p>
      <h2>Not a growth engagement? Here's the right page.</h2>
      <p>The enquiry form above is for growth engagement enquiries. For everything else, use one of these direct routes — they reach the right inbox faster.</p>
      <div class="grid-3 mt-6">
        <article class="feature-card">
          <p class="card-kicker">Speaking enquiries</p>
          <h3>Book Daniel for a talk or workshop</h3>
          <p>Conference keynotes, founder cohort sessions, accelerator workshops, university lectures.</p>
          <a class="card-link" href="https://danieljohnson.xyz/speaking/" rel="noreferrer" target="_blank">danieljohnson.xyz/speaking →</a>
        </article>
        <article class="feature-card">
          <p class="card-kicker">Podcast guest pitches</p>
          <h3>Daniel as a guest on your show</h3>
          <p>Topics, recent appearances, audio clips, and the application form for podcast hosts.</p>
          <a class="card-link" href="/podcast-guest-application">/podcast-guest-application →</a>
        </article>
        <article class="feature-card">
          <p class="card-kicker">Press &amp; media</p>
          <h3>Quotes, interviews, contributed pieces</h3>
          <p>Press kit, fast facts, and how to describe Daniel and WSS accurately.</p>
          <a class="card-link" href="/press">/press →</a>
        </article>
        <article class="feature-card">
          <p class="card-kicker">Mentor sessions</p>
          <h3>1:1 with Daniel via GrowthMentor</h3>
          <p>Lower-ticket individual mentor sessions outside the WSS engagement scope. Fastest route for one-off questions.</p>
          <a class="card-link" href="https://app.growthmentor.com/mentors/daniel-johnson" rel="noreferrer" target="_blank">GrowthMentor profile →</a>
        </article>
        <article class="feature-card">
          <p class="card-kicker">Partnerships</p>
          <h3>Co-marketing, integrations, syndication</h3>
          <p>Send context on what you're proposing, who it's for, and the shape of the partnership. We respond when there's a clear fit.</p>
          <a class="card-link" href={`mailto:${siteConfig.email}?subject=Partnership%20enquiry`}>Email — Partnership enquiry →</a>
        </article>
        <article class="feature-card">
          <p class="card-kicker">Accelerator / VC programmes</p>
          <h3>Portfolio workshops &amp; mentor pools</h3>
          <p>Daniel mentors through Google for Startups, Techstars, and runs portfolio diagnosis workshops for VC firms.</p>
          <a class="card-link" href={`mailto:${siteConfig.email}?subject=Portfolio%20workshop%20or%20mentor%20enquiry`}>Email — Programme enquiry →</a>
        </article>
      </div>
      <p class="mt-6 text-sm" style="color:var(--muted, #666);">
        <strong>Response time:</strong> Enquiries are read by the operator, not a gatekeeper. Most enquiries get a reply within one working day. If it's a fit, you'll get a clear next step. If it isn't, you'll get an honest "no" or a referral to the right person.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <p class="eyebrow">Related reading</p>
      <h2>Self-serve before you email.</h2>
      <ul class="related-insights-list">
        {contactRelatedReading.map((item) => (
          <li>
            <a class="card-link" href={item.href}>
              {item.label} →
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section-alt">
    <div class="shell">
      <p class="eyebrow">FAQ</p>
      <h2>Contact and response expectations.</h2>
      <div class="grid-3">
        {contactFaqs.map((item) => (
          <article class="feature-card">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="shell cta-inner">
      <div>
        <p class="eyebrow">Rather talk it through?</p>
        <h2>Send the form — or book the call.</h2>
        <p>
          In {siteConfig.bookingCallDurationPhrase}, we can usually tell whether the constraint is positioning, acquisition, conversion, reporting, or ownership — and whether WSS is the right shape of help.
        </p>
      </div>
      <div class="hero-actions">
        <a
          class="button button-brand button-with-subcopy"
          href={siteConfig.bookingUrl}
          data-cta="contact-final-book"
          title={siteConfig.bookingCallReassurance}
        >
          <span class="button-label">{siteConfig.bookingLabel}</span>
          <span class="button-subcopy">{siteConfig.bookingSubcopy}</span>
        </a>
        <a class="button button-light" href={siteConfig.scorecardUrl} data-cta="contact-final-scorecard">
          Or, {siteConfig.scorecardLabel} →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ email: siteConfig.email }}>
  const form = document.getElementById("growth-enquiry");

  form?.addEventListener("submit", (event) => {
    event.preventDefault();
    const data = new FormData(form);
    const subject = `WSS enquiry from ${data.get("company") || data.get("name") || "website"}`;
    const body = [
      `Name: ${data.get("name") || ""}`,
      `Email: ${data.get("email") || ""}`,
      `Company: ${data.get("company") || ""}`,
      `Stage: ${data.get("stage") || ""}`,
      `ARR: ${data.get("arr") || ""}`,
      `Channels: ${data.get("channels") || ""}`,
      `Budget: ${data.get("budget") || ""}`,
      `Timeline: ${data.get("timeline") || ""}`,
      "",
      "Current bottleneck:",
      `${data.get("bottleneck") || ""}`,
      "",
      "Help needed:",
      `${data.get("help") || ""}`
    ].join("\n");

    window.location.href = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

    // Fallback so the enquiry never dead-ends if no mail client is configured.
    let note = document.getElementById("enquiry-fallback");
    if (!note) {
      note = document.createElement("div");
      note.id = "enquiry-fallback";
      note.setAttribute("role", "status");
      note.style.cssText = "margin-top:1rem;padding:1rem;border:1px solid currentColor;border-radius:8px;font-size:0.9rem;";
      form.appendChild(note);
    }
    note.innerHTML = `Your email draft should have opened. If it didn't, email <a href="mailto:${email}">${email}</a> directly — your message has been copied to the clipboard.`;
    if (navigator.clipboard) navigator.clipboard.writeText(`${subject}\n\n${body}`).catch(() => {});
  });
</script>
