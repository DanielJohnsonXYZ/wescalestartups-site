---
/** Visual map: growth inputs → WSS core loop → durable outcomes (Notion Growth Hub spec). */
interface Props {
  /** Alternate section background (paper-deep band). */
  tone?: "default" | "alt";
}

const { tone = "default" } = Astro.props;
const sectionClass = tone === "alt" ? "section section-alt wss-os-diagram" : "section wss-os-diagram";

const inputs = ["ICP", "Channels", "Funnel", "Reporting", "Team cadence"] as const;
const core = ["Diagnosis", "Experiments", "Reporting", "Weekly rhythm"] as const;
const outcomes = ["Pipeline clarity", "Decision rules", "Transfer pack"] as const;
---

<section class={sectionClass} aria-labelledby="wss-os-diagram-title">
  <div class="shell wss-os-inner">
    <header class="wss-os-head">
      <p class="eyebrow">The operating system</p>
      <h2 id="wss-os-diagram-title">What feeds the work — and what you leave with.</h2>
      <p class="wss-os-lede">
        A single picture of how growth inputs flow through diagnosis, experiments, and cadence into assets the team can run without founder heroics.
      </p>
    </header>

    <div class="wss-os-board" role="img" aria-label="Diagram: inputs ICP, channels, funnel, reporting, team cadence feed the WSS system of diagnosis, experiments, reporting, and weekly rhythm, producing pipeline clarity, decision rules, and a transfer pack.">
      <div class="wss-os-col wss-os-col--inputs">
        <h3 class="wss-os-col-title">Inputs</h3>
        <ul class="wss-os-chips">
          {inputs.map((label) => (
            <li>{label}</li>
          ))}
        </ul>
      </div>

      <span class="wss-os-arrow" aria-hidden="true">
        <svg width="48" height="24" viewBox="0 0 48 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M2 12h36m0 0l-8-8m8 8l-8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>

      <div class="wss-os-col wss-os-col--core">
        <h3 class="wss-os-col-title">WSS system</h3>
        <ul class="wss-os-core-list">
          {core.map((label) => (
            <li>{label}</li>
          ))}
        </ul>
      </div>

      <span class="wss-os-arrow" aria-hidden="true">
        <svg width="48" height="24" viewBox="0 0 48 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M2 12h36m0 0l-8-8m8 8l-8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>

      <div class="wss-os-col wss-os-col--out">
        <h3 class="wss-os-col-title">Outcomes</h3>
        <ul class="wss-os-chips wss-os-chips--out">
          {outcomes.map((label) => (
            <li>{label}</li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .wss-os-inner {
    max-width: 72rem;
  }

  .wss-os-head {
    max-width: 52ch;
    margin-bottom: 2rem;
  }

  .wss-os-head h2 {
    font-family:'Geist','Inter',ui-sans-serif,system-ui,sans-serif;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight:700;
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin: 0.45rem 0 0;
    color: var(--ink);
  }

  .wss-os-lede {
    margin: 0.85rem 0 0;
    color: var(--muted);
    line-height: 1.6;
    font-size: 1rem;
  }

  .wss-os-board {
    display: grid;
    gap: 1rem 0.5rem;
    align-items: stretch;
    grid-template-columns: 1fr;
    color: var(--ink);
  }

  @media (min-width: 900px) {
    .wss-os-board {
      grid-template-columns: 1fr auto 1.15fr auto 1fr;
      gap: 0.75rem 0.25rem;
      align-items: center;
    }
  }

  .wss-os-col {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 1rem;
    padding: 1.15rem 1.2rem 1.25rem;
    min-height: 100%;
  }

  .section-alt .wss-os-col {
    background: rgba(255, 254, 250, 0.92);
  }

  .wss-os-col--core {
    border-color: color-mix(in srgb, var(--violet) 38%, var(--line));
    box-shadow: 0 14px 40px -20px color-mix(in srgb, var(--violet) 35%, transparent);
  }

  .wss-os-col-title {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--violet);
    margin: 0 0 0.85rem;
  }

  .wss-os-chips {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .wss-os-chips li {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--ink-2);
    padding: 0.35rem 0.65rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--paper-deep) 65%, var(--surface));
    border: 1px solid var(--line);
  }

  .wss-os-chips--out li {
    background: color-mix(in srgb, var(--violet) 7%, var(--surface));
    border-color: color-mix(in srgb, var(--violet) 22%, var(--line));
  }

  .wss-os-core-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.55rem;
  }

  .wss-os-core-list li {
    position: relative;
    padding-left: 1.1rem;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.35;
  }

  .wss-os-core-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--violet);
  }

  .wss-os-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    color: color-mix(in srgb, var(--violet) 55%, var(--muted));
    transform: rotate(90deg);
    margin: -0.25rem 0;
  }

  @media (min-width: 900px) {
    .wss-os-arrow {
      transform: none;
      margin: 0;
    }
  }
</style>
