---
import { siteConfig } from "../site";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const isActive = (href: string) => href === "/" ? currentPath === "/" : currentPath.startsWith(href);
const navGroups = [
  { href: "/start-here", label: "Start here" },
  {
    href: "/services",
    label: "Services",
    children: [
      { href: "/services/growth-diagnosis", label: "Growth Diagnosis", note: "Name the bottleneck first" },
      { href: "/services/90-day-growth-sprint", label: "90-Day Sprint", note: "Focused execution cycle" },
      { href: "/services/acquisition-system-build", label: "Acquisition Build", note: "Channels, offers, reporting" },
      { href: "/services/fractional-cmo", label: "Fractional CMO", note: "Senior growth leadership" }
    ]
  },
  {
    href: "/proof",
    label: "Proof",
    children: [
      { href: "/case-studies", label: "Case studies", note: "Client work in context" },
      { href: "/testimonials", label: "Testimonials", note: "Founder and operator voices" },
      { href: "/fractional-cmo-vs-agency", label: "WSS vs agency", note: "When each model fits" }
    ]
  },
  { href: "/pricing", label: "Pricing" },
  {
    href: "/resources",
    label: "Resources",
    children: [
      { href: siteConfig.scorecardUrl, label: "Growth Bottleneck Scorecard", note: "10 questions, 5 minutes" },
      { href: "/insights", label: "Insights", note: "Strategic reads" },
      { href: "/podcast", label: "Podcast", note: "How Startups Win With AI" }
    ]
  },
  {
    href: "/about",
    label: "About",
    children: [
      { href: "/about", label: "About WSS", note: "Who we are for" },
      { href: "/about/daniel", label: "About Daniel", note: "Founder profile" },
      { href: "/press", label: "Speaking & press", note: "Talks, media, press kit" }
    ]
  }
] as const;

const isGroupActive = (item: typeof navGroups[number]) =>
  isActive(item.href) || ("children" in item && item.children.some((child) => isActive(child.href)));
---

<header class="site-header">
  <div class="shell header-inner">
    <a class="brand" href="/" aria-label="We Scale Startups home">
      <img
        src="/images/logos/wss-logo.webp"
        alt="We Scale Startups"
        width="120"
        height="68"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </a>
    <nav class="nav-links" aria-label="Primary navigation">
      {navGroups.map((item) => (
        "children" in item ? (
          <div class:list={["nav-dropdown", { "is-active": isGroupActive(item) }]}>
            <a class="nav-link nav-link-parent" href={item.href} aria-haspopup="true" aria-expanded="false">
              {item.label}
              <span aria-hidden="true">⌄</span>
            </a>
            <div class="nav-menu" aria-label={`${item.label} menu`}>
              {item.children.map((child) => (
                <a class:list={["nav-menu-link", { "is-active": isActive(child.href) }]} href={child.href}>
                  <strong>{child.label}</strong>
                  <span>{child.note}</span>
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a class:list={["nav-link", { "is-active": isGroupActive(item) }]} href={item.href}>{item.label}</a>
        )
      ))}
    </nav>
    <a
      class="button button-brand header-cta header-cta--stacked button-with-subcopy"
      href="/contact"
      data-cta="header-contact"
      aria-label="Contact We Scale Startups"
      title="Contact We Scale Startups"
    >
      <span class="button-label">Contact</span>
      <span class="button-subcopy">Send growth context.</span>
    </a>
    <details class="mobile-menu">
      <summary class="button button-light">Menu</summary>
      <nav aria-label="Mobile navigation">
        {navGroups.map((item) => (
          "children" in item ? (
            <div class="mobile-nav-group">
              <a class:list={["nav-link", { "is-active": isGroupActive(item) }]} href={item.href}>{item.label}</a>
              <div>
                {item.children.map((child) => (
                  <a class:list={["mobile-subnav-link", { "is-active": isActive(child.href) }]} href={child.href}>{child.label}</a>
                ))}
              </div>
            </div>
          ) : (
            <a class:list={["nav-link", { "is-active": isGroupActive(item) }]} href={item.href}>{item.label}</a>
          )
        ))}
        <a
          class="button button-brand button-with-subcopy"
          href="/contact"
          data-cta="mobile-contact"
          title="Contact We Scale Startups"
        >
          <span class="button-label">Contact</span>
          <span class="button-subcopy">Send growth context.</span>
        </a>
      </nav>
    </details>
  </div>
</header>

<style is:global>
  @import "../styles/mobile-qa.css";
</style>
